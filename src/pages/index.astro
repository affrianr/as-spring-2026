                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M14 5h5m0 0v5m0-5L10 14"></path>
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19 14v4a1 1 0 01-1 1h-12a1 1 0 01-1-1V6a1 1 0 011-1h4"
                    ></path>
                  </svg>
                </span>
              </a>

              <div class="access-composition__body">
                <p class="access-composition__address font-serif">
                  <span class="lang-mix"
                    >Perumahan Bumi Sumekar Asri, Kec. Kota Sumenep</span
                  >
                  <span class="lang-en"
                    >Perumahan Bumi Sumekar Asri, Kec. Kota Sumenep</span
                  >
                </p>

                <p class="access-composition__notes">
                  <span class="lang-mix">
                    Parkir tersedia di area sekitar lokasi acara.<br />
                    Silakan gunakan Google Maps untuk rute terbaik menuju venue.
                  </span>
                  <span class="lang-en">
                    Parking is available around the venue.<br />
                    Please use Google Maps for the best route to the venue.
                  </span>
                </p>
              </div>
            </div>
          </div>
        </section>

        <!-- Wedding Wish Section -->
        <section
          id="wishes"
          data-auto-scroll-section
          class="content-card content-card--transparent wish-section py-32 px-6"
        >
          <div class="wish-scene reveal" aria-hidden="true">
            <img
              src="/assets/p4a%20crop.webp"
              alt=""
              class="wish-scene__image"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="wish-shell">
            <div class="wish-shell__inner mx-auto">
              <div class="wish-grid">
                <div class="wish-panel wish-panel--form reveal">
                  <div class="wish-panel__body">
                    <div class="wish-panel__heading">
                      <h3 class="wish-panel__title font-serif">
                        <span class="lang-mix"
                          >Tuliskan doa dan ucapan manis untuk hari kami</span
                        >
                        <span class="lang-en"
                          >Leave a sweet note for our day</span
                        >
                      </h3>

                      <p class="wish-panel__copy">
                        <span class="lang-mix">
                          Nama dan pesan Anda akan langsung tampil di buku
                          ucapan ini.
                        </span>
                        <span class="lang-en">
                          Your name and message will appear instantly in this
                          guestbook.
                        </span>
                      </p>
                    </div>

                    <form
                      id="wish-form"
                      class="wish-form"
                      method="post"
                      action="/api/wishes"
                    >
                      <label class="wish-field">
                        <span class="wish-field__label">
                          <span class="lang-mix">Nama</span>
                          <span class="lang-en">Name</span>
                        </span>
                        <input
                          id="wish-name"
                          name="name"
                          type="text"
                          maxlength="80"
                          autocomplete="name"
                          required
                          class="wish-input"
                          data-placeholder-mix="Nama Anda"
                          data-placeholder-en="Your name"
                        />
                      </label>

                      <label class="wish-field">
                        <span class="wish-field__label">
                          <span class="lang-mix">Ucapan</span>
                          <span class="lang-en">Message</span>
                        </span>
                        <textarea
                          id="wish-message"
                          name="message"
                          rows="5"
                          maxlength="500"
                          required
                          class="wish-textarea"
                          data-placeholder-mix="Tuliskan doa, harapan, atau pesan manis Anda di sini."
                          data-placeholder-en="Write your prayer, blessing, or a short note here."
                        ></textarea>
                      </label>

                      <div class="wish-form__footer">
                        <button
                          type="submit"
                          class="wish-submit rsvp-btn inline-flex items-center gap-3 px-10 py-4 rounded-full text-sm font-medium tracking-widest uppercase transition-all duration-300"
                        >
                          <span class="lang-mix">Kirim Ucapan</span>
                          <span class="lang-en">Send Wish</span>
                          <svg
                            class="w-4 h-4 rsvp-arrow transition-transform duration-300"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                          </svg>
                        </button>

                        <p class="wish-form__note">
                          <span class="lang-mix">
                            Ucapan akan tampil segera setelah berhasil dikirim.
                          </span>
                          <span class="lang-en">
                            Your note will show up here as soon as it is sent.
                          </span>
                        </p>
                      </div>

                      <p
                        id="wish-status"
                        class="wish-status hidden"
                        role="status"
                        aria-live="polite"
                      >
                      </p>
                    </form>
                  </div>
                </div>

                <div
                  class="wish-panel wish-panel--list reveal"
                  data-delay="120"
                >
                  <div class="wish-list__top">
                    <div>
                      <h3 class="wish-list__title font-serif">
                        <span class="lang-mix"
                          >Ucapan hangat yang sudah sampai ke kami</span
                        >
                        <span class="lang-en"
                          >Warm wishes that have already reached us</span
                        >
                      </h3>

                      <p class="wish-list__deck">
                        <span class="lang-mix">
                          Geser kartu untuk melihat ucapan lainnya.
                        </span>
                        <span class="lang-en">
                          Swipe through the cards to see more wishes.
                        </span>
                      </p>
                    </div>
                  </div>

                  <div id="wish-stage" class="wish-stage">
                    <div id="wish-list" class="wish-list">
                      {
                        initialWishes.map((wish) => (
                          <article class="wish-card" data-wish-id={wish.id}>
                            <div class="wish-card__head">
                              <div>
                                <p class="wish-card__name">{wish.name}</p>
                                <p class="wish-card__date">
                                  <span class="lang-mix">
                                    {formatWishDate(wish.createdAt, 'id')}
                                  </span>
                                  <span class="lang-en">
                                    {formatWishDate(wish.createdAt, 'en')}
                                  </span>
                                </p>
                              </div>

                              <span class="wish-card__glyph" aria-hidden="true">
                                ✦
                              </span>
                            </div>

                            <p class="wish-card__message">{wish.message}</p>
                          </article>
                        ))
                      }
                    </div>

                    <p
                      id="wish-empty"
                      class={initialWishes.length > 0
                        ? 'wish-empty hidden'
                        : 'wish-empty'}
                    >
                      <span class="lang-mix">
                        Jadilah orang pertama yang meninggalkan ucapan untuk
                        kami.
                      </span>
                      <span class="lang-en">
                        Be the first to leave a note for our celebration.
                      </span>
                    </p>
                  </div>

                  <template id="wish-card-template">
                    <article class="wish-card" data-wish-id="">
                      <div class="wish-card__head">
                        <div>
                          <p class="wish-card__name"></p>
                          <p class="wish-card__date">
                            <span class="lang-mix"></span>
                            <span class="lang-en"></span>
                          </p>
                        </div>

                        <span class="wish-card__glyph" aria-hidden="true"
                          >✦</span
                        >
                      </div>

                      <p class="wish-card__message"></p>
                    </article>
                  </template>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>

      <!-- Footer -->
      <footer
        data-auto-scroll-section
        class="content-card py-16 px-6 text-center"
      >
        <div class="footer-shell desktop-reading-block space-y-4 font-serif">
          <p class="text-xs mt-8">
            Thank you for being part of our special day
          </p>
          <div class="flex items-center justify-center gap-4 mt-6">
            <div class="h-px w-16 bg-charcoal/10 divider-line"></div>
            <div class="w-2 h-2 rounded-full bg-lime footer-dot"></div>
            <div class="h-px w-16 bg-charcoal/10 divider-line"></div>
          </div>

          <p class="text-xs">© 2026 · Made with love ❤️</p>
        </div>
      </footer>
    </div><!-- .content-cards -->
  </div><!-- #content-layer -->
</Layout>

<style>
