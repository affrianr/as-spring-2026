  /* ── Accessibility: users who prefer reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .hero-bg-image,
    .hero-scene__mountain,
    .hero-scene__cat {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }
