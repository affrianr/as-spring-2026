---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import type { WeddingWish } from '../lib/wedding-wishes';
import { listWeddingWishes } from '../lib/wedding-wishes';

const wishDateFormatterId = new Intl.DateTimeFormat('id-ID', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const wishDateFormatterEn = new Intl.DateTimeFormat('en-US', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const formatWishDate = (timestamp: number, locale: 'id' | 'en') =>
  (locale === 'id' ? wishDateFormatterId : wishDateFormatterEn).format(
    new Date(timestamp),
  );

let initialWishes: WeddingWish[] = [];

try {
  initialWishes = await listWeddingWishes(Astro.locals.runtime?.env?.DB, 6);
} catch (error) {
  console.error('Failed to render wedding wishes', error);
}
---

<Layout>
  <!-- Scrollable content layer -->
  <div id="content-layer" class="relative z-10">
    <SiteNav currentPage="home" showMusicToggle={true} />

    <!-- Hero Section — transparent, shows background -->
    <section
      id="home"
      data-auto-scroll-section
      class="hero-section relative flex items-center justify-center"
    >
      <div id="bg-main" class="absolute inset-0 z-0" aria-hidden="true">
        <img
          src="/assets/p1.webp"
          alt=""
          class="main-bg-image hero-bg-image absolute inset-0 h-full w-full object-cover object-center"
          loading="eager"
          decoding="async"
        />
        <div
          class="absolute inset-0 bg-gradient-to-b from-charcoal/40 via-charcoal/18 to-charcoal/32 transition-opacity duration-700"
        >
        </div>
      </div>

      <div class="hero-scene" aria-hidden="true">
        <div class="hero-scene__mountain"></div>
        <img
          src="/assets/p1b-r1-crop-smaller.webp"
          alt=""
          class="hero-scene__couple"
          loading="eager"
          decoding="async"
        />
        <div class="">
          <img
            src="/assets/gio2-smaller.webp"
            alt=""
            class="hero-scene__cat hero-scene__cat--left"
            loading="lazy"
            decoding="async"
          />
          <img
            src="/assets/coco2-smaller.webp"
            alt=""
            class="hero-scene__cat hero-scene__cat--right"
            loading="lazy"
            decoding="async"
          />
          <img
            src="/assets/ucil2-smaller.webp"
            alt=""
            class="hero-scene__cat hero-scene__cat--center"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>

      <div
        class="hero-content hero-shell relative text-center px-6 pt-20 text-white"
      >
        <div class="inline-block mb-8 reveal" data-delay="0">
          <span class="text-xs tracking-[0.3em] uppercase text-white/70"
            >Wedding Invitation</span
          >
        </div>

        <h1
          class="font-display text-6xl md:text-8xl lg:text-9xl font-normal tracking-tight mb-6 drop-shadow-lg"
        >
          <span class="block reveal" data-delay="200">Affrian</span>
          <span
            class="block text-2xl md:text-3xl text-white/70 font-sans font-light my-4 reveal"
            data-delay="400">&</span
          >
          <span class="block reveal" data-delay="600">Sherly</span>
        </h1>

        <div class="space-y-2 reveal" data-delay="1000">
          <p
            class="font-serif text-2xl md:text-3xl tracking-widest drop-shadow-md"
          >
            02.05.2026
          </p>
          <p class="text-xs tracking-[0.3em] uppercase text-white/60">
            Saturday
          </p>
        </div>

        <button
          type="button"
          data-auto-scroll-next
          class="hero-scroll-cue mt-20 inline-flex items-center justify-center reveal cursor-pointer bg-transparent p-0 text-white/40 transition-colors duration-300 hover:text-white focus:outline-none"
          data-delay="1200"
          aria-label="Scroll to next section"
        >
          <svg
            class="w-5 h-5 mx-auto"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 14l-7 7m0 0l-7-7"></path>
          </svg>
        </button>
      </div>
    </section>

    <!-- Content card sections float above the background -->
    <div class="content-cards">
      <!-- Greeting Section -->
      <section
        id="greeting"
        data-auto-scroll-section
        class="px-6 py-20 md:py-24 flex items-end"
