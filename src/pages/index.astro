                      >
                      <span
                        class="text-[9px] tracking-widest uppercase text-charcoal/50"
                      >
                        <span class="lang-mix">Menit</span>
                        <span class="lang-en">Min</span>
                      </span>
                    </div>
                    <span class="text-xl text-charcoal/30 font-light mt-0.5"
                      >:</span
                    >
                    <div class="text-center">
                      <span
                        id="cd-secs"
                        class="block text-2xl font-serif text-charcoal tabular-nums"
                        >--</span
                      >
                      <span
                        class="text-[9px] tracking-widest uppercase text-charcoal/50"
