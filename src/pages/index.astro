            </svg>

            <div class="flex flex-col md:flex-row items-stretch gap-0">
              <!-- Text content -->
              <div
                class="calendar-card__body flex-1 flex flex-col justify-between p-6 md:p-8"
              >
                <div>
                  <div class="calendar-card__header flex items-center">
                    <div class="calendar-card__copy-wrap">
                      <p
                        class="calendar-card__title font-serif italic text-2xl md:text-3xl text-charcoal mb-2"
