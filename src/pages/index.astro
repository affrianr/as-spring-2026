---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Fixed background artwork -->
  <div id="bg-main" class="fixed inset-0 z-0" aria-hidden="true">
    <img
      src="/assets/p1.png"
      alt=""
      class="main-bg-image absolute inset-0 h-full w-full object-cover object-center"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-charcoal/40 via-charcoal/18 to-charcoal/32 transition-opacity duration-700"></div>
  </div>

  <!-- Scrollable content layer -->
  <div id="content-layer" class="relative z-10">

    <!-- Navigation -->
    <nav id="main-nav" data-auto-scroll-header class="fixed top-0 left-0 right-0 z-9999 transition-all duration-500">
      <div class="nav-shell desktop-shell max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <span class="font-serif text-sm tracking-widest uppercase nav-logo text-white drop-shadow-sm">A & S</span>
        <div class="flex items-center gap-6">
          <div class="hidden md:flex gap-8 text-xs tracking-widest uppercase text-white/70">
            <a href="#home" class="nav-link relative hover:text-white transition-colors duration-300">Top</a>
            <a href="#greeting" class="nav-link relative hover:text-white transition-colors duration-300">Greeting</a>
            <a href="/gallery" class="nav-link relative hover:text-white transition-colors duration-300">Gallery</a>
            <a href="#details" class="nav-link relative hover:text-white transition-colors duration-300">Details</a>
            <a href="#schedule" class="nav-link relative hover:text-white transition-colors duration-300">Timeline</a>
            <a href="#access" class="nav-link relative hover:text-white transition-colors duration-300">Access</a>
            <a href="#rsvp" class="nav-link relative hover:text-white transition-colors duration-300">RSVP</a>
          </div>
          <!-- Language toggle -->
          <button id="lang-toggle" class="lang-toggle flex items-center gap-1.5 text-[10px] tracking-widest uppercase text-white/60 hover:text-white border border-white/20 hover:border-white/40 rounded-full px-3 py-1.5 transition-all duration-300" aria-label="Toggle language">
            <span class="lang-label-mix">ID / EN</span>
            <span class="lang-label-en hidden">EN</span>
            
          </button>
        </div>
      </div>
    </nav>

    <!-- Hero Section — transparent, shows background -->
    <section id="home" data-auto-scroll-section class="hero-section relative min-h-screen flex items-center justify-center">
      <div class="hero-scene" aria-hidden="true">
        <div class="hero-scene__mountain"></div>
        <img
          src="/assets/p1%20b%20crop.png"
          alt=""
          class="hero-scene__couple translateY-30"
          loading="eager"
          decoding="async"
        />
        <div class="">
          <img src="/assets/gio2.webp"  alt="" class="hero-scene__cat hero-scene__cat--left"   loading="lazy" decoding="async"/>
          <img src="/assets/coco2.webp"  alt="" class="hero-scene__cat hero-scene__cat--right"  loading="lazy" decoding="async"/>
          <img src="/assets/ucil2.webp"   alt="" class="hero-scene__cat hero-scene__cat--center" loading="lazy" decoding="async"/>
        </div>
      </div>

      <div class="hero-content hero-shell relative text-center px-6 pt-20 text-white">
        <div class="inline-block mb-8 reveal" data-delay="0">
          <span class="text-xs tracking-[0.3em] uppercase text-white/70">Wedding Invitation</span>
        </div>

        <h1 class="font-serif text-6xl md:text-8xl lg:text-9xl font-normal tracking-tight mb-6 drop-shadow-lg">
          <span class="block reveal" data-delay="200">Affrian</span>
          <span class="block text-2xl md:text-3xl text-white/70 font-sans font-light my-4 reveal" data-delay="400">&</span>
          <span class="block reveal" data-delay="600">Sherly</span>
        </h1>

        <div class="space-y-2 reveal" data-delay="1000">
          <p class="font-serif text-2xl md:text-3xl tracking-widest drop-shadow-md">2026.05.02</p>
          <p class="text-xs tracking-[0.3em] uppercase text-white/60">Saturday</p>
        </div>

        <button
          type="button"
          data-auto-scroll-next
          class="mt-20 inline-flex items-center justify-center animate-bounce reveal cursor-pointer bg-transparent p-0 text-white/40 transition-colors duration-300 hover:text-white focus:outline-none"
          data-delay="1200"
          aria-label="Scroll to next section"
        >
          <svg class="w-5 h-5 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
          </svg>
        </button>
      </div>
    </section>

    <!-- Content card sections float above the background -->
    <div class="content-cards">

      <!-- Greeting Section -->
      <section
        id="greeting"
        data-auto-scroll-section
        class="min-h-screen px-6 py-20 md:py-24 flex items-end"
      >
        <div class="greeting-panel" aria-hidden="true"></div>
        <!-- <div class="max-w-2xl mx-auto text-center">
          <div class="inline-block bg-lime/20 px-4 py-1.5 rounded-full mb-12 reveal">
            <span class="text-xs tracking-[0.2em] uppercase font-medium">Greeting</span>
          </div>

          <div class="lang-mix">
            <p class="font-serif text-lg md:text-xl leading-loose tracking-wide reveal">
              Dengan penuh kebahagiaan kami<br />
              akan melangsungkan pernikahan
            </p>

            <p class="mt-8 text-sm leading-loose text-muted tracking-wide reveal">
              Bersama keluarga tercinta kami bermaksud<br />
              mengundang Bapak/Ibu/Saudara/i<br />
              untuk hadir menyaksikan hari bahagia kami
            </p>

            <p class="mt-8 text-sm leading-loose text-muted tracking-wide reveal">
              Merupakan kebahagiaan yang besar bagi kami<br />
              apabila Anda berkenan hadir<br />
              dan memberikan doa restu
            </p>

            <div class="mt-12 flex items-center justify-center gap-4 reveal">
              <div class="h-px w-12 bg-charcoal/20 divider-line"></div>
              <p class="text-xs tracking-[0.3em] text-muted">Musim Semi 2026</p>
              <div class="h-px w-12 bg-charcoal/20 divider-line"></div>
            </div>
          </div>

          <div class="lang-en">
            <p class="font-serif text-lg md:text-xl leading-relaxed tracking-wide reveal">
              We are delighted to announce<br />
              that we are getting married
            </p>

            <p class="mt-8 text-sm leading-relaxed text-muted tracking-wide reveal">
              We would be honored to have you,<br />
              our dear family and friends,<br />
              join us as we celebrate our ceremony.
            </p>

            <p class="mt-8 text-sm leading-relaxed text-muted tracking-wide reveal">
              We know how precious your time is,<br />
              and it would mean the world to us<br />
              if you could be there.
            </p>

            <div class="mt-12 flex items-center justify-center gap-4 reveal">
              <div class="h-px w-12 bg-charcoal/20 divider-line"></div>
              <p class="text-xs tracking-[0.3em] text-muted">Spring, 2026</p>
              <div class="h-px w-12 bg-charcoal/20 divider-line"></div>
            </div>

            <p class="mt-6 font-serif text-sm tracking-widest reveal">
              Affrian & Sherly
            </p>
          </div>
        </div> -->

        <div class="greeting-content desktop-reading-block mx-auto max-w-full text-center pb-[30vh] md:pb-[10vh]">
          <p class="font-serif text-sm md:text-base leading-relaxed tracking-[0.02em] reveal">
            &ldquo;Dan di antara tanda-tanda (kebesaran)-Nya ialah<br />
            Dia menciptakan pasangan-pasangan untukmu dari<br />
            jenismu sendiri, agar kamu cenderung dan merasa<br />
            tenteram kepadanya, dan Dia menjadikan di antaramu rasa<br />
            kasih dan sayang. Sesungguhnya pada yang demikian itu<br />
            benar-benar terdapat tanda-tanda (kebesaran Allah) bagi<br />
            kaum yang berpikir.&rdquo;
          </p>
          <p class="font-serif text-sm md:text-base leading-relaxed tracking-[0.02em] reveal">(QS. Ar-Rum: 21)</p>
        </div>
        <div class="greeting-cats" aria-hidden="true">
          <img
            src="/assets/gio2.webp"
            alt=""
            class="greeting-cat greeting-cat--gio"
            loading="lazy"
            decoding="async"
          />
          <img
            src="/assets/coco2.webp"
            alt=""
            class="greeting-cat greeting-cat--coco"
            loading="lazy"
            decoding="async"
          />
          <img
            src="/assets/ucil2.webp"
            alt=""
            class="greeting-cat greeting-cat--ucil"
            loading="lazy"
            decoding="async"
          />
        </div>
      </section>
    <!-- Transparent spacer — background shows through -->
      <div class="ambient-spacer ambient-spacer--after-greeting h-[50vh]"></div>

      <!-- Countdown / Calendar teaser -->
      <section id="gallery" data-auto-scroll-section class="py-16 px-6 relative">
        <div class="calendar-shell desktop-shell max-w-3xl mx-auto reveal">
          <a
            href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Affrian+%26+Sherly+Wedding+Ceremony&dates=20260502T140000/20260502T153000&details=Join+us+for+the+wedding+ceremony+of+Affrian+and+Sherly.&location=Masjid+Besar+Riyadhus+Sholihin%2C+Perumahan+Bumi+Sumekar+Asri%2C+Kec.+Kota+Sumenep&ctz=Asia%2FJakarta"
            target="_blank"
            rel="noreferrer"
            class="gallery-teaser calendar-card group block relative overflow-hidden rounded-2xl bg-lime transition-transform duration-500 hover:-translate-y-1"
          >
            <!-- Decorative sparkles -->
            <svg class="sparkle absolute top-6 right-12 w-4 h-4 text-lime-dark/40" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41Z"/>
            </svg>
            <svg class="sparkle absolute top-16 right-24 w-3 h-3 text-lime-dark/30" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41Z"/>
            </svg>
            <svg class="sparkle absolute bottom-20 left-8 w-3 h-3 text-lime-dark/25" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41Z"/>
            </svg>
            <!-- Decorative curved line -->
            <svg class="absolute inset-0 w-full h-full pointer-events-none opacity-20" viewBox="0 0 600 300" fill="none" preserveAspectRatio="none">
              <path d="M-20 250 Q150 100 300 180 Q450 260 620 80" stroke="currentColor" stroke-width="1.5" class="text-lime-dark"/>
            </svg>

            <div class="calendar-card__layout flex flex-col md:flex-row items-stretch gap-0">
              <!-- Calendar visual -->
              <div class="calendar-card__visual relative md:w-[55%] aspect-[4/3] md:aspect-auto overflow-hidden m-4 md:m-5 md:mr-0 rounded-xl bg-charcoal/10 flex items-center justify-center min-h-[220px]">
                <div class="text-center px-6" id="calendar-card-visual">
                  <svg class="w-12 h-12 mx-auto mb-4 text-charcoal/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 2v4m8-4v4M3.5 9.5h17M5 5.5h14A1.5 1.5 0 0120.5 7v12A1.5 1.5 0 0119 20.5H5A1.5 1.5 0 013.5 19V7A1.5 1.5 0 015 5.5z" />
                  </svg>
                  <p class="text-xs tracking-[0.28em] uppercase text-charcoal/40">
                    <span class="lang-mix">2 Mei 2026</span>
                    <span class="lang-en">May 2, 2026</span>
                  </p>
                  <p class="mt-3 font-serif text-2xl text-charcoal">
                    <span class="lang-mix">14.00 WIB</span>
                    <span class="lang-en">2:00 PM</span>
                  </p>
                  <p class="mt-3 text-sm leading-relaxed text-charcoal/65">
                    <span class="lang-mix">Masjid Besar Riyadhus Sholihin</span>
                    <span class="lang-en">Masjid Besar Riyadhus Sholihin</span>
                  </p>
                </div>
              </div>

              <!-- Text content -->
              <div class="calendar-card__body flex-1 flex flex-col justify-between p-6 md:p-8">
                <div>
                  <p class="calendar-card__title font-serif italic text-2xl md:text-3xl text-charcoal mb-2">
                    <span class="lang-mix">Save it to calendar</span>
                    <span class="lang-en">Save it to calendar</span>
                  </p>
                  <p class="calendar-card__copy text-sm leading-relaxed text-charcoal/70 max-w-sm">
                    <span class="lang-mix">Simpan tanggal akad kami ke Google Calendar agar tidak terlewat.</span>
                    <span class="lang-en">Add our ceremony to Google Calendar so the date stays on your schedule.</span>
                  </p>
                  <!-- Countdown -->
                  <div id="countdown" class="calendar-countdown flex gap-3 mt-3">
                    <div class="text-center">
                      <span id="cd-days" class="block text-2xl font-serif text-charcoal tabular-nums">--</span>
                      <span class="text-[9px] tracking-widest uppercase text-charcoal/50">
                        <span class="lang-mix">Hari</span>
                        <span class="lang-en">Days</span>
                      </span>
                    </div>
                    <span class="text-xl text-charcoal/30 font-light mt-0.5">:</span>
                    <div class="text-center">
                      <span id="cd-hours" class="block text-2xl font-serif text-charcoal tabular-nums">--</span>
                      <span class="text-[9px] tracking-widest uppercase text-charcoal/50">
                        <span class="lang-mix">Jam</span>
                        <span class="lang-en">Hrs</span>
                      </span>
                    </div>
                    <span class="text-xl text-charcoal/30 font-light mt-0.5">:</span>
                    <div class="text-center">
                      <span id="cd-mins" class="block text-2xl font-serif text-charcoal tabular-nums">--</span>
                      <span class="text-[9px] tracking-widest uppercase text-charcoal/50">
                        <span class="lang-mix">Menit</span>
                        <span class="lang-en">Min</span>
                      </span>
                    </div>
                    <span class="text-xl text-charcoal/30 font-light mt-0.5">:</span>
                    <div class="text-center">
                      <span id="cd-secs" class="block text-2xl font-serif text-charcoal tabular-nums">--</span>
                      <span class="text-[9px] tracking-widest uppercase text-charcoal/50">
                        <span class="lang-mix">Detik</span>
                        <span class="lang-en">Sec</span>
                      </span>
                    </div>
                  </div>
                </div>
                <div class="calendar-card__footer flex items-center justify-between mt-6">
                  <p class="text-sm text-charcoal/70 leading-snug" id="calendar-link-text">
                    <span class="lang-mix">Buka Google Calendar<br/>dan simpan acaranya</span>
                    <span class="lang-en">Open Google Calendar<br/>and save the event</span>
                  </p>
                  <div class="w-10 h-10 rounded-full border border-charcoal/20 flex items-center justify-center transition-all duration-300 group-hover:bg-charcoal group-hover:border-charcoal">
                    <svg class="w-5 h-5 text-charcoal transition-colors duration-300 group-hover:text-lime" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                  </div>
                </div>
              </div>
            </div>
          </a>
        </div>
      </section>

      <!-- Couple Introduction -->
      <section id="introduction" data-auto-scroll-section class="content-card content-card--transparent py-32 px-6">
        <div class="couple-shell desktop-shell max-w-5xl mx-auto">
          <div class="text-center mb-6">
            <div class="inline-block bg-lime/20 px-4 py-1.5 rounded-full mb-6 reveal">
              <span class="text-xs tracking-[0.2em] uppercase font-medium">
                <span >The Couple</span>
              </span>
            </div>
          </div>

          <div class="grid gap-10 md:gap-14">
            <div class="couple-card-group reveal">
              <article class="couple-card rounded-[2rem] p-4 md:p-8">
                <div class="couple-card__text text-left">
                  <p class="couple-card__eyebrow mb-5">
                    <span class="lang-mix">Mempelai Wanita</span>
                    <span class="lang-en">Bride</span>
                  </p>
                  <h3 class="couple-card__name font-serif mb-5">
                    Syafazerlinda
                  </h3>
                  <div class="lang-mix couple-card__meta space-y-2">
                    <p>Putri kedua dari</p>
                    <p>Bpk. Moch. Syafi'i &amp; Ibu Fatimah Umar</p>
                  </div>
                  <div class="lang-en couple-card__meta space-y-2">
                    <p>Second daughter of</p>
                    <p>Mr. Moch. Syafi'i &amp; Mrs. Fatimah Umar</p>
                  </div>
                </div>
              </article>

              <div class="couple-card__portrait" aria-hidden="true">
                <img
                  src="/assets/sherly.png"
                  alt=""
                  class="couple-card__portrait-image"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>

            <div class="couple-card-group reveal">
              <div class="couple-card__portrait couple-card__portrait--left" aria-hidden="true">
                <img
                  src="/assets/rian.png"
                  alt=""
                  class="couple-card__portrait-image"
                  loading="lazy"
                  decoding="async"
                />
              </div>

              <article class="couple-card rounded-[2rem] p-6 md:p-8">
                <div class="couple-card__text text-left">
                  <p class="couple-card__eyebrow mb-5">
                    <span class="lang-mix">Mempelai Pria</span>
                    <span class="lang-en">Groom</span>
                  </p>
                  <h3 class="couple-card__name font-serif mb-5">
                    Affrian Rachmansyah
                  </h3>
                  <div class="lang-mix couple-card__meta space-y-2">
                    <p>Putra pertama dari</p>
                    <p>Bpk. Yanuk Fatchorrahman (Alm.) &amp; Ibu Dinar Rahmawati</p>
                  </div>
                  <div class="lang-en couple-card__meta space-y-2">
                    <p>First son of</p>
                    <p>Mr. Yanuk Fatchorrahman (late) &amp; Mrs. Dinar Rahmawati</p>
                  </div>
                </div>
              </article>
            </div>
          </div>
        </div>
      </section>

  
      <!-- Transparent spacer -->
      <div class="ambient-spacer h-[50vh]"></div>

      <!-- Details Section -->
      <section id="details" data-auto-scroll-section class="content-card py-32 px-6">
        <div class="details-layout desktop-shell max-w-3xl mx-auto">
          <div class="details-header text-center mb-16">
            <div class="inline-block bg-lime/20 px-4 py-1.5 rounded-full mb-6 reveal">
              <span class="text-xs tracking-[0.2em] uppercase font-medium">Details</span>
            </div>
            <h2 class="font-serif text-3xl md:text-4xl reveal">
              <span class="lang-mix">Akad</span>
              <span class="lang-en">Ceremony</span>
            </h2>
          </div>

          <div class="details-grid grid md:grid-cols-2 gap-12 md:gap-16">
            <div class="detail-card text-center md:text-left p-8 rounded-2xl transition-all duration-500 reveal">
              <h3 class="text-xs tracking-[0.2em] uppercase text-muted mb-4">Date & Time</h3>
              <p class="font-serif text-xl mb-2">
                <span class="lang-mix">2 Mei 2026 (Sabtu)</span>
                <span class="lang-en">May 2, 2026 (Sat)</span>
              </p>
              <div class="space-y-1 text-sm text-muted">
                <span class="lang-mix">
                  <p>Akad: 14.00 WIB</p>
                </span>
                <span class="lang-en">
                  <p>Ceremony: 2:00 PM</p>
                </span>
              </div>
            </div>

            <div class="detail-card text-center md:text-left p-8 rounded-2xl transition-all duration-500 reveal">
              <h3 class="text-xs tracking-[0.2em] uppercase text-muted mb-4">Venue</h3>
              <p class="font-serif text-xl mb-2">Masjid Besar Riyadhus Sholihin</p>
              <p class="text-sm text-muted">
                <span class="lang-mix">
                  Perumahan Bumi Sumekar Asri<br />
                  Kec. Kota Sumenep
                </span>
                <span class="lang-en">
                  Perumahan Bumi Sumekar Asri<br />
                  Kec. Kota Sumenep
                </span>
              </p>
            </div>
          </div>

          <div class="details-dress mt-16 text-center border-t border-charcoal/10 pt-12 reveal">
            <h3 class="text-xs tracking-[0.2em] uppercase text-muted mb-4">Dress Code</h3>
            <p class="font-serif text-lg">
              <span class="lang-mix">Semi Formal</span>
              <span class="lang-en">Semi-Formal</span>
            </p>
            <p class="mt-2 text-sm text-muted lang-mix">Busana semi formal</p>
            <p class="mt-2 text-sm text-muted lang-en">Cocktail attire welcome</p>
          </div>
        </div>
      </section>

      <!-- Schedule Section -->
      <section id="schedule" data-auto-scroll-section class="content-card py-32 px-6">
        <div class="schedule-shell desktop-reading-block max-w-2xl mx-auto">
          <div class="text-center mb-16">
            <div class="inline-block bg-lime/20 px-4 py-1.5 rounded-full mb-6 reveal">
              <span class="text-xs tracking-[0.2em] uppercase font-medium">Schedule</span>
            </div>
            <h2 class="font-serif text-3xl md:text-4xl reveal">
              <span class="lang-mix">Rangkaian Acara</span>
              <span class="lang-en">Timeline</span>
            </h2>
          </div>

          <div class="space-y-0">
            {[
              { time: "1:30 PM", label: "Registrasi dibuka", labelEn: "Doors Open" },
              { time: "2:00 PM", label: "Akad", labelEn: "Ceremony" },
              { time: "2:30 PM", label: "Foto bersama", labelEn: "Group Photo" },
            ].map((item, i) => (
              <div class="flex items-start gap-8 group timeline-item reveal">
                <div class="w-20 text-right shrink-0">
                  <span class="font-serif text-lg transition-colors duration-300 group-hover:text-charcoal">{item.time}</span>
                </div>
                <div class="flex flex-col items-center shrink-0">
                  <div class="w-3 h-3 rounded-full bg-lime border-2 border-charcoal/20 transition-all duration-300 group-hover:scale-150 group-hover:bg-lime group-hover:border-lime group-hover:shadow-[0_0_12px_rgba(225,255,0,0.5)]"></div>
                  {i < 2 && <div class="w-px h-16 bg-charcoal/10 transition-colors duration-300 group-hover:bg-lime/40"></div>}
                </div>
                <div class="pb-16 last:pb-0 transition-transform duration-300 group-hover:translate-x-1">
                  <p class="font-medium">
                    <span class="lang-mix">{item.label}</span>
                    <span class="lang-en">{item.labelEn}</span>
                  </p>
                  <p class="text-xs text-muted mt-1 lang-mix">{item.labelEn}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Transparent spacer -->
      <div class="ambient-spacer h-[50vh]"></div>

      <!-- Access Section -->
      <section id="access" data-auto-scroll-section class="content-card py-32 px-6">
        <div class="access-layout desktop-shell max-w-3xl mx-auto">
          <div class="access-header text-center mb-16">
            <div class="inline-block bg-lime/20 px-4 py-1.5 rounded-full mb-6 reveal">
              <span class="text-xs tracking-[0.2em] uppercase font-medium">Access</span>
            </div>
