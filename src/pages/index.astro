    top: 100%;
    right: 8%;
    width: 25%;
  }
  /* Center cat (ucil) — bottom-center, largest */
  .hero-scene__cat--center {
    top: 120%;
    left: 50%;
    transform: translateX(-50%);
    width: 30%;
  }
