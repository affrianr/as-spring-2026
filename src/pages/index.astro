---
import Layout from '../layouts/Layout.astro';

const bgImages = [
  "https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=2000&q=80",
  "https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?auto=format&fit=crop&w=2000&q=80",
  "https://images.unsplash.com/photo-1520854221256-17451cc331bf?auto=format&fit=crop&w=2000&q=80",
  "https://images.unsplash.com/photo-1519167758481-83f550bb49b3?auto=format&fit=crop&w=2000&q=80",
  "https://images.unsplash.com/photo-1478146059778-26028b07395a?auto=format&fit=crop&w=2000&q=80",
  "https://images.unsplash.com/photo-1511285560929-80b456fea0bc?auto=format&fit=crop&w=2000&q=80",
];
---

<Layout>
  <!-- Fixed background slideshow -->
  <div id="bg-slideshow" class="fixed inset-0 z-0">
    {bgImages.map((src, i) => (
      <img
        src={src}
        alt=""
        class:list={["bg-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-[2000ms] ease-in-out", i === 0 ? "opacity-100" : "opacity-0"]}
        data-index={i}
        loading={i === 0 ? "eager" : "lazy"}
      />
    ))}
    <!-- Overlay that darkens/lightens based on content -->
    <div id="bg-overlay" class="absolute inset-0 bg-charcoal/40 transition-opacity duration-700"></div>
  </div>

  <!-- Scrollable content layer -->
  <div id="content-layer" class="relative z-10">

    <!-- Navigation -->
    <nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <span class="font-serif text-sm tracking-widest uppercase nav-logo text-white drop-shadow-sm">A & S</span>
        <div class="flex items-center gap-6">
          <div class="hidden md:flex gap-8 text-xs tracking-widest uppercase text-white/70">
            <a href="#home" class="nav-link relative hover:text-white transition-colors duration-300">Top</a>
            <a href="#greeting" class="nav-link relative hover:text-white transition-colors duration-300">Greeting</a>
            <a href="/gallery" class="nav-link relative hover:text-white transition-colors duration-300">Gallery</a>
            <a href="#details" class="nav-link relative hover:text-white transition-colors duration-300">Details</a>
            <a href="#schedule" class="nav-link relative hover:text-white transition-colors duration-300">Timeline</a>
            <a href="#access" class="nav-link relative hover:text-white transition-colors duration-300">Access</a>
            <a href="#rsvp" class="nav-link relative hover:text-white transition-colors duration-300">RSVP</a>
          </div>
          <!-- Language toggle -->
          <button id="lang-toggle" class="lang-toggle flex items-center gap-1.5 text-[10px] tracking-widest uppercase text-white/60 hover:text-white border border-white/20 hover:border-white/40 rounded-full px-3 py-1.5 transition-all duration-300" aria-label="Toggle language">
            <span class="lang-label-mix">JP / EN</span>
            <span class="lang-label-en hidden">EN</span>
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- Hero Section — transparent, shows background -->
    <section id="home" class="relative min-h-screen flex items-center justify-center">
      <div class="relative text-center px-6 pt-20 hero-content text-white">
        <div class="inline-block mb-8 reveal" data-delay="0">
          <span class="text-xs tracking-[0.3em] uppercase text-white/70">Wedding Invitation</span>
        </div>

        <h1 class="font-serif text-6xl md:text-8xl lg:text-9xl font-normal tracking-tight mb-6 drop-shadow-lg">
          <span class="block reveal" data-delay="200">Affrian</span>
          <span class="block text-2xl md:text-3xl text-white/70 font-sans font-light my-4 reveal" data-delay="400">&</span>
          <span class="block reveal" data-delay="600">Sherly</span>
        </h1>

        <div class="space-y-2 reveal" data-delay="1000">
          <p class="font-serif text-2xl md:text-3xl tracking-widest drop-shadow-md">2026.05.02</p>
          <p class="text-xs tracking-[0.3em] uppercase text-white/60">Saturday</p>
        </div>

        <div class="mt-20 animate-bounce reveal" data-delay="1200">
          <svg class="w-5 h-5 mx-auto text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
          </svg>
        </div>
      </div>
    </section>

    <!-- Content card sections float above the background -->
    <div class="content-cards">

      <!-- Greeting Section -->
      <section id="greeting" class="content-card py-32 px-6">
        <div class="max-w-2xl mx-auto text-center">
          <div class="inline-block bg-lime/20 px-4 py-1.5 rounded-full mb-12 reveal">
            <span class="text-xs tracking-[0.2em] uppercase font-medium">Greeting</span>
          </div>

          <div class="lang-mix">
            <p class="font-serif text-lg md:text-xl leading-loose tracking-wide reveal">
              このたび 私たちは<br />
              結婚式を挙げることになりました
            </p>

            <p class="mt-8 text-sm leading-loose text-muted tracking-wide reveal">
              つきましては 日頃お世話になっている<br />
              皆様にお集まりいただき<br />
              挙式を執り行いたいと存じます
            </p>

            <p class="mt-8 text-sm leading-loose text-muted tracking-wide reveal">
              おいそがしいところ 誠に恐縮ではございますが<br />
              ぜひご出席くださいますよう<br />
              お願い申し上げます
            </p>

            <div class="mt-12 flex items-center justify-center gap-4 reveal">
              <div class="h-px w-12 bg-charcoal/20 divider-line"></div>
              <p class="text-xs tracking-[0.3em] text-muted">2026年 春</p>
              <div class="h-px w-12 bg-charcoal/20 divider-line"></div>
            </div>
          </div>

          <div class="lang-en">
            <p class="font-serif text-lg md:text-xl leading-relaxed tracking-wide reveal">
              We are delighted to announce<br />
              that we are getting married
            </p>

            <p class="mt-8 text-sm leading-relaxed text-muted tracking-wide reveal">
              We would be honored to have you,<br />
              our dear family and friends,<br />
              join us as we celebrate our ceremony.
            </p>

            <p class="mt-8 text-sm leading-relaxed text-muted tracking-wide reveal">
              We know how precious your time is,<br />
              and it would mean the world to us<br />
              if you could be there.
            </p>

            <div class="mt-12 flex items-center justify-center gap-4 reveal">
              <div class="h-px w-12 bg-charcoal/20 divider-line"></div>
              <p class="text-xs tracking-[0.3em] text-muted">Spring, 2026</p>
              <div class="h-px w-12 bg-charcoal/20 divider-line"></div>
            </div>

            <p class="mt-6 font-serif text-sm tracking-widest reveal">
              Affrian & Sherly
            </p>
          </div>
        </div>
      </section>

      <!-- Transparent spacer — background shows through -->
      <div class="h-[50vh]"></div>

      <!-- Special Thanks / Gallery teaser -->
      <section id="gallery" class="py-16 px-6 relative">
        <div class="max-w-3xl mx-auto reveal">
          <a href="/gallery" class="gallery-teaser group block relative overflow-hidden rounded-2xl bg-lime transition-transform duration-500 hover:-translate-y-1">
            <!-- Decorative sparkles -->
            <svg class="sparkle absolute top-6 right-12 w-4 h-4 text-lime-dark/40" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41Z"/>
            </svg>
            <svg class="sparkle absolute top-16 right-24 w-3 h-3 text-lime-dark/30" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41Z"/>
            </svg>
            <svg class="sparkle absolute bottom-20 left-8 w-3 h-3 text-lime-dark/25" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41Z"/>
            </svg>
            <!-- Decorative curved line -->
            <svg class="absolute inset-0 w-full h-full pointer-events-none opacity-20" viewBox="0 0 600 300" fill="none" preserveAspectRatio="none">
              <path d="M-20 250 Q150 100 300 180 Q450 260 620 80" stroke="currentColor" stroke-width="1.5" class="text-lime-dark"/>
            </svg>

            <div class="flex flex-col md:flex-row items-stretch gap-0">
              <!-- Photo placeholder (will be replaced with real photos after the wedding) -->
              <div class="relative md:w-[55%] aspect-[4/3] md:aspect-auto overflow-hidden m-4 md:m-5 md:mr-0 rounded-xl bg-charcoal/10 flex items-center justify-center min-h-[220px]">
                <div class="text-center px-6" id="gallery-photo-area">
                  <svg class="w-12 h-12 mx-auto mb-3 text-charcoal/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <p class="text-xs tracking-widest uppercase text-charcoal/30">
                    <span class="lang-mix">結婚式後に公開</span>
                    <span class="lang-en">Coming after the wedding</span>
                  </p>
                </div>
              </div>

              <!-- Text content -->
              <div class="flex-1 flex flex-col justify-between p-6 md:p-8">
                <div>
                  <p class="font-serif italic text-2xl md:text-3xl text-charcoal mb-2">Special Thanks</p>
                  <!-- Countdown -->
                  <div id="countdown" class="flex gap-3 mt-3">
                    <div class="text-center">
                      <span id="cd-days" class="block text-2xl font-serif text-charcoal tabular-nums">--</span>
                      <span class="text-[9px] tracking-widest uppercase text-charcoal/50">
                        <span class="lang-mix">日</span>
                        <span class="lang-en">Days</span>
                      </span>
                    </div>
                    <span class="text-xl text-charcoal/30 font-light mt-0.5">:</span>
                    <div class="text-center">
                      <span id="cd-hours" class="block text-2xl font-serif text-charcoal tabular-nums">--</span>
                      <span class="text-[9px] tracking-widest uppercase text-charcoal/50">
                        <span class="lang-mix">時</span>
                        <span class="lang-en">Hrs</span>
                      </span>
                    </div>
                    <span class="text-xl text-charcoal/30 font-light mt-0.5">:</span>
                    <div class="text-center">
                      <span id="cd-mins" class="block text-2xl font-serif text-charcoal tabular-nums">--</span>
                      <span class="text-[9px] tracking-widest uppercase text-charcoal/50">
                        <span class="lang-mix">分</span>
                        <span class="lang-en">Min</span>
                      </span>
                    </div>
                    <span class="text-xl text-charcoal/30 font-light mt-0.5">:</span>
                    <div class="text-center">
                      <span id="cd-secs" class="block text-2xl font-serif text-charcoal tabular-nums">--</span>
                      <span class="text-[9px] tracking-widest uppercase text-charcoal/50">
                        <span class="lang-mix">秒</span>
                        <span class="lang-en">Sec</span>
                      </span>
                    </div>
                  </div>
                </div>
                <div class="flex items-center justify-between mt-6">
                  <p class="text-sm text-charcoal/70 leading-snug" id="gallery-link-text">
                    <span class="lang-mix">結婚式当日の<br/>様子はこちら</span>
                    <span class="lang-en">View our wedding<br/>day photos</span>
                  </p>
                  <div class="w-10 h-10 rounded-full border border-charcoal/20 flex items-center justify-center transition-all duration-300 group-hover:bg-charcoal group-hover:border-charcoal">
                    <svg class="w-5 h-5 text-charcoal transition-colors duration-300 group-hover:text-lime" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                  </div>
                </div>
              </div>
            </div>
          </a>
        </div>
      </section>

      <!-- Transparent spacer -->
      <div class="h-[50vh]"></div>

      <!-- Details Section -->
      <section id="details" class="content-card py-32 px-6">
        <div class="max-w-3xl mx-auto">
          <div class="text-center mb-16">
            <div class="inline-block bg-lime/20 px-4 py-1.5 rounded-full mb-6 reveal">
              <span class="text-xs tracking-[0.2em] uppercase font-medium">Details</span>
            </div>
            <h2 class="font-serif text-3xl md:text-4xl reveal">
              <span class="lang-mix">挙式</span>
              <span class="lang-en">Ceremony</span>
            </h2>
          </div>

          <div class="grid md:grid-cols-2 gap-12 md:gap-16">
            <div class="detail-card text-center md:text-left p-8 rounded-2xl transition-all duration-500 reveal">
              <h3 class="text-xs tracking-[0.2em] uppercase text-muted mb-4">Date & Time</h3>
              <p class="font-serif text-xl mb-2">
                <span class="lang-mix">2026年 5月 2日（土）</span>
                <span class="lang-en">May 2, 2026 (Sat)</span>
              </p>
              <div class="space-y-1 text-sm text-muted">
                <span class="lang-mix">
                  <p>挙式　14:00〜</p>
                </span>
                <span class="lang-en">
                  <p>Ceremony: 2:00 PM</p>
                </span>
              </div>
            </div>

            <div class="detail-card text-center md:text-left p-8 rounded-2xl transition-all duration-500 reveal">
              <h3 class="text-xs tracking-[0.2em] uppercase text-muted mb-4">Venue</h3>
              <p class="font-serif text-xl mb-2">The Grand Garden</p>
              <p class="text-sm text-muted">
                <span class="lang-mix">
                  〒150-0001<br />
                  東京都渋谷区神宮前1-2-3<br />
                  グランドガーデン 3F
                </span>
                <span class="lang-en">
                  1-2-3 Jingumae, Shibuya-ku<br />
                  Tokyo 150-0001<br />
                  Grand Garden, 3F
                </span>
              </p>
            </div>
          </div>

          <div class="mt-16 text-center border-t border-charcoal/10 pt-12 reveal">
            <h3 class="text-xs tracking-[0.2em] uppercase text-muted mb-4">Dress Code</h3>
            <p class="font-serif text-lg">
              <span class="lang-mix">セミフォーマル</span>
              <span class="lang-en">Semi-Formal</span>
            </p>
            <p class="mt-2 text-sm text-muted lang-mix">Semi-Formal</p>
            <p class="mt-2 text-sm text-muted lang-en">Cocktail attire welcome</p>
          </div>
        </div>
      </section>

      <!-- Schedule Section -->
      <section id="schedule" class="content-card py-32 px-6">
        <div class="max-w-2xl mx-auto">
          <div class="text-center mb-16">
            <div class="inline-block bg-lime/20 px-4 py-1.5 rounded-full mb-6 reveal">
              <span class="text-xs tracking-[0.2em] uppercase font-medium">Schedule</span>
            </div>
            <h2 class="font-serif text-3xl md:text-4xl reveal">
              <span class="lang-mix">当日のタイムライン</span>
              <span class="lang-en">Timeline</span>
            </h2>
          </div>

          <div class="space-y-0">
            {[
              { time: "1:30 PM", label: "受付開始", labelEn: "Doors Open" },
              { time: "2:00 PM", label: "挙式", labelEn: "Ceremony" },
              { time: "2:30 PM", label: "集合写真", labelEn: "Group Photo" },
            ].map((item, i) => (
              <div class="flex items-start gap-8 group timeline-item reveal">
                <div class="w-20 text-right shrink-0">
                  <span class="font-serif text-lg transition-colors duration-300 group-hover:text-charcoal">{item.time}</span>
                </div>
                <div class="flex flex-col items-center shrink-0">
                  <div class="w-3 h-3 rounded-full bg-lime border-2 border-charcoal/20 transition-all duration-300 group-hover:scale-150 group-hover:bg-lime group-hover:border-lime group-hover:shadow-[0_0_12px_rgba(225,255,0,0.5)]"></div>
                  {i < 2 && <div class="w-px h-16 bg-charcoal/10 transition-colors duration-300 group-hover:bg-lime/40"></div>}
                </div>
                <div class="pb-16 last:pb-0 transition-transform duration-300 group-hover:translate-x-1">
                  <p class="font-medium">
                    <span class="lang-mix">{item.label}</span>
                    <span class="lang-en">{item.labelEn}</span>
                  </p>
                  <p class="text-xs text-muted mt-1 lang-mix">{item.labelEn}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Transparent spacer -->
      <div class="h-[50vh]"></div>

      <!-- Access Section -->
      <section id="access" class="content-card py-32 px-6">
        <div class="max-w-3xl mx-auto">
          <div class="text-center mb-16">
            <div class="inline-block bg-lime/20 px-4 py-1.5 rounded-full mb-6 reveal">
              <span class="text-xs tracking-[0.2em] uppercase font-medium">Access</span>
            </div>
            <h2 class="font-serif text-3xl md:text-4xl reveal">
              <span class="lang-mix">アクセス</span>
              <span class="lang-en">Getting There</span>
            </h2>
          </div>

          <div class="map-card aspect-video rounded-xl overflow-hidden mb-12 transition-all duration-500 reveal relative group">
            <img
              src="https://images.unsplash.com/photo-1519167758481-83f550bb49b3?auto=format&fit=crop&w=1400&q=80"
              alt="Wedding venue exterior"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-charcoal/40 via-transparent to-transparent"></div>
            <div class="absolute bottom-6 left-6 text-white">
              <p class="font-serif text-lg drop-shadow-md">The Grand Garden</p>
              <p class="text-xs text-white/70 mt-1">
                <span class="lang-mix">東京都渋谷区神宮前</span>
                <span class="lang-en">Jingumae, Shibuya, Tokyo</span>
              </p>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-8 text-sm">
            <div class="access-card p-6 rounded-xl transition-all duration-400 reveal">
              <h3 class="text-xs tracking-[0.2em] uppercase text-muted mb-3">
                <span class="lang-mix">電車でお越しの方</span>
                <span class="lang-en">By Train</span>
              </h3>
              <p class="text-muted leading-relaxed">
                <span class="lang-mix">
                  JR山手線「原宿」駅 竹下口より徒歩5分<br />
                  東京メトロ千代田線「明治神宮前」駅 2番出口より徒歩3分
                </span>
                <span class="lang-en">
                  5 min walk from JR Harajuku Station (Takeshita Exit)<br />
                  3 min walk from Meiji-jingumae Station (Exit 2)
                </span>
              </p>
            </div>
            <div class="access-card p-6 rounded-xl transition-all duration-400 reveal">
              <h3 class="text-xs tracking-[0.2em] uppercase text-muted mb-3">
                <span class="lang-mix">お車でお越しの方</span>
                <span class="lang-en">By Car</span>
              </h3>
              <p class="text-muted leading-relaxed">
                <span class="lang-mix">
                  会場敷地内に駐車場がございます（20台）<br />
                  満車の場合は近隣のコインパーキングをご利用ください
                </span>
                <span class="lang-en">
                  On-site parking available (20 spaces)<br />
                  Nearby coin parking available if full
                </span>
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- RSVP Section — semi-transparent dark -->
      <section id="rsvp" class="content-card content-card--dark py-32 px-6">
        <div class="max-w-xl mx-auto text-center">
          <div class="inline-block bg-lime/20 px-4 py-1.5 rounded-full mb-6 reveal">
            <span class="text-xs tracking-[0.2em] uppercase font-medium text-lime">RSVP</span>
          </div>
          <h2 class="font-serif text-3xl md:text-4xl mb-6 text-white reveal">
            <span class="lang-mix">出欠のご連絡</span>
            <span class="lang-en">RSVP</span>
          </h2>
          <p class="text-sm text-white/60 leading-relaxed mb-12 reveal">
            <span class="lang-mix">
              お手数ではございますが<br />
              <span class="text-white/80 font-medium">2026年 3月 15日</span>までに<br />
              ご返信いただけますと幸いです
            </span>
            <span class="lang-en">
              We would appreciate your reply<br />
              by <span class="text-white/80 font-medium">March 15, 2026</span><br />
              so we can prepare for our special day.
            </span>
          </p>

          <div class="reveal">
            <a
              href="#"
              class="rsvp-btn inline-flex items-center gap-3 bg-lime text-charcoal px-10 py-4 rounded-full text-sm font-medium tracking-widest uppercase transition-all duration-300"
            >
              <span class="lang-mix">出席・欠席を回答する</span>
              <span class="lang-en">Respond Now</span>
              <svg class="w-4 h-4 rsvp-arrow transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
          </div>

          <p class="mt-6 text-xs text-white/40 reveal">Reply by RSVP form</p>
        </div>
      </section>

      <!-- Footer -->
      <footer class="content-card py-16 px-6 text-center">
        <div class="space-y-4">
          <p class="font-serif text-2xl tracking-widest footer-logo">A & S</p>
          <p class="text-xs tracking-[0.3em] uppercase text-muted">2026.05.02</p>
          <div class="flex items-center justify-center gap-4 mt-6">
            <div class="h-px w-16 bg-charcoal/10 divider-line"></div>
            <div class="w-2 h-2 rounded-full bg-lime footer-dot"></div>
            <div class="h-px w-16 bg-charcoal/10 divider-line"></div>
          </div>
          <p class="text-xs text-muted/50 mt-8">
            Thank you for being part of our special day
          </p>
        </div>
      </footer>

    </div><!-- .content-cards -->
  </div><!-- #content-layer -->
</Layout>

<style>
  /* ── Fixed background slideshow ── */
  #bg-slideshow {
    will-change: auto;
  }
  .bg-slide {
    will-change: opacity;
    /* Subtle slow zoom on the active slide */
    animation: bg-ken-burns 12s ease-in-out infinite alternate;
  }
  @keyframes bg-ken-burns {
    0% { transform: scale(1); }
    100% { transform: scale(1.08); }
  }

  /* ── Content cards float above background ── */
  .content-card {
    background: rgba(250, 249, 246, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255, 255, 255, 0.3);
    position: relative;
  }
  .content-card--dark {
    background: rgba(26, 26, 26, 0.88);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* ── Scroll reveal animations ── */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Nav ── */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    width: 0;
    height: 1px;
    background: #e1ff00;
    transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                left 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav-link:hover::after {
    width: 100%;
    left: 0;
  }
  .nav-logo {
    transition: letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav-logo:hover {
    letter-spacing: 0.15em;
  }
  #main-nav.scrolled {
    background: rgba(26, 26, 26, 0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 1px 12px rgba(0,0,0,0.15);
  }

  /* ── Detail cards hover ── */
  .detail-card {
    background: transparent;
    border: 1px solid transparent;
  }
  .detail-card:hover {
    background: rgba(225, 255, 0, 0.04);
    border-color: rgba(225, 255, 0, 0.15);
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(225, 255, 0, 0.06);
  }

  /* ── Access cards hover ── */
  .access-card {
    background: transparent;
    border: 1px solid transparent;
  }
  .access-card:hover {
    background: rgba(225, 255, 0, 0.04);
    border-color: rgba(225, 255, 0, 0.12);
    transform: translateY(-2px);
  }

  /* ── Gallery teaser card ── */
  .gallery-teaser {
    box-shadow: 0 4px 30px rgba(225, 255, 0, 0.15);
  }
  .gallery-teaser:hover {
    box-shadow: 0 12px 40px rgba(225, 255, 0, 0.25);
  }
  .sparkle {
    animation: sparkle-float 3s ease-in-out infinite alternate;
  }
  .sparkle:nth-child(2) { animation-delay: 1s; }
  .sparkle:nth-child(3) { animation-delay: 2s; }
  @keyframes sparkle-float {
    0% { transform: translateY(0) scale(1); opacity: 0.3; }
    100% { transform: translateY(-6px) scale(1.2); opacity: 0.6; }
  }

  /* ── Map card hover ── */
  .map-card:hover {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  /* ── RSVP button ── */
  .rsvp-btn:hover {
    background: #c8e600;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(225, 255, 0, 0.3);
  }
  .rsvp-btn:hover .rsvp-arrow {
    transform: translateX(4px);
  }
  .rsvp-btn:active {
    transform: translateY(0);
    box-shadow: 0 2px 10px rgba(225, 255, 0, 0.2);
  }

  /* ── Divider line expand ── */
  .divider-line {
    transition: width 1s cubic-bezier(0.16, 1, 0.3, 1) 0.3s;
  }
  .reveal:not(.visible) .divider-line {
    width: 0;
  }

  /* ── Footer ── */
  .footer-logo {
    transition: letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                color 0.3s ease;
    cursor: default;
  }
  .footer-logo:hover {
    letter-spacing: 0.2em;
  }
  .footer-dot {
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(225, 255, 0, 0.4); }
    50% { box-shadow: 0 0 0 6px rgba(225, 255, 0, 0); }
  }

  /* ── Hero ── */
  .hero-content {
    will-change: transform;
  }

  /* ── Language toggle ── */
  .lang-en {
    display: none;
  }
  .lang-mix {
    display: inline;
  }
  :global([data-lang="en"]) .lang-en {
    display: inline;
  }
  :global([data-lang="en"]) .lang-mix {
    display: none;
  }
  :global([data-lang="en"]) .lang-label-en {
    display: inline !important;
  }
  :global([data-lang="en"]) .lang-label-mix {
    display: none !important;
  }

  .lang-toggle:hover {
    background: rgba(255, 255, 255, 0.1);
  }
  .lang-toggle:active {
    transform: scale(0.95);
  }

  /* ── Reduce motion ── */
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .bg-slide {
      animation: none;
    }
    .footer-dot {
      animation: none;
    }
  }
</style>

<script define:vars={{ imageCount: bgImages.length }}>
  // ── Background image slideshow ──
  const slides = document.querySelectorAll('.bg-slide');
  let currentSlide = 0;
  const SLIDE_INTERVAL = 6000; // 6 seconds per image

  function shuffleSlide() {
    // Pick a random next slide (not the same as current)
    let next;
    do {
      next = Math.floor(Math.random() * imageCount);
    } while (next === currentSlide && imageCount > 1);

    // Crossfade
    slides[currentSlide].classList.remove('opacity-100');
    slides[currentSlide].classList.add('opacity-0');
    slides[next].classList.remove('opacity-0');
    slides[next].classList.add('opacity-100');

    currentSlide = next;
  }

  setInterval(shuffleSlide, SLIDE_INTERVAL);
</script>

<script>
  // ── Scroll reveal with IntersectionObserver ──
  const reveals = document.querySelectorAll('.reveal');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = parseInt(el.dataset.delay || '0', 10);
          setTimeout(() => el.classList.add('visible'), delay);
          revealObserver.unobserve(el);
        }
      });
    },
    { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
  );
  reveals.forEach((el) => revealObserver.observe(el));

  // ── Hero parallax + fade on scroll ──
  const heroContent = document.querySelector('.hero-content') as HTMLElement | null;
  const nav = document.getElementById('main-nav');

  let ticking = false;
  function onScroll() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const scrollY = window.scrollY;

      // Hero text drifts up and fades as you scroll
      if (heroContent) {
        heroContent.style.transform = `translate3d(0, ${scrollY * 0.25}px, 0)`;
        heroContent.style.opacity = String(Math.max(0, 1 - scrollY / 500));
      }

      // Nav background on scroll
      if (nav) {
        nav.classList.toggle('scrolled', scrollY > 80);
      }

      ticking = false;
    });
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // ── Magnetic hover on RSVP button ──
  const rsvpBtn = document.querySelector('.rsvp-btn') as HTMLElement | null;
  if (rsvpBtn) {
    rsvpBtn.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = rsvpBtn.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      rsvpBtn.style.transform = `translate(${x * 0.08}px, ${y * 0.08 - 2}px)`;
    });
    rsvpBtn.addEventListener('mouseleave', () => {
      rsvpBtn.style.transform = '';
    });
  }

  // ── Wedding countdown ──
  const WEDDING_DATE = new Date('2026-05-02T14:00:00+09:00');
  const cdDays = document.getElementById('cd-days');
  const cdHours = document.getElementById('cd-hours');
  const cdMins = document.getElementById('cd-mins');
  const cdSecs = document.getElementById('cd-secs');
  const photoArea = document.getElementById('gallery-photo-area');
  const linkText = document.getElementById('gallery-link-text');
  let weddingPassed = false;

  function updateCountdown() {
    const now = new Date();
    const diff = WEDDING_DATE.getTime() - now.getTime();

    if (diff <= 0) {
      if (!weddingPassed) {
        weddingPassed = true;
        // Swap placeholder to real photo
        const parent = photoArea?.parentElement;
        if (parent && photoArea) {
          parent.classList.remove('bg-charcoal/10', 'flex', 'items-center', 'justify-center');
          parent.innerHTML = `<img src="https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=800&q=80" alt="Wedding day" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />`;
        }
        // Update link text
        if (linkText) {
          linkText.innerHTML = `<span class="lang-mix">結婚式当日の<br/>様子はこちら</span><span class="lang-en">View our wedding<br/>day photos</span>`;
          // Re-apply current lang
          const lang = document.documentElement.getAttribute('data-lang');
          if (lang === 'en') {
            document.documentElement.setAttribute('data-lang', 'en');
          }
        }
      }
      if (cdDays) cdDays.textContent = '0';
      if (cdHours) cdHours.textContent = '0';
      if (cdMins) cdMins.textContent = '0';
      if (cdSecs) cdSecs.textContent = '0';
      return;
    }

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
    const mins = Math.floor((diff / (1000 * 60)) % 60);
    const secs = Math.floor((diff / 1000) % 60);

    if (cdDays) cdDays.textContent = String(days);
    if (cdHours) cdHours.textContent = String(hours).padStart(2, '0');
    if (cdMins) cdMins.textContent = String(mins).padStart(2, '0');
    if (cdSecs) cdSecs.textContent = String(secs).padStart(2, '0');
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);

  // ── Language toggle ──
  const langToggle = document.getElementById('lang-toggle');
  if (langToggle) {
    // Restore saved preference
    const saved = localStorage.getItem('wedding-lang');
    if (saved === 'en') {
      document.documentElement.setAttribute('data-lang', 'en');
    }

    langToggle.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-lang');
      const next = current === 'en' ? 'mix' : 'en';
      if (next === 'en') {
        document.documentElement.setAttribute('data-lang', 'en');
      } else {
        document.documentElement.removeAttribute('data-lang');
      }
      localStorage.setItem('wedding-lang', next);
    });
  }

  // ── Section heading tilt on mouse move ──
  const tiltSections = document.querySelectorAll('#details, #access') as NodeListOf<HTMLElement>;
  tiltSections.forEach((section) => {
    const heading = section.querySelector('h2') as HTMLElement | null;
    if (!heading) return;
    section.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = section.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      heading.style.transform = `perspective(800px) rotateY(${x * 3}deg) rotateX(${-y * 2}deg)`;
    });
    section.addEventListener('mouseleave', () => {
      heading.style.transform = '';
      heading.style.transition = 'transform 0.5s cubic-bezier(0.16, 1, 0.3, 1)';
      setTimeout(() => { heading.style.transition = ''; }, 500);
    });
  });
</script>
