                </figure>

                <div class="couple-card__text couple-card__text--rian">
                  <h3 class="couple-card__name font-serif italic text-left">
                    Affrian Rachmansyah
                  </h3>
                  <p class="lang-mix couple-card__meta text-center">
                    <span class="couple-card__meta-line"
                      >Putra pertama dari<br /> Bpk. Yanuk Fatchorrahman (Alm.)</span
                    >
                    <span class="">&amp;</span>
                    <span class="couple-card__meta-line"
                      >Ibu Dinar Rahmawati</span
                    >
                  </p>
                  <p class="lang-en couple-card__meta text-center">
                    <span class="couple-card__meta-line"
                      >First son of<br /> Mr. Yanuk Fatchorrahman (late)</span
                    >
                    <span class="">&amp;</span>
                    <span class="couple-card__meta-line"
                      >Mrs. Dinar Rahmawati</span
                    >
                  </p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Details Section -->
        <section
          id="details"
          data-auto-scroll-section
          class="content-card content-card--transparent py-32 px-6"
        >
          <div class="details-layout desktop-shell w-full">
            <div class="details-composition reveal">
              <div class="details-line">
                <div class="details-line__intro">
                  <p class="details-line__label font-serif">
                    <span class="lang-mix">Hari</span>
