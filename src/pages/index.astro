    list-style: none;
    cursor: pointer;
    border: 1px solid rgba(255, 255, 255, 0.32);
    background: rgba(225, 255, 0, 0.94);
    backdrop-filter: blur(18px) saturate(135%);
    -webkit-backdrop-filter: blur(18px) saturate(135%);
    box-shadow:
      0 14px 36px rgba(26, 26, 26, 0.16),
      0 10px 30px rgba(225, 255, 0, 0.22);
    transition:
      transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.35s ease,
      background-color 0.35s ease;
  }
  .gallery-teaser__summary::-webkit-details-marker {
    display: none;
  }
  .gallery-teaser__summary::marker {
    content: '';
  }
  .gallery-teaser__summary-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-charcoal);
    opacity: 0.78;
  }
  .gallery-teaser__expanded {
    position: absolute;
    right: 0;
    bottom: calc(100% + 0.5rem);
    z-index: 1;
    width: min(19rem, calc(100vw - 1rem));
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.32);
    border-radius: 1rem;
    background: rgba(225, 255, 0, 0.94);
    backdrop-filter: blur(18px) saturate(135%);
    -webkit-backdrop-filter: blur(18px) saturate(135%);
    box-shadow:
      0 18px 46px rgba(26, 26, 26, 0.16),
      0 12px 30px rgba(225, 255, 0, 0.22);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(0.75rem) scale(0.96);
    transform-origin: bottom right;
    transition:
      opacity 0.28s ease,
      transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0.28s ease;
  }
  .gallery-teaser__expanded .calendar-card__title {
    font-size: 1.55rem;
    line-height: 1.08;
    margin-bottom: 0.5rem;
  }
  .gallery-teaser__expanded .calendar-card__copy {
    max-width: none;
    font-size: 0.88rem;
  }
  .gallery-teaser__expanded .calendar-card__footer {
    margin-top: 0.9rem;
    padding-top: 0.9rem;
    border-top: 1px solid rgba(26, 26, 26, 0.12);
  }
  .gallery-teaser__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(26, 26, 26, 0.14);
    border-radius: 0.5rem;
    background: rgba(26, 26, 26, 0.08);
    color: var(--color-charcoal);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      background-color 0.25s ease,
      transform 0.25s ease,
      border-color 0.25s ease;
  }
  .gallery-teaser__cta:hover {
    background: rgba(26, 26, 26, 0.14);
    border-color: rgba(26, 26, 26, 0.24);
    transform: translateY(-1px);
  }
  .gallery-teaser--floating[open] {
    z-index: 65;
  }
  .gallery-teaser--floating[open] .gallery-teaser__expanded,
  .gallery-teaser--floating:focus-within .gallery-teaser__expanded {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }
  .gallery-teaser--floating[open] > .gallery-teaser__summary,
  .gallery-teaser--floating:focus-within > .gallery-teaser__summary {
    box-shadow:
      0 18px 42px rgba(26, 26, 26, 0.18),
      0 14px 34px rgba(225, 255, 0, 0.26);
  }
  /* ── Pointer: desktop mouse hover interactions ── */
  @media (hover: hover) and (pointer: fine) {
    .gallery-teaser--floating:hover .gallery-teaser__expanded {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateY(0) scale(1);
    }
    .gallery-teaser--floating:hover > .gallery-teaser__summary {
      transform: translateY(-4px) scale(1.03);
      box-shadow:
        0 18px 42px rgba(26, 26, 26, 0.18),
        0 14px 34px rgba(225, 255, 0, 0.26);
    }
  }
  /* ── Mobile portrait: iPhone SE (375×667), iPhone 14/15 (390×844), Pixel 7 (412×915), Galaxy S24 (360×780) ── */
  @media (max-width: 639px) {
    .gallery-teaser--floating {
      width: 3.75rem;
      height: 3.75rem;
      right: max(0.625rem, calc(env(safe-area-inset-right) + 0.625rem));
      bottom: max(0.625rem, calc(env(safe-area-inset-bottom) + 0.625rem));
    }
    .gallery-teaser__expanded {
      width: min(17.25rem, calc(100vw - 0.75rem));
      bottom: calc(100% + 0.45rem);
      padding: 0.9rem;
    }
  }
  .sparkle {
    animation: sparkle-float 3s ease-in-out infinite alternate;
  }
  .sparkle:nth-child(2) {
    animation-delay: 1s;
  }
  .sparkle:nth-child(3) {
    animation-delay: 2s;
  }
  @keyframes sparkle-float {
    0% {
      transform: translateY(0) scale(1);
      opacity: 0.3;
    }
    100% {
      transform: translateY(-6px) scale(1.2);
      opacity: 0.6;
    }
  }

  /* ── Map card hover ── */
  .map-card:hover {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  /* ── Wedding wish guestbook ── */
  .wish-section {
    overflow: visible;
    background: transparent;
    border-top: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }
  #wishes.wish-section {
    padding-bottom: 0;
  }
  .wish-shell {
    position: relative;
    width: 100vw;
    max-width: none;
    margin-inline: calc(50% - 50vw);
    margin-top: -1px;
    padding: clamp(1.15rem, 3vw, 1.6rem)
      max(1.5rem, calc(env(safe-area-inset-right) + 1.5rem))
      clamp(2.5rem, 5vw, 3.5rem)
      max(1.5rem, calc(env(safe-area-inset-left) + 1.5rem));
    background: rgba(174, 209, 93, 1);
    border-top: none;
    overflow: hidden;
  }
  .wish-shell__inner {
    position: relative;
    max-width: min(100%, 74rem);
    margin-inline: auto;
    isolation: isolate;
    --wish-accent: #b8cf92;
    --wish-accent-strong: #dbe8b3;
    --wish-accent-ink: #273618;
    --wish-accent-soft: #eef4dd;
    --wish-accent-line: rgba(61, 86, 28, 0.16);
    --wish-paper: #fffdf5;
    --wish-paper-soft: rgba(255, 252, 243, 0.72);
    --wish-shadow: rgba(74, 99, 40, 0.16);
  }
  .wish-shell__inner::before,
  .wish-shell__inner::after {
    content: '';
    position: absolute;
    inset: auto;
    border-radius: 999px;
    pointer-events: none;
    z-index: -1;
    filter: blur(24px);
    opacity: 0.75;
  }
  .wish-shell__inner::before {
    width: 14rem;
    height: 14rem;
    top: -3rem;
    right: -2rem;
    /* background: radial-gradient(
      circle,
      rgba(249, 248, 231, 0.6) 0%,
      rgba(249, 248, 231, 0) 72%
    ); */
  }
  .wish-shell__inner::after {
    width: 13rem;
    height: 13rem;
    bottom: -2rem;
    left: -1rem;
    background: radial-gradient(
      circle,
      rgba(142, 183, 76, 0.18) 0%,
      rgba(142, 183, 76, 0) 72%
    );
  }
  .wish-grid {
    display: grid;
    gap: 1.35rem;
    align-items: start;
  }
  .wish-panel {
    position: relative;
    overflow: hidden;
    /* border-radius: 2rem; */
    /* border: 1px solid var(--wish-accent-line); */
    /* background: var(--wish-paper-soft); */
    padding: clamp(1.35rem, 3vw, 2rem);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .wish-panel::after {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
  }
  .wish-panel:hover {
    transform: translateY(-2px);
  }
  .wish-panel--form {
    padding: 0;
    background: transparent;
    border-color: transparent;
    box-shadow: none;
  }
  .wish-panel--form::after {
    display: none;
  }
  .wish-panel--form:hover {
    transform: none;
    border-color: transparent;
  }
  .wish-panel--list {
    background: rgba(174, 209, 93, 1);
  }
  .wish-panel__body {
    display: grid;
    gap: 1.35rem;
    padding: clamp(1.35rem, 3vw, 2rem);
    position: relative;
    z-index: 1;
  }
  .wish-scene {
    position: relative;
    z-index: 2;
    width: 100vw;
    max-width: none;
    margin-inline: calc(50% - 50vw);
    margin-bottom: 0;
    pointer-events: none;
  }
  .wish-scene::before {
    content: '';
    position: absolute;
    inset: 8% 20% 12%;
    border-radius: 999px;
    background: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.34) 0%,
      rgba(255, 255, 255, 0) 72%
    );
    filter: blur(26px);
    z-index: -1;
  }
  .wish-scene__image {
    display: block;
    width: 100%;
    height: auto;
    max-width: none;
    /* filter: drop-shadow(0 24px 28px rgba(72, 95, 33, 0.22)); */
  }
  .wish-panel__heading {
    display: grid;
    gap: 0.6rem;
  }
  .wish-panel__eyebrow,
  .wish-list__eyebrow {
    font-size: 0.72rem;
    line-height: 1.6;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(39, 54, 24, 0.54);
  }
  .wish-panel__title {
    font-size: clamp(2.35rem, 9vw, 3.8rem);
    line-height: 0.92;
    max-width: 10ch;
    color: var(--wish-accent-ink);
  }
  .wish-panel__copy,
  .wish-list__deck {
    margin-top: 0.9rem;
    color: rgba(39, 54, 24, 0.7);
    line-height: 1.75;
    text-align: left;
  }
  .wish-form {
    display: grid;
    gap: 1rem;
  }
  .wish-field {
    display: grid;
    gap: 0.6rem;
    text-align: left;
  }
  .wish-field__label {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(39, 54, 24, 0.6);
  }
  .wish-input,
  .wish-textarea {
    width: 100%;
    border-radius: 1.1rem;
    border: 1px solid rgba(61, 86, 28, 0.12);
    background: rgba(255, 255, 255, 0.96);
    color: var(--wish-accent-ink);
    padding: 1rem 1.1rem;
    font-size: 0.95rem;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      background 0.25s ease;
  }
  .wish-input::placeholder,
  .wish-textarea::placeholder {
    color: rgba(39, 54, 24, 0.36);
  }
  .wish-input:focus,
  .wish-textarea:focus {
    outline: none;
    border-color: rgba(61, 86, 28, 0.26);
    box-shadow:
      0 0 0 4px rgba(131, 161, 63, 0.12),
      0 14px 28px rgba(74, 99, 40, 0.1);
    background: #fff;
  }
  .wish-textarea {
    min-height: 9.5rem;
    resize: vertical;
    background-image:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.96),
        rgba(255, 255, 255, 0.96)
      ),
      repeating-linear-gradient(
        180deg,
        rgba(39, 54, 24, 0) 0,
        rgba(39, 54, 24, 0) 1.82rem,
        rgba(61, 86, 28, 0.07) 1.82rem,
        rgba(61, 86, 28, 0.07) 1.9rem
      );
  }
  .wish-form__footer {
    display: grid;
    gap: 0.85rem;
    justify-items: start;
    margin-top: 0.25rem;
  }
  .wish-submit {
    width: 100%;
    justify-content: center;
  }
  .wish-submit[disabled] {
    opacity: 0.7;
    cursor: wait;
    box-shadow: none;
  }
  .wish-submit {
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, #445d25 0%, #31451a 100%);
    color: #faf8ef;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.14),
      0 16px 28px rgba(66, 90, 28, 0.18);
  }
  .wish-submit::before {
    content: '';
    position: absolute;
    inset: 1px;
    border-radius: inherit;
    border: 1px solid rgba(255, 255, 255, 0.12);
    pointer-events: none;
  }
  .wish-form__note {
    font-size: 0.75rem;
    line-height: 1.7;
    color: rgba(39, 54, 24, 0.58);
    text-align: left;
  }
  .wish-status {
    border-radius: 1rem;
    padding: 0.85rem 1rem;
    font-size: 0.82rem;
    line-height: 1.6;
    text-align: left;
  }
  .wish-status[data-state='pending'] {
    border: 1px solid rgba(61, 86, 28, 0.1);
    background: rgba(255, 255, 255, 0.68);
    color: rgba(39, 54, 24, 0.78);
  }
  .wish-status[data-state='success'] {
    border: 1px solid rgba(61, 86, 28, 0.12);
    background: rgba(68, 93, 37, 0.1);
    color: rgba(39, 54, 24, 0.9);
  }
  .wish-status[data-state='error'] {
    border: 1px solid rgba(177, 84, 56, 0.16);
    background: rgba(215, 146, 120, 0.14);
    color: rgba(113, 44, 22, 0.9);
  }
  .wish-list__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
    text-align: left;
  }
  .wish-list__tools {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .wish-list__title {
    margin-top: 0.4rem;
    font-size: clamp(2.15rem, 7vw, 3.4rem);
    line-height: 1.05;
    max-width: 12ch;
  }

  .wish-stage {
    position: relative;
    overflow: hidden;
    margin-top: 1.2rem;
    --wish-peek: clamp(2.6rem, 9vw, 4.75rem);
    --wish-gap: clamp(0.85rem, 2vw, 1.1rem);
    touch-action: pan-y;
    user-select: none;
  }
  .wish-stage::before,
  .wish-stage::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1.1rem;
    z-index: 2;
    pointer-events: none;
  }
  .wish-stage::before {
    left: 0;
    background: linear-gradient(
      90deg,
      rgba(227, 236, 196, 0.95),
      rgba(227, 236, 196, 0)
    );
  }
  .wish-stage::after {
    right: 0;
    background: linear-gradient(
      270deg,
      rgba(227, 236, 196, 0.95),
      rgba(227, 236, 196, 0)
    );
  }
  .wish-list {
    display: flex;
    align-items: stretch;
    gap: 0;
    will-change: transform;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .wish-list:not(.wish-list--solo) {
    gap: var(--wish-gap);
  }
  .wish-empty {
    border-radius: 1.15rem;
    border: 1px dashed rgba(61, 86, 28, 0.18);
    background: rgba(255, 255, 255, 0.54);
    padding: 1.15rem 1.2rem;
    color: rgba(39, 54, 24, 0.68);
    line-height: 1.8;
    text-align: left;
  }
  .wish-card {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    flex: 0 0 calc(100% - var(--wish-peek));
    min-height: clamp(17rem, 42vw, 19.5rem);
    max-height: clamp(17rem, 42vw, 19.5rem);
    border-radius: 1.35rem;
    border: 1px solid rgba(61, 86, 28, 0.12);
    background: linear-gradient(180deg, #fffdf6 0%, #f8f6ec 100%);
    padding: 1.2rem 1.25rem 1.15rem;
    margin-inline: 0;

    transition:
      transform 0.3s ease,
      border-color 0.25s ease;
  }
  .wish-list--solo .wish-card {
    flex-basis: 100%;
  }
  .wish-card::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: linear-gradient(
      180deg,
      rgba(127, 154, 69, 0.88) 0%,
      rgba(127, 154, 69, 0) 100%
    );
    opacity: 0.72;
  }
  .wish-card::after {
    content: '';
    position: absolute;
    top: 0.85rem;
    right: 1rem;
    width: 2.2rem;
    height: 0.55rem;
    border-radius: 999px;
    background: rgba(186, 208, 129, 0.34);
    transform: rotate(10deg);
    pointer-events: none;
  }
  .wish-card:hover {
    transform: translateY(-2px);
    border-color: rgba(61, 86, 28, 0.18);
  }
  .wish-card__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.85rem;
    flex-shrink: 0;
  }
  .wish-card__name {
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--wish-accent-ink);
  }
  .wish-card__date {
    margin-top: 0.35rem;
    font-size: 0.73rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(39, 54, 24, 0.42);
  }
  .wish-card__glyph {
    color: rgba(127, 154, 69, 0.82);
    font-size: 1rem;
    transform: translateY(0.15rem);
  }
  .wish-card__message {
    margin-top: 0.9rem;
    flex: 1 1 auto;
    overflow-y: auto;
    padding-right: 0.35rem;
    color: rgba(39, 54, 24, 0.84);
    line-height: 1.8;
    white-space: pre-line;
    text-wrap: pretty;
    overflow-wrap: anywhere;
    overscroll-behavior: contain;
    scrollbar-width: thin;
    scrollbar-color: rgba(127, 154, 69, 0.42) rgba(61, 86, 28, 0.06);
  }
  .wish-card__message::-webkit-scrollbar {
    width: 0.35rem;
  }
  .wish-card__message::-webkit-scrollbar-track {
    background: rgba(61, 86, 28, 0.06);
    border-radius: 999px;
  }
  .wish-card__message::-webkit-scrollbar-thumb {
    background: rgba(127, 154, 69, 0.42);
    border-radius: 999px;
  }
  .rsvp-btn:hover {
    background: linear-gradient(180deg, #c9dbab 0%, #b1c788 100%);
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(68, 99, 79, 0.22);
  }
  .rsvp-btn:hover .rsvp-arrow {
    transform: translateX(4px);
  }
  .rsvp-btn:active {
    transform: translateY(0);
    box-shadow: 0 2px 10px rgba(68, 99, 79, 0.14);
  }

  /* ── Divider line expand ── */
  .divider-line {
    transition: width 1s cubic-bezier(0.16, 1, 0.3, 1) 0.3s;
  }
  .reveal:not(.visible) .divider-line {
    width: 0;
  }

  /* ── Footer ── */
  .footer-logo {
    transition:
      letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      color 0.3s ease;
    cursor: default;
  }
  .footer-logo:hover {
    letter-spacing: 0.2em;
  }
  .footer-dot {
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(225, 255, 0, 0.4);
    }
    50% {
      box-shadow: 0 0 0 6px rgba(225, 255, 0, 0);
    }
  }

  /* ── Hero ── */
  .hero-section {
    --hero-couple-transform: translateX(0);
  }
  .hero-scene {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  /* ── Hero load sequence: bg → mountain → couple → cats → text ── */
  .hero-bg-image {
    opacity: 0;
    transform: scale(1.04);
    transition:
      opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hero-scene__mountain {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 60%;
    background: url('/assets/gunung.webp') center bottom / cover no-repeat;
    opacity: 0;
    transform: translate3d(0, 2.4rem, 0) scale(1.04);
    transition:
      opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.5s,
      transform 1.3s cubic-bezier(0.16, 1, 0.3, 1) 0.5s;
  }
  .hero-scene__couple {
    position: absolute;
    top: 60%;
    left: 0;
    bottom: auto;
    width: 100%;
    max-width: none;
    opacity: 0;
    transform: var(--hero-couple-transform) translate3d(0, 3rem, 0) scale(0.94);
    filter: blur(12px);
    background-repeat: no-repeat;
    transition:
      opacity 1s cubic-bezier(0.16, 1, 0.3, 1) 1s,
      transform 1.4s cubic-bezier(0.16, 1, 0.3, 1) 1s,
      filter 1.2s cubic-bezier(0.16, 1, 0.3, 1) 1s;
  }
  .hero-scene__cat {
    opacity: 0;
    transform: translate3d(0, 1.4rem, 0) scale(0.92);
    filter: blur(10px);
    transition:
      opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      transform 1.05s cubic-bezier(0.16, 1, 0.3, 1),
      filter 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hero-scene__cat--left {
    transition-delay: 0s;
  }
  .hero-scene__cat--right {
    transition-delay: 0.1s;
  }
  .hero-scene__cat--center {
    transition-delay: 0.2s;
  }
  .hero-scene__cat--visible {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
    filter: blur(0);
  }
  .hero-section--loaded .hero-bg-image {
    opacity: 1;
    transform: scale(1);
  }
  .hero-section--loaded .hero-scene__mountain {
    opacity: 0.98;
    transform: translate3d(0, 0, 0) scale(1);
  }
  .hero-section--loaded .hero-scene__couple {
    opacity: 1;
    transform: var(--hero-couple-transform) translate3d(0, 0, 0) scale(1);
    filter: blur(0);
  }
  /* cats are revealed on scroll via .hero-scene__cat--visible */
  .hero-content {
    z-index: 1;
    display: flex;
    width: min(100%, 28rem);
    margin-inline: auto;
    flex-direction: column;
    align-items: center;
    will-change: transform;
    padding-top: max(5rem, calc(env(safe-area-inset-top) + 4.5rem));
    padding-bottom: 10.5rem;
    text-shadow: 0 10px 30px rgba(16, 66, 86, 0.18);
  }
