                >
                  <span class="lang-mix">02.05.2026<br />Sabtu</span>
                  <span class="lang-en">02.05.2026<br />Saturday</span>
                </p>
              </div>

              <div class="details-line details-line--secondary">
                <div class="details-line__intro">
                  <p class="details-line__label font-serif">
                    <span class="lang-mix">Akad</span>
                    <span class="lang-en">Akad</span>
                  </p>
                  <p class="details-line__meta">
                    <span class="lang-mix">Wedding</span>
                    <span class="lang-en">Wedding</span>
                  </p>
                </div>
                <p
                  class="details-line__value details-line__value--time font-serif"
