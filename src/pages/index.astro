    .wish-grid {
      grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
      gap: clamp(1.5rem, 2.4vw, 2rem);
      align-items: start;
    }
    .wish-scene {
      margin-bottom: 0;
    }
    .wish-hero {
      grid-template-columns: minmax(0, 1.12fr) minmax(17rem, 0.88fr);
      align-items: center;
      text-align: left;
      padding: clamp(1.9rem, 3vw, 2.6rem);
    }
    .wish-hero__labels {
      justify-content: flex-start;
    }
    .wish-hero__lead {
      margin-inline: 0;
    }
    .wish-hero__art {
      min-height: 14rem;
    }
    .wish-hero__caption {
      right: 0.5rem;
      bottom: 0.5rem;
    }
    .footer-shell {
      max-width: 30rem;
      margin-inline: auto;
    }
  }

  /* ── Phones + iPad Mini exact width (≤768px): iPhone SE (375), iPhone 14/15 (390), Pixel 7 (412), Galaxy S24 (360), iPad Mini (768) ── */
  @media (max-width: 768px) {
    .hero-scene__mountain {
      height: 60%;
      background-position: center bottom;
    }

    .couple-card-group {
      --couple-group-gap: 1.25rem;
    }
    .couple-separator {
      margin-block: -0.5rem;
    }
  }
</style>

<script>

  // ── Scroll reveal with IntersectionObserver ──
  const reveals = document.querySelectorAll('.reveal');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = parseInt(el.dataset.delay || '0', 10);
          setTimeout(() => el.classList.add('visible'), delay);
          revealObserver.unobserve(el);
        }
      });
    },
    { threshold: 0.15, rootMargin: '0px 0px -40px 0px' },
  );

  // Wait for loader panels to finish before starting hero text reveals.
  // Non-hero reveals (below the fold) start immediately since they won't
  // fire until the user scrolls to them anyway.
  const heroReveals = Array.from(reveals).filter((el) =>
    el.closest('#home')
  );
  const otherReveals = Array.from(reveals).filter((el) =>
    !el.closest('#home')
  );

  otherReveals.forEach((el) => revealObserver.observe(el));

  const startHeroReveals = () => heroReveals.forEach((el) => revealObserver.observe(el));
  window.addEventListener('intro-done', startHeroReveals, { once: true });

  // ── Cats appear on scroll ──
  const heroCats = document.querySelectorAll<HTMLElement>('.hero-scene__cat');
  let catsRevealed = false;
  const revealCats = () => {
    if (catsRevealed) return;
    catsRevealed = true;
    heroCats.forEach((cat) => cat.classList.add('hero-scene__cat--visible'));
    window.removeEventListener('scroll', revealCats);
  };
  window.addEventListener('scroll', revealCats, { passive: true });

  // ── Hero parallax + fade on scroll ──
  const heroContent = document.querySelector(
    '.hero-content',
  ) as HTMLElement | null;
  const nav = document.getElementById('main-nav');

  let ticking = false;
  function onScroll() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const scrollY = window.scrollY;

      // Hero text drifts up and fades as you scroll
      if (heroContent) {
        heroContent.style.transform = `translate3d(0, ${scrollY * 0.25}px, 0)`;
        heroContent.style.opacity = String(Math.max(0, 1 - scrollY / 500));
      }

      // Nav background on scroll
      if (nav) {
        nav.classList.toggle('scrolled', scrollY > 80);
      }

      ticking = false;
    });
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // ── Magnetic hover on wish button ──
  const rsvpBtn = document.querySelector('.rsvp-btn') as HTMLElement | null;
  if (rsvpBtn) {
    rsvpBtn.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = rsvpBtn.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      rsvpBtn.style.transform = `translate(${x * 0.08}px, ${y * 0.08 - 2}px)`;
    });
    rsvpBtn.addEventListener('mouseleave', () => {
      rsvpBtn.style.transform = '';
    });
  }

  // ── Wedding countdown ──
  const WEDDING_DATE = new Date('2026-05-02T09:00:00+07:00');
  const cdDays = document.getElementById('cd-days');
  const cdHours = document.getElementById('cd-hours');
  const cdMins = document.getElementById('cd-mins');
  const cdSecs = document.getElementById('cd-secs');
  let weddingPassed = false;

  function updateCountdown() {
    const now = new Date();
    const diff = WEDDING_DATE.getTime() - now.getTime();

    if (diff <= 0) {
      if (!weddingPassed) {
        weddingPassed = true;
      }
      if (cdDays) cdDays.textContent = '0';
      if (cdHours) cdHours.textContent = '0';
      if (cdMins) cdMins.textContent = '0';
      if (cdSecs) cdSecs.textContent = '0';
      return;
    }

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
    const mins = Math.floor((diff / (1000 * 60)) % 60);
    const secs = Math.floor((diff / 1000) % 60);

    if (cdDays) cdDays.textContent = String(days);
    if (cdHours) cdHours.textContent = String(hours).padStart(2, '0');
    if (cdMins) cdMins.textContent = String(mins).padStart(2, '0');
    if (cdSecs) cdSecs.textContent = String(secs).padStart(2, '0');
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);

  // ── Floating gallery widget ──
  const galleryWidget = document.querySelector(
    '.gallery-teaser--floating',
  ) as HTMLDetailsElement | null;
  if (galleryWidget) {
    document.addEventListener('click', (event) => {
      const target = event.target as Node | null;
      if (target && !galleryWidget.contains(target)) {
        galleryWidget.removeAttribute('open');
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        galleryWidget.removeAttribute('open');
      }
    });
  }

  const getActiveLanguage = () =>
    document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'mix';

  const bgMusic = document.getElementById(
    'bg-music',
  ) as HTMLAudioElement | null;
  const musicToggle = document.getElementById(
    'music-toggle',
  ) as HTMLButtonElement | null;
  const MUTE_PREF_KEY = 'wedding-music-muted';

  const syncMuteUi = () => {
    if (!bgMusic || !musicToggle) return;
    const isMuted = bgMusic.muted;
    musicToggle.dataset.state = isMuted ? 'muted' : 'playing';
    musicToggle.setAttribute('aria-label', isMuted ? 'Unmute' : 'Mute');
  };

  if (bgMusic && musicToggle) {
    // Restore mute preference
    bgMusic.muted = window.localStorage.getItem(MUTE_PREF_KEY) === 'true';
    syncMuteUi();

    // Music starts when cover "Open" is clicked (Layout dispatches 'music-started').
    // If already playing, just sync UI.
    window.addEventListener('music-started', () => syncMuteUi(), { once: true });

    musicToggle.addEventListener('click', () => {
      bgMusic.muted = !bgMusic.muted;
      window.localStorage.setItem(MUTE_PREF_KEY, String(bgMusic.muted));
      syncMuteUi();
    });
  }

  const syncWishFieldPlaceholders = () => {
    const fields = document.querySelectorAll<
      HTMLInputElement | HTMLTextAreaElement
    >('[data-placeholder-mix][data-placeholder-en]');

    fields.forEach((field) => {
      field.placeholder =
        getActiveLanguage() === 'en'
          ? (field.dataset.placeholderEn ?? '')
          : (field.dataset.placeholderMix ?? '');
    });
  };

  // ── Language toggle ──
  const langToggle = document.getElementById('lang-toggle');
  if (langToggle) {
    // Restore saved preference
    const saved = localStorage.getItem('wedding-lang');
    if (saved === 'en') {
      document.documentElement.setAttribute('data-lang', 'en');
    }

    syncWishFieldPlaceholders();

    langToggle.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-lang');
      const next = current === 'en' ? 'mix' : 'en';
      if (next === 'en') {
        document.documentElement.setAttribute('data-lang', 'en');
      } else {
        document.documentElement.removeAttribute('data-lang');
      }
      localStorage.setItem('wedding-lang', next);
      syncWishFieldPlaceholders();
    });
  }

  // ── Wedding wish form ──
  const wishForm = document.getElementById(
    'wish-form',
  ) as HTMLFormElement | null;
  const wishList = document.getElementById('wish-list') as HTMLElement | null;
  const wishStage = document.getElementById('wish-stage') as HTMLElement | null;
  const wishEmpty = document.getElementById('wish-empty') as HTMLElement | null;
  const wishStatus = document.getElementById(
    'wish-status',
  ) as HTMLElement | null;
  const wishPrev = document.getElementById(
    'wish-prev',
  ) as HTMLButtonElement | null;
  const wishNext = document.getElementById(
    'wish-next',
  ) as HTMLButtonElement | null;
  const wishCardTemplate = document.getElementById(
    'wish-card-template',
  ) as HTMLTemplateElement | null;
  const wishSubmit = wishForm?.querySelector(
    '.wish-submit',
  ) as HTMLButtonElement | null;
  let activeWishIndex = 0;

  const wishMessages = {
    mix: {
      validation: 'Mohon isi nama dan ucapan terlebih dahulu.',
      pending: 'Ucapan Anda sedang kami kirim...',
      success: 'Terima kasih. Ucapan Anda sudah tampil di buku ucapan.',
      error: 'Maaf, ucapan belum bisa dikirim sekarang.',
    },
    en: {
      validation: 'Please enter your name and message first.',
      pending: 'Sending your wish...',
      success: 'Thank you. Your note is now live in the guestbook.',
      error: 'Sorry, your wish could not be sent right now.',
    },
  } as const;

  const setWishStatus = (state: 'idle' | 'pending' | 'success' | 'error') => {
    if (!wishStatus) return;

    if (state === 'idle') {
      wishStatus.textContent = '';
      wishStatus.classList.add('hidden');
      wishStatus.removeAttribute('data-state');
      return;
    }

    wishStatus.dataset.state = state;
    wishStatus.textContent = wishMessages[getActiveLanguage()][state];
    wishStatus.classList.remove('hidden');
  };

  const getWishCards = () =>
    wishList
      ? Array.from(wishList.querySelectorAll<HTMLElement>('[data-wish-id]'))
      : [];

  const syncWishDeck = () => {
    if (!wishList) return;

    const cards = getWishCards();
    const total = cards.length;

    if (wishEmpty) {
      wishEmpty.classList.toggle('hidden', total > 0);
    }

    if (total === 0) {
      activeWishIndex = 0;
      wishList.style.transform = 'translate3d(0, 0, 0)';
      wishList.classList.add('wish-list--solo');
      if (wishPrev) wishPrev.disabled = true;
      if (wishNext) wishNext.disabled = true;
      return;
    }

    activeWishIndex = ((activeWishIndex % total) + total) % total;
    wishList.classList.toggle('wish-list--solo', total === 1);

    const activeCard = cards[activeWishIndex];
    const offset = activeCard?.offsetLeft ?? 0;
    wishList.style.transform = `translate3d(${-offset}px, 0, 0)`;

    cards.forEach((card, index) => {
      card.setAttribute(
        'aria-hidden',
        index === activeWishIndex ? 'false' : 'true',
      );
    });

    const canCycle = total > 1;
    if (wishPrev) wishPrev.disabled = !canCycle;
    if (wishNext) wishNext.disabled = !canCycle;
  };

  const formatWishCardDate = (timestamp: number, language: 'mix' | 'en') =>
    new Intl.DateTimeFormat(language === 'en' ? 'en-US' : 'id-ID', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    }).format(new Date(timestamp));

  const createWishCard = (wish: {
    id: string;
    name: string;
    message: string;
    createdAt: number;
  }) => {
    const card =
      wishCardTemplate?.content.firstElementChild?.cloneNode(true) ??
      document.createElement('article');

    if (!(card instanceof HTMLElement)) {
      throw new Error('Failed to create wedding wish card');
    }

    card.dataset.wishId = wish.id;

    const name = card.querySelector('.wish-card__name');
    const dateMix = card.querySelector('.wish-card__date .lang-mix');
    const dateEn = card.querySelector('.wish-card__date .lang-en');
    const message = card.querySelector('.wish-card__message');

    if (name) name.textContent = wish.name;
    if (dateMix) {
      dateMix.textContent = formatWishCardDate(Number(wish.createdAt), 'mix');
    }
    if (dateEn) {
      dateEn.textContent = formatWishCardDate(Number(wish.createdAt), 'en');
    }
    if (message) message.textContent = wish.message;

    return card;
  };

  if (wishForm && wishList && wishSubmit) {
    syncWishDeck();

    const moveWishDeck = (direction: -1 | 1) => {
      const total = getWishCards().length;
      if (total < 2) return;
      activeWishIndex = (activeWishIndex + direction + total) % total;
      syncWishDeck();
    };

    wishPrev?.addEventListener('click', () => moveWishDeck(-1));
    wishNext?.addEventListener('click', () => moveWishDeck(1));

    let touchStartX = 0;
    let touchStartY = 0;

    wishStage?.addEventListener(
      'touchstart',
      (event) => {
        const touch = event.changedTouches[0];
        touchStartX = touch.clientX;
        touchStartY = touch.clientY;
      },
      { passive: true },
    );

    wishStage?.addEventListener(
      'touchend',
      (event) => {
        const total = getWishCards().length;
        if (total < 2) return;

        const touch = event.changedTouches[0];
        const deltaX = touch.clientX - touchStartX;
        const deltaY = touch.clientY - touchStartY;

        if (Math.abs(deltaX) < 40 || Math.abs(deltaX) <= Math.abs(deltaY)) {
          return;
        }

        moveWishDeck(deltaX < 0 ? 1 : -1);
      },
      { passive: true },
    );

    window.addEventListener('resize', syncWishDeck);

    wishForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      setWishStatus('idle');

      const formData = new FormData(wishForm);
      const name = String(formData.get('name') ?? '').trim();
      const message = String(formData.get('message') ?? '').trim();

      if (!name || !message) {
        setWishStatus('error');
        if (wishStatus) {
          wishStatus.textContent = wishMessages[getActiveLanguage()].validation;
        }
        return;
      }

      wishSubmit.disabled = true;
      wishSubmit.setAttribute('aria-busy', 'true');
      setWishStatus('pending');

      try {
        const response = await fetch(wishForm.action, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify({ name, message }),
        });

        const payload = await response.json().catch(() => null);

        if (!response.ok || !payload?.wish) {
          throw new Error('Guestbook submission failed');
        }

        wishEmpty?.classList.add('hidden');
        wishList.prepend(createWishCard(payload.wish));
        activeWishIndex = 0;
        syncWishDeck();
        wishForm.reset();
        syncWishFieldPlaceholders();
        setWishStatus('success');
      } catch (error) {
        console.error('Failed to submit wedding wish', error);
        setWishStatus('error');
      } finally {
        wishSubmit.disabled = false;
        wishSubmit.removeAttribute('aria-busy');
      }
    });
  }

  // ── Section heading tilt on mouse move ──
  const tiltSections = document.querySelectorAll(
    '#details, #access',
  ) as NodeListOf<HTMLElement>;
  tiltSections.forEach((section) => {
    const heading = section.querySelector('h2') as HTMLElement | null;
    if (!heading) return;
    section.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = section.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      heading.style.transform = `perspective(800px) rotateY(${x * 3}deg) rotateX(${-y * 2}deg)`;
    });
    section.addEventListener('mouseleave', () => {
      heading.style.transform = '';
      heading.style.transition = 'transform 0.5s cubic-bezier(0.16, 1, 0.3, 1)';
      setTimeout(() => {
        heading.style.transition = '';
      }, 500);
    });
  });
</script>
