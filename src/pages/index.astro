            loading="lazy"
            decoding="async"
          />
          <img
            src="/assets/coco2-smaller.webp"
            alt=""
            class="greeting-cat greeting-cat--coco"
            loading="lazy"
            decoding="async"
          />
          <img
            src="/assets/ucil2-smaller.webp"
            alt=""
            class="greeting-cat greeting-cat--ucil"
