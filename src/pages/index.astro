---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Scrollable content layer -->
  <div id="content-layer" class="relative z-10">
    <!-- Navigation -->
    <nav
      id="main-nav"
      data-auto-scroll-header
      class="fixed top-0 left-0 right-0 z-9999 transition-all duration-500"
    >
      <div
        class="nav-shell desktop-shell max-w-5xl mx-auto px-6 py-4 flex items-center justify-between"
      >
        <span
          class="font-display text-sm tracking-widest uppercase nav-logo text-white drop-shadow-sm"
          >A & S</span
        >
        <div class="flex items-center gap-6">
          <div
            class="hidden md:flex gap-8 text-xs tracking-widest uppercase text-white/70"
          >
            <a
              href="#home"
              class="nav-link relative hover:text-white transition-colors duration-300"
              >Top</a
            >
            <a
              href="#greeting"
              class="nav-link relative hover:text-white transition-colors duration-300"
              >Greeting</a
            >
            <a
              href="/gallery"
              class="nav-link relative hover:text-white transition-colors duration-300"
              >Gallery</a
            >
            <a
              href="#details"
              class="nav-link relative hover:text-white transition-colors duration-300"
              >Details</a
            >
            <a
              href="#schedule"
              class="nav-link relative hover:text-white transition-colors duration-300"
              >Timeline</a
            >
            <a
              href="#access"
              class="nav-link relative hover:text-white transition-colors duration-300"
              >Access</a
            >
            <a
              href="#rsvp"
              class="nav-link relative hover:text-white transition-colors duration-300"
              >RSVP</a
            >
          </div>
          <!-- Language toggle -->
          <button
            id="lang-toggle"
            class="lang-toggle flex items-center gap-1.5 text-[10px] tracking-widest uppercase text-white/60 hover:text-white border border-white/20 hover:border-white/40 rounded-full px-3 py-1.5 transition-all duration-300"
            aria-label="Toggle language"
          >
            <span class="lang-label-mix">ID / EN</span>
            <span class="lang-label-en hidden">EN</span>
          </button>
        </div>
      </div>
    </nav>

    <!-- Hero Section — transparent, shows background -->
    <section
      id="home"
      data-auto-scroll-section
      class="hero-section relative flex items-center justify-center"
    >
      <div id="bg-main" class="absolute inset-0 z-0" aria-hidden="true">
        <img
          src="/assets/p1.webp"
          alt=""
          class="main-bg-image absolute inset-0 h-full w-full object-cover object-center"
          loading="eager"
          decoding="async"
        />
        <div
          class="absolute inset-0 bg-gradient-to-b from-charcoal/40 via-charcoal/18 to-charcoal/32 transition-opacity duration-700"
        >
        </div>
      </div>

      <div class="hero-scene" aria-hidden="true">
        <div class="hero-scene__mountain"></div>
        <img
          src="/assets/p1%20b%20crop.webp"
          alt=""
          class="hero-scene__couple translateY-30"
          loading="eager"
          decoding="async"
        />
        <div class="">
          <img
            src="/assets/gio2.webp"
            alt=""
            class="hero-scene__cat hero-scene__cat--left"
            loading="lazy"
            decoding="async"
          />
          <img
            src="/assets/coco2.webp"
            alt=""
            class="hero-scene__cat hero-scene__cat--right"
            loading="lazy"
            decoding="async"
          />
          <img
            src="/assets/ucil2.webp"
            alt=""
            class="hero-scene__cat hero-scene__cat--center"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>

      <div
        class="hero-content hero-shell relative text-center px-6 pt-20 text-white"
      >
        <div class="inline-block mb-8 reveal" data-delay="0">
          <span class="text-xs tracking-[0.3em] uppercase text-white/70"
            >Wedding Invitation</span
          >
        </div>

        <h1
          class="font-display text-6xl md:text-8xl lg:text-9xl font-normal tracking-tight mb-6 drop-shadow-lg"
        >
          <span class="block reveal" data-delay="200">Affrian</span>
          <span
            class="block text-2xl md:text-3xl text-white/70 font-sans font-light my-4 reveal"
            data-delay="400">&</span
          >
          <span class="block reveal" data-delay="600">Sherly</span>
        </h1>

        <div class="space-y-2 reveal" data-delay="1000">
          <p
            class="font-serif text-2xl md:text-3xl tracking-widest drop-shadow-md"
          >
            2026.05.02
          </p>
          <p class="text-xs tracking-[0.3em] uppercase text-white/60">
            Saturday
          </p>
        </div>

        <button
          type="button"
          data-auto-scroll-next
          class="mt-20 inline-flex items-center justify-center animate-bounce reveal cursor-pointer bg-transparent p-0 text-white/40 transition-colors duration-300 hover:text-white focus:outline-none"
          data-delay="1200"
          aria-label="Scroll to next section"
        >
          <svg
            class="w-5 h-5 mx-auto"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 14l-7 7m0 0l-7-7"></path>
          </svg>
        </button>
      </div>
    </section>

    <!-- Content card sections float above the background -->
    <div class="content-cards">
      <!-- Greeting Section -->
      <section
        id="greeting"
        data-auto-scroll-section
        class="px-6 py-20 md:py-24 flex items-end"
      >
        <div class="greeting-panel" aria-hidden="true">
          <div class="greeting-panel__scene">
            <img
              src="/assets/p1%20b%20crop.webp"
              alt=""
              class="greeting-panel__art"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
        <!-- <div class="max-w-2xl mx-auto text-center">
          <div class="inline-block bg-lime/20 px-4 py-1.5 rounded-full mb-12 reveal">
            <span class="text-xs tracking-[0.2em] uppercase font-medium">Greeting</span>
          </div>

          <div class="lang-mix">
            <p class="font-serif text-lg md:text-xl leading-loose tracking-wide reveal">
              Dengan penuh kebahagiaan kami<br />
              akan melangsungkan pernikahan
            </p>

            <p class="mt-8 text-sm leading-loose text-muted tracking-wide reveal">
              Bersama keluarga tercinta kami bermaksud<br />
              mengundang Bapak/Ibu/Saudara/i<br />
              untuk hadir menyaksikan hari bahagia kami
            </p>

            <p class="mt-8 text-sm leading-loose text-muted tracking-wide reveal">
              Merupakan kebahagiaan yang besar bagi kami<br />
              apabila Anda berkenan hadir<br />
              dan memberikan doa restu
            </p>

            <div class="mt-12 flex items-center justify-center gap-4 reveal">
              <div class="h-px w-12 bg-charcoal/20 divider-line"></div>
              <p class="text-xs tracking-[0.3em] text-muted">Musim Semi 2026</p>
              <div class="h-px w-12 bg-charcoal/20 divider-line"></div>
            </div>
          </div>

          <div class="lang-en">
            <p class="font-serif text-lg md:text-xl leading-relaxed tracking-wide reveal">
              We are delighted to announce<br />
              that we are getting married
            </p>

            <p class="mt-8 text-sm leading-relaxed text-muted tracking-wide reveal">
              We would be honored to have you,<br />
              our dear family and friends,<br />
              join us as we celebrate our ceremony.
            </p>

            <p class="mt-8 text-sm leading-relaxed text-muted tracking-wide reveal">
              We know how precious your time is,<br />
              and it would mean the world to us<br />
              if you could be there.
            </p>

            <div class="mt-12 flex items-center justify-center gap-4 reveal">
              <div class="h-px w-12 bg-charcoal/20 divider-line"></div>
              <p class="text-xs tracking-[0.3em] text-muted">Spring, 2026</p>
              <div class="h-px w-12 bg-charcoal/20 divider-line"></div>
            </div>

            <p class="mt-6 font-serif text-sm tracking-widest reveal">
              Affrian & Sherly
            </p>
          </div>
        </div> -->

        <div
          class="greeting-content desktop-reading-block mx-auto max-w-full text-center"
        >
          <p
            class="font-serif text-sm md:text-base leading-relaxed tracking-[0.02em] reveal"
          >
            &ldquo;Dan di antara tanda-tanda (kebesaran)-Nya ialah<br />
            Dia menciptakan pasangan-pasangan untukmu dari<br />
            jenismu sendiri, agar kamu cenderung dan merasa<br />
            tenteram kepadanya, dan Dia menjadikan di antaramu rasa<br />
            kasih dan sayang. Sesungguhnya pada yang demikian itu<br />
            benar-benar terdapat tanda-tanda (kebesaran Allah) bagi<br />
            kaum yang berpikir.&rdquo;
          </p>
          <p
            class="font-serif text-sm md:text-base leading-relaxed tracking-[0.02em] reveal"
          >
            (QS. Ar-Rum: 21)
          </p>
        </div>
        <div class="greeting-cats" aria-hidden="true">
          <img
            src="/assets/gio2.webp"
            alt=""
            class="greeting-cat greeting-cat--gio"
            loading="lazy"
            decoding="async"
          />
          <img
            src="/assets/coco2.webp"
            alt=""
            class="greeting-cat greeting-cat--coco"
            loading="lazy"
            decoding="async"
          />
          <img
            src="/assets/ucil2.webp"
            alt=""
            class="greeting-cat greeting-cat--ucil"
            loading="lazy"
            decoding="async"
          />
        </div>
      </section>

      <!-- Countdown / Calendar teaser -->
      <section
        id="gallery"
        data-auto-scroll-section
        class="py-16 relative"
        style="background:#aed15d"
      >
        <div class="desktop-shell max-w-3xl mx-auto reveal">
          <a
            href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Affrian+%26+Sherly+Wedding+Ceremony&dates=20260502T140000/20260502T153000&details=Join+us+for+the+wedding+ceremony+of+Affrian+and+Sherly.&location=Masjid+Besar+Riyadhus+Sholihin%2C+Perumahan+Bumi+Sumekar+Asri%2C+Kec.+Kota+Sumenep&ctz=Asia%2FJakarta"
            target="_blank"
            rel="noreferrer"
            class="gallery-teaser calendar-card group block relative overflow-hidden rounded-2xl transition-transform duration-500 hover:-translate-y-1"
          >
            <!-- Decorative sparkles -->
            <svg
              class="sparkle absolute top-6 right-12 w-4 h-4 text-lime-dark/40"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41Z"
              ></path>
            </svg>
            <svg
              class="sparkle absolute top-16 right-24 w-3 h-3 text-lime-dark/30"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41Z"
              ></path>
            </svg>
            <svg
              class="sparkle absolute bottom-20 left-8 w-3 h-3 text-lime-dark/25"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41Z"
              ></path>
            </svg>
            <!-- Decorative curved line -->
            <svg
              class="absolute inset-0 w-full h-full pointer-events-none opacity-20"
              viewBox="0 0 600 300"
              fill="none"
              preserveAspectRatio="none"
            >
              <path
                d="M-20 250 Q150 100 300 180 Q450 260 620 80"
                stroke="currentColor"
                stroke-width="1.5"
                class="text-lime-dark"></path>
            </svg>

            <div class="flex flex-col md:flex-row items-stretch gap-0">
              <!-- Text content -->
              <div
                class="calendar-card__body flex-1 flex flex-col justify-between p-6 md:p-8"
              >
                <div>
                  <div class="calendar-card__header flex items-center">
                    <div class="calendar-card__copy-wrap">
                      <p
                        class="calendar-card__title font-serif italic text-2xl md:text-3xl text-charcoal mb-2"
                      >
                        <span class="lang-mix">Save it to calendar</span>
                        <span class="lang-en">Save it to calendar</span>
                      </p>
                      <p
                        class="calendar-card__copy text-sm leading-relaxed text-charcoal/70 max-w-sm"
                      >
                        <span class="lang-mix"
                          >Simpan tanggal akad kami ke Google Calendar agar
                          tidak terlewat.</span
                        >
                        <span class="lang-en"
                          >Add our ceremony to Google Calendar so the date stays
                          on your schedule.</span
                        >
                      </p>
                    </div>
                    <div
                      class="calendar-card__arrow w-10 h-10 rounded-full border border-charcoal/20 flex items-center justify-center transition-all duration-300 group-hover:bg-charcoal group-hover:border-charcoal"
                    >
                      <svg
                        class="w-5 h-5 text-charcoal transition-colors duration-300 group-hover:text-lime"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="1.5"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                      </svg>
                    </div>
                  </div>
                  <!-- Countdown -->
                  <div id="countdown" class="calendar-countdown">
                    <div class="text-center">
                      <span
                        id="cd-days"
                        class="block text-2xl font-serif text-charcoal tabular-nums"
                        >--</span
                      >
                      <span
                        class="text-[9px] tracking-widest uppercase text-charcoal/50"
                      >
                        <span class="lang-mix">Hari</span>
                        <span class="lang-en">Days</span>
                      </span>
                    </div>
                    <span class="text-xl text-charcoal/30 font-light mt-0.5"
                      >:</span
                    >
                    <div class="text-center">
                      <span
                        id="cd-hours"
                        class="block text-2xl font-serif text-charcoal tabular-nums"
                        >--</span
                      >
                      <span
                        class="text-[9px] tracking-widest uppercase text-charcoal/50"
                      >
                        <span class="lang-mix">Jam</span>
                        <span class="lang-en">Hrs</span>
                      </span>
                    </div>
                    <span class="text-xl text-charcoal/30 font-light mt-0.5"
                      >:</span
                    >
                    <div class="text-center">
                      <span
                        id="cd-mins"
                        class="block text-2xl font-serif text-charcoal tabular-nums"
                        >--</span
                      >
                      <span
                        class="text-[9px] tracking-widest uppercase text-charcoal/50"
                      >
                        <span class="lang-mix">Menit</span>
                        <span class="lang-en">Min</span>
                      </span>
                    </div>
                    <span class="text-xl text-charcoal/30 font-light mt-0.5"
                      >:</span
                    >
                    <div class="text-center">
                      <span
                        id="cd-secs"
                        class="block text-2xl font-serif text-charcoal tabular-nums"
                        >--</span
                      >
                      <span
                        class="text-[9px] tracking-widest uppercase text-charcoal/50"
                      >
                        <span class="lang-mix">Detik</span>
                        <span class="lang-en">Sec</span>
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </a>
        </div>
      </section>

      <div class="story-background">
        <div class="story-background__backdrop" aria-hidden="true">
          <img
            src="/assets/p1.webp"
            alt=""
            class="main-bg-image absolute inset-0 h-full w-full object-cover object-center"
            loading="lazy"
            decoding="async"
          />
          <div
            class="absolute inset-0 bg-gradient-to-b from-charcoal/40 via-charcoal/18 to-charcoal/32 transition-opacity duration-700"
          >
          </div>
        </div>
        <!-- Couple Introduction -->
        <section
          id="introduction"
          data-auto-scroll-section
          data-auto-scroll-align="start"
          class="content-card content-card--transparent py-32 px-6 z-[99]"
        >
          <div class="couple-shell desktop-shell max-w-5xl mx-auto">
            <div class="grid gap-28 md:gap-20">
              <div class="couple-card-group reveal">
                <figure
                  class="couple-card__image-frame couple-card__image-frame--single"
                  aria-hidden="true"
                >
                  <img
                    src="/assets/sherly.webp"
                    alt=""
                    class="couple-card__image couple-card__image--single"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
                <div class="couple-card__text text-left">
                  <h3 class="couple-card__name font-serif italic">
                    Syafazerlinda
                  </h3>
                  <p class="lang-mix couple-card__meta">
                    Putri kedua dari Bpk. Moch. Syafi'i &amp; Ibu Fatimah Umar
                  </p>
                  <p class="lang-en couple-card__meta">
                    Second daughter of Mr. Moch. Syafi'i &amp; Mrs. Fatimah Umar
                  </p>
                </div>
              </div>

              <div class="couple-card-group reveal">
                <figure
                  class="couple-card__image-frame couple-card__image-frame--single"
                  aria-hidden="true"
                >
                  <img
                    src="/assets/rian.webp"
                    alt=""
                    class="couple-card__image couple-card__image--single"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>

                <div class="couple-card__text text-left">
                  <h3 class="couple-card__name font-serif italic">
                    Affrian Rachmansyah
                  </h3>
                  <p class="lang-mix couple-card__meta">
                    Putra pertama dari Bpk. Yanuk Fatchorrahman (Alm.) &amp; Ibu
                    Dinar Rahmawati
                  </p>
                  <p class="lang-en couple-card__meta">
                    First son of Mr. Yanuk Fatchorrahman (late) &amp; Mrs. Dinar
                    Rahmawati
                  </p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Details Section -->
        <section
          id="details"
          data-auto-scroll-section
          class="content-card content-card--transparent py-32 px-6"
        >
          <div class="details-layout desktop-shell w-full">
            <div class="details-composition reveal">
              <div class="details-line">
                <div class="details-line__intro">
                  <p class="details-line__label font-serif">
                    <span class="lang-mix">Hari</span>
                    <span class="lang-en">Day</span>
                  </p>
                  <p class="details-line__meta">
                    <span class="lang-mix">Tanggal</span>
                    <span class="lang-en">Date</span>
                  </p>
                </div>
                <p
                  class="details-line__value details-line__value--date font-serif"
                >
                  <span class="lang-mix">2026.05.02 Sab</span>
                  <span class="lang-en">2026.05.02 Sat</span>
                </p>
              </div>

              <div class="details-line details-line--secondary">
                <div class="details-line__intro">
                  <p class="details-line__label font-serif">
                    <span class="lang-mix">Akad</span>
                    <span class="lang-en">Ceremony</span>
                  </p>
                  <p class="details-line__meta">
                    <span class="lang-mix">Wedding</span>
                    <span class="lang-en">Wedding</span>
                  </p>
                </div>
                <p
                  class="details-line__value details-line__value--time font-serif"
                >
                  <span class="lang-mix">09:00 WIB</span>
                  <span class="lang-en">09:00 AM</span>
                </p>
              </div>
            </div>
          </div>
        </section>

        <!-- Access Section -->
        <section
          id="access"
          data-auto-scroll-section
          class="content-card content-card--transparent py-32 px-6"
        >
          <div class="access-layout desktop-shell max-w-5xl mx-auto">
            <div class="access-composition reveal">
              <div class="access-composition__top">
                <div class="access-composition__label-block">
                  <p class="access-composition__label font-serif">
                    <span class="lang-mix">Tempat</span>
                    <span class="lang-en">Place</span>
                  </p>
                  <p class="access-composition__meta">
                    <span class="lang-mix">Lokasi akad</span>
                    <span class="lang-en">Ceremony venue</span>
                  </p>
                </div>
              </div>

              <a
                href="https://www.google.com/maps/search/?api=1&query=Masjid+Besar+Riyadhus+Sholihin+Perumahan+Bumi+Sumekar+Asri+Kec.+Kota+Sumenep"
                target="_blank"
                rel="noreferrer"
                class="access-composition__title-row"
                aria-label="Open venue in Google Maps"
              >
                <p class="access-composition__title font-serif">
                  Masjid Besar<br />
                  Riyadhus<br />
                  Sholihin
                </p>
                <span class="access-composition__link" aria-hidden="true">
                  <svg
                    class="w-12 h-12"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="rgba(174, 209, 93, 0.94)"
                    stroke-width="1.8"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M14 5h5m0 0v5m0-5L10 14"></path>
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19 14v4a1 1 0 01-1 1h-12a1 1 0 01-1-1V6a1 1 0 011-1h4"
                    ></path>
                  </svg>
                </span>
              </a>

              <div class="access-composition__body">
                <p class="access-composition__address font-serif">
                  <span class="lang-mix"
                    >Perumahan Bumi Sumekar Asri, Kec. Kota Sumenep</span
                  >
                  <span class="lang-en"
                    >Perumahan Bumi Sumekar Asri, Kec. Kota Sumenep</span
                  >
                </p>

                <p class="access-composition__notes">
                  <span class="lang-mix">
                    Parkir tersedia di area sekitar lokasi acara.<br />
                    Silakan gunakan Google Maps untuk rute terbaik menuju venue.
                  </span>
                  <span class="lang-en">
                    Parking is available around the venue.<br />
                    Please use Google Maps for the best route to the venue.
                  </span>
                </p>
              </div>
            </div>
          </div>
        </section>
      </div>

      <!-- RSVP Section — semi-transparent dark -->
      <section
        id="rsvp"
        data-auto-scroll-section
        class="content-card content-card--dark py-32 px-6"
      >
        <div
          class="rsvp-shell desktop-reading-block max-w-xl mx-auto text-center"
        >
          <div
            class="inline-block bg-lime/20 px-4 py-1.5 rounded-full mb-6 reveal"
          >
            <span
              class="text-xs tracking-[0.2em] uppercase font-medium text-lime"
              >RSVP</span
            >
          </div>
          <h2 class="font-display text-3xl md:text-4xl mb-6 text-white reveal">
            <span class="lang-mix">Konfirmasi Kehadiran</span>
            <span class="lang-en">RSVP</span>
          </h2>
          <p class="text-sm text-white/60 leading-relaxed mb-12 reveal">
            <span class="lang-mix">
              Mohon kesediaannya untuk mengisi konfirmasi<br />
              paling lambat <span class="text-white/80 font-medium"
                >15 Maret 2026</span
              ><br />
              agar kami dapat mempersiapkan hari istimewa ini
            </span>
            <span class="lang-en">
              We would appreciate your reply<br />
              by <span class="text-white/80 font-medium">March 15, 2026</span
              ><br />
