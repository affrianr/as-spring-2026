    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-content [data-auto-scroll-next] {
    margin-top: clamp(2.5rem, 8svh, 5rem);
  }

  /* ── Music toggle ── */
  .music-toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.9rem;
    height: 2.9rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.68);
    transition:
      transform 0.25s ease,
      background 0.25s ease,
      border-color 0.25s ease,
      color 0.25s ease,
      box-shadow 0.25s ease;
  }
  .music-toggle__icon {
    width: 1rem;
    height: 1rem;
  }
  .music-toggle__icon--off {
    display: none;
  }
  .music-toggle[data-state='muted'] .music-toggle__icon--on {
    display: none;
  }
  .music-toggle[data-state='muted'] .music-toggle__icon--off {
    display: block;
  }
  .music-toggle__pulse {
    position: absolute;
    top: 0.6rem;
    right: 0.58rem;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: rgba(184, 207, 146, 0.9);
    opacity: 0;
    box-shadow: 0 0 0 0 rgba(184, 207, 146, 0.32);
    transition: opacity 0.2s ease;
  }
  .music-toggle[data-state='playing'] {
    color: rgba(244, 248, 234, 0.92);
    border-color: rgba(184, 207, 146, 0.28);
    background: rgba(184, 207, 146, 0.12);
    box-shadow: 0 8px 22px rgba(68, 99, 79, 0.14);
  }
  .music-toggle[data-state='playing'] .music-toggle__pulse {
    opacity: 1;
    animation: music-pulse 1.8s ease-in-out infinite;
  }
  .music-toggle:hover {
    transform: translateY(-1px);
    color: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.34);
    background: rgba(255, 255, 255, 0.08);
  }
  .music-toggle:active {
    transform: scale(0.96);
  }
  @keyframes music-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(184, 207, 146, 0.32);
    }
    50% {
      box-shadow: 0 0 0 6px rgba(184, 207, 146, 0);
    }
  }

  /* ── Language toggle ── */
  .lang-en {
    display: none;
  }
  .lang-mix {
    display: inline;
  }
  :global([data-lang='en']) .lang-en {
    display: inline;
  }
  :global([data-lang='en']) .lang-mix {
    display: none;
  }
  :global([data-lang='en']) .lang-label-en {
    display: inline !important;
  }
  :global([data-lang='en']) .lang-label-mix {
    display: none !important;
  }

  .lang-toggle:hover {
    background: rgba(255, 255, 255, 0.1);
  }
  .lang-toggle:active {
    transform: scale(0.95);
  }

