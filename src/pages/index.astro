                  <span class="lang-mix">09:00 WIB</span>
                  <span class="lang-en">09:00 AM</span>
                </p>
              </div>
            </div>
          </div>
        </section>

        <!-- Access Section -->
        <section
          id="access"
          data-auto-scroll-section
          class="content-card content-card--transparent py-32 px-6"
        >
          <div class="access-layout desktop-shell max-w-5xl mx-auto">
            <div class="access-composition reveal">
              <div class="access-composition__top">
                <div class="access-composition__label-block">
                  <p class="access-composition__label font-serif">
