                <p class="access-composition__title font-serif">
                  Masjid Besar<br />
                  Riyadhus<br />
                  Sholihin
                </p>
                <span class="access-composition__link" aria-hidden="true">
                  <svg
                    class="w-12 h-12"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="rgba(174, 209, 93, 0.94)"
                    stroke-width="1.8"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M14 5h5m0 0v5m0-5L10 14"></path>
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19 14v4a1 1 0 01-1 1h-12a1 1 0 01-1-1V6a1 1 0 011-1h4"
