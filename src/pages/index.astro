      height: clamp(4.5rem, 12vw, 7rem);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 9999px;
      opacity: 0.5;
    }
    .story-intro__lead {
      margin: 0;
      max-width: 12ch;
      font-size: clamp(2.3rem, 7.5vw, 4.6rem);
      line-height: 0.96;
      color: rgba(255, 255, 255, 0.98);
      text-wrap: balance;
    }
    .story-intro__body {
      margin: 0;
      max-width: 46rem;
      font-size: clamp(1rem, 2.5vw, 1.18rem);
      line-height: 1.85;
      letter-spacing: 0.01em;
      color: rgba(255, 255, 255, 0.78);
    }
    .story-intro__footer {
      display: flex;
      width: fit-content;
      max-width: 100%;
      align-items: center;
      gap: 1rem;
      margin-top: clamp(0.5rem, 2vw, 1rem);
    }
    .story-intro__divider {
      width: clamp(2.5rem, 8vw, 4.5rem);
      height: 1px;
      background: rgba(255, 255, 255, 0.28);
    }
    .story-intro__season {
      margin: 0;
      font-size: 0.75rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.6);
      white-space: nowrap;
    }
    .story-intro__signature {
      margin: 0;
      font-size: clamp(0.95rem, 2vw, 1.15rem);
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.88);
    }

    /* ── Gallery teaser card ── */
    .gallery-anchor {
      height: 0;
    }
    .gallery-teaser {
      color: inherit;
    }
    .calendar-card {
      /* background: #aed15d; */
    }
    .calendar-card__body {
      gap: 1.5rem;
    }
    .calendar-card__header {
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.9rem;
    }
    .calendar-card__copy-wrap {
      flex: 1 1 auto;
      min-width: 0;
    }
    .calendar-card__arrow {
      flex: 0 0 auto;
      width: 2.75rem;
      height: 2.75rem;
      margin-top: 0.1rem;
    }
    .gallery-teaser--floating {
      position: fixed;
      right: max(0.875rem, calc(env(safe-area-inset-right) + 0.875rem));
      bottom: max(0.875rem, calc(env(safe-area-inset-bottom) + 0.875rem));
      z-index: 55;
      width: 4rem;
      height: 4rem;
      overflow: visible;
    }
    .gallery-teaser__summary {
      position: relative;
      display: flex;
      width: 100%;
      height: 100%;
      align-items: center;
      justify-content: center;
      list-style: none;
      cursor: pointer;
      border: 1px solid rgba(255, 255, 255, 0.32);
      background: rgba(225, 255, 0, 0.94);
      backdrop-filter: blur(18px) saturate(135%);
      -webkit-backdrop-filter: blur(18px) saturate(135%);
      box-shadow:
        0 14px 36px rgba(26, 26, 26, 0.16),
        0 10px 30px rgba(225, 255, 0, 0.22);
      transition:
        transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
        box-shadow 0.35s ease,
        background-color 0.35s ease;
    }
    .gallery-teaser__summary::-webkit-details-marker {
      display: none;
    }
    .gallery-teaser__summary::marker {
      content: '';
    }
    .gallery-teaser__summary-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--color-charcoal);
      opacity: 0.78;
    }
    .gallery-teaser__expanded {
      position: absolute;
      right: 0;
      bottom: calc(100% + 0.5rem);
      z-index: 1;
      width: min(19rem, calc(100vw - 1rem));
      padding: 1rem;
      border: 1px solid rgba(255, 255, 255, 0.32);
      border-radius: 1rem;
      background: rgba(225, 255, 0, 0.94);
      backdrop-filter: blur(18px) saturate(135%);
      -webkit-backdrop-filter: blur(18px) saturate(135%);
      box-shadow:
        0 18px 46px rgba(26, 26, 26, 0.16),
        0 12px 30px rgba(225, 255, 0, 0.22);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateY(0.75rem) scale(0.96);
      transform-origin: bottom right;
      transition:
        opacity 0.28s ease,
        transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
        visibility 0.28s ease;
    }
    .gallery-teaser__expanded .calendar-card__title {
      font-size: 1.55rem;
      line-height: 1.08;
      margin-bottom: 0.5rem;
    }
    .gallery-teaser__expanded .calendar-card__copy {
      max-width: none;
      font-size: 0.88rem;
    }
    .gallery-teaser__expanded .calendar-card__footer {
      margin-top: 0.9rem;
      padding-top: 0.9rem;
      border-top: 1px solid rgba(26, 26, 26, 0.12);
    }
    .gallery-teaser__cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 100%;
      padding: 0.75rem 1rem;
      border: 1px solid rgba(26, 26, 26, 0.14);
      border-radius: 0.5rem;
      background: rgba(26, 26, 26, 0.08);
      color: var(--color-charcoal);
      font-size: 0.72rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-decoration: none;
      transition:
        background-color 0.25s ease,
        transform 0.25s ease,
        border-color 0.25s ease;
    }
    .gallery-teaser__cta:hover {
      background: rgba(26, 26, 26, 0.14);
      border-color: rgba(26, 26, 26, 0.24);
      transform: translateY(-1px);
    }
    .gallery-teaser--floating[open] {
      z-index: 65;
    }
    .gallery-teaser--floating[open] .gallery-teaser__expanded,
    .gallery-teaser--floating:focus-within .gallery-teaser__expanded {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateY(0) scale(1);
    }
    .gallery-teaser--floating[open] > .gallery-teaser__summary,
    .gallery-teaser--floating:focus-within > .gallery-teaser__summary {
      box-shadow:
        0 18px 42px rgba(26, 26, 26, 0.18),
        0 14px 34px rgba(225, 255, 0, 0.26);
    }
    /* ── Pointer: desktop mouse hover interactions ── */
    @media (hover: hover) and (pointer: fine) {
      .gallery-teaser--floating:hover .gallery-teaser__expanded {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transform: translateY(0) scale(1);
      }
      .gallery-teaser--floating:hover > .gallery-teaser__summary {
        transform: translateY(-4px) scale(1.03);
        box-shadow:
          0 18px 42px rgba(26, 26, 26, 0.18),
          0 14px 34px rgba(225, 255, 0, 0.26);
      }
    }
    /* ── Mobile portrait: iPhone SE (375×667), iPhone 14/15 (390×844), Pixel 7 (412×915), Galaxy S24 (360×780) ── */
    @media (max-width: 639px) {
      .gallery-teaser--floating {
        width: 3.75rem;
        height: 3.75rem;
        right: max(0.625rem, calc(env(safe-area-inset-right) + 0.625rem));
        bottom: max(0.625rem, calc(env(safe-area-inset-bottom) + 0.625rem));
      }
      .gallery-teaser__expanded {
        width: min(17.25rem, calc(100vw - 0.75rem));
        bottom: calc(100% + 0.45rem);
        padding: 0.9rem;
      }
    }
    .sparkle {
      animation: sparkle-float 3s ease-in-out infinite alternate;
    }
    .sparkle:nth-child(2) {
      animation-delay: 1s;
    }
    .sparkle:nth-child(3) {
      animation-delay: 2s;
    }
    @keyframes sparkle-float {
      0% {
        transform: translateY(0) scale(1);
        opacity: 0.3;
      }
      100% {
        transform: translateY(-6px) scale(1.2);
        opacity: 0.6;
      }
    }
    @media (max-width: 767px), (pointer: coarse) {
      .sparkle {
        animation: none;
      }
    }

    /* ── Map card hover ── */
    .map-card:hover {
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
      transform: translateY(-2px);
    }

    /* ── Wedding wish guestbook ── */
    .wish-section {
      overflow: visible;
      background: transparent;
      border-top: none;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
    #wishes.wish-section {
      padding-bottom: 0;
    }
    .wish-shell {
      position: relative;
      width: 100vw;
      max-width: none;
      margin-inline: calc(50% - 50vw);
      margin-top: -1px;
      padding: clamp(1.15rem, 3vw, 1.6rem)
        max(1.5rem, calc(env(safe-area-inset-right) + 1.5rem))
        clamp(2.5rem, 5vw, 3.5rem)
        max(1.5rem, calc(env(safe-area-inset-left) + 1.5rem));
      background: rgba(174, 209, 93, 1);
      border-top: none;
      overflow: hidden;
    }
    .wish-shell__inner {
      position: relative;
      max-width: min(100%, 74rem);
      margin-inline: auto;
      isolation: isolate;
      --wish-accent: #b8cf92;
      --wish-accent-strong: #dbe8b3;
      --wish-accent-ink: #273618;
      --wish-accent-soft: #eef4dd;
      --wish-accent-line: rgba(61, 86, 28, 0.16);
      --wish-paper: #fffdf5;
      --wish-paper-soft: rgba(255, 252, 243, 0.72);
      --wish-shadow: rgba(74, 99, 40, 0.16);
    }
    .wish-shell__inner::before,
    .wish-shell__inner::after {
      content: '';
      position: absolute;
      inset: auto;
      border-radius: 999px;
      pointer-events: none;
      z-index: -1;
      filter: blur(24px);
      opacity: 0.75;
    }
    .wish-shell__inner::before {
      width: 14rem;
      height: 14rem;
      top: -3rem;
      right: -2rem;
      /* background: radial-gradient(
      circle,
      rgba(249, 248, 231, 0.6) 0%,
      rgba(249, 248, 231, 0) 72%
    ); */
    }
    .wish-shell__inner::after {
      width: 13rem;
      height: 13rem;
      bottom: -2rem;
      left: -1rem;
      background: radial-gradient(
        circle,
        rgba(142, 183, 76, 0.18) 0%,
        rgba(142, 183, 76, 0) 72%
      );
    }
    .wish-grid {
      display: grid;
      gap: 1.35rem;
      align-items: start;
    }
    .wish-panel {
      position: relative;
      overflow: hidden;
      /* border-radius: 2rem; */
      /* border: 1px solid var(--wish-accent-line); */
      /* background: var(--wish-paper-soft); */
      padding: clamp(1.35rem, 3vw, 2rem);
      transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .wish-panel::after {
      content: '';
      position: absolute;
      inset: 0 0 auto 0;
      height: 1px;
    }
    .wish-panel:hover {
      transform: translateY(-2px);
    }
    .wish-panel--form {
      padding: 0;
      background: transparent;
      border-color: transparent;
      box-shadow: none;
    }
    .wish-panel--form::after {
      display: none;
    }
    .wish-panel--form:hover {
      transform: none;
      border-color: transparent;
    }
    .wish-panel--list {
      background: rgba(174, 209, 93, 1);
    }
    .wish-panel__body {
      display: grid;
      gap: 1.35rem;
      padding: clamp(1.35rem, 3vw, 2rem);
      position: relative;
      z-index: 1;
    }
    .wish-scene {
      position: relative;
      z-index: 2;
      width: 100vw;
      max-width: none;
      margin-inline: calc(50% - 50vw);
      margin-bottom: 0;
      pointer-events: none;
    }
    .wish-scene::before {
      content: '';
      position: absolute;
      inset: 8% 20% 12%;
      border-radius: 999px;
      background: radial-gradient(
        circle,
        rgba(255, 255, 255, 0.34) 0%,
        rgba(255, 255, 255, 0) 72%
      );
      filter: blur(26px);
      z-index: -1;
    }
    .wish-scene__image {
      display: block;
      width: 100%;
      height: auto;
      max-width: none;
      /* filter: drop-shadow(0 24px 28px rgba(72, 95, 33, 0.22)); */
    }
    .wish-panel__heading {
      display: grid;
      gap: 0.6rem;
    }
    .wish-panel__eyebrow,
    .wish-list__eyebrow {
      font-size: 0.72rem;
      line-height: 1.6;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: rgba(39, 54, 24, 0.54);
    }
    .wish-panel__title {
      font-size: clamp(2.35rem, 9vw, 3.8rem);
      line-height: 0.92;
      max-width: 10ch;
      color: var(--wish-accent-ink);
    }
    .wish-panel__copy,
    .wish-list__deck {
      margin-top: 0.9rem;
      color: rgba(39, 54, 24, 0.7);
      line-height: 1.75;
      text-align: left;
    }
    .wish-form {
      display: grid;
      gap: 1rem;
    }
    .wish-field {
      display: grid;
      gap: 0.6rem;
      text-align: left;
    }
    .wish-field__label {
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(39, 54, 24, 0.6);
    }
    .wish-input,
    .wish-textarea {
      width: 100%;
      border-radius: 1.1rem;
      border: 1px solid rgba(61, 86, 28, 0.12);
      background: rgba(255, 255, 255, 0.96);
      color: var(--wish-accent-ink);
      padding: 1rem 1.1rem;
      font-size: 0.95rem;
      transition:
        border-color 0.25s ease,
        box-shadow 0.25s ease,
        background 0.25s ease;
    }
    .wish-input::placeholder,
    .wish-textarea::placeholder {
      color: rgba(39, 54, 24, 0.36);
    }
    .wish-input:focus,
    .wish-textarea:focus {
      outline: none;
      border-color: rgba(61, 86, 28, 0.26);
      box-shadow:
        0 0 0 4px rgba(131, 161, 63, 0.12),
        0 14px 28px rgba(74, 99, 40, 0.1);
      background: #fff;
    }
    .wish-textarea {
      min-height: 9.5rem;
      resize: vertical;
      background-image:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.96),
          rgba(255, 255, 255, 0.96)
        ),
        repeating-linear-gradient(
          180deg,
          rgba(39, 54, 24, 0) 0,
          rgba(39, 54, 24, 0) 1.82rem,
          rgba(61, 86, 28, 0.07) 1.82rem,
          rgba(61, 86, 28, 0.07) 1.9rem
        );
    }
    .wish-form__footer {
      display: grid;
      gap: 0.85rem;
      justify-items: start;
      margin-top: 0.25rem;
    }
    .wish-submit {
      width: 100%;
      justify-content: center;
    }
    .wish-submit[disabled] {
      opacity: 0.7;
      cursor: wait;
      box-shadow: none;
    }
    .wish-submit {
      position: relative;
      overflow: hidden;
      background: linear-gradient(180deg, #445d25 0%, #31451a 100%);
      color: #faf8ef;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.14),
        0 16px 28px rgba(66, 90, 28, 0.18);
    }
    .wish-submit::before {
      content: '';
      position: absolute;
      inset: 1px;
      border-radius: inherit;
      border: 1px solid rgba(255, 255, 255, 0.12);
      pointer-events: none;
    }
    .wish-form__note {
      font-size: 0.75rem;
      line-height: 1.7;
      color: rgba(39, 54, 24, 0.58);
      text-align: left;
    }
    .wish-status {
      position: relative;
      overflow: hidden;
      border-radius: 1rem;
      padding: 0.95rem 1.05rem;
      font-size: 0.82rem;
      line-height: 1.6;
      text-align: left;
      box-shadow: 0 12px 26px rgba(69, 89, 39, 0.08);
    }
    .wish-status::before {
      content: '';
      position: absolute;
      inset: 1px 1px auto;
      height: 1px;
      border-radius: 999px;
      opacity: 0.8;
      pointer-events: none;
    }
    .wish-status[data-state='pending'] {
      border: 1px solid rgba(61, 86, 28, 0.1);
      background: rgba(255, 255, 255, 0.68);
      color: rgba(39, 54, 24, 0.78);
    }
    .wish-status[data-state='pending']::before {
      background: linear-gradient(
        90deg,
        rgba(173, 191, 128, 0.72),
        rgba(173, 191, 128, 0)
      );
    }
    .wish-status[data-state='success'] {
      border: 1px solid rgba(78, 106, 44, 0.14);
      background:
        radial-gradient(
          circle at top right,
          rgba(255, 252, 236, 0.88),
          rgba(255, 252, 236, 0) 42%
        ),
        linear-gradient(
          180deg,
          rgba(255, 252, 241, 0.96),
          rgba(241, 246, 221, 0.98)
        );
      color: rgba(39, 54, 24, 0.92);
      padding-inline: 1.1rem 1.2rem;
      box-shadow:
        0 18px 34px rgba(74, 99, 40, 0.12),
        inset 0 1px 0 rgba(255, 255, 255, 0.72);
    }
    .wish-status[data-state='success']::before {
      background: linear-gradient(
        90deg,
        rgba(133, 162, 83, 0.94),
        rgba(214, 228, 176, 0.18),
        rgba(133, 162, 83, 0)
      );
    }
    .wish-status[data-state='error'] {
      border: 1px solid rgba(177, 84, 56, 0.16);
      background: rgba(215, 146, 120, 0.14);
      color: rgba(113, 44, 22, 0.9);
    }
    .wish-status[data-state='error']::before {
      background: linear-gradient(
        90deg,
        rgba(177, 84, 56, 0.64),
        rgba(177, 84, 56, 0)
      );
    }
    .wish-list__top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1.25rem;
      text-align: left;
    }
    .wish-list__tools {
      display: flex;
      align-items: center;
      flex-shrink: 0;
    }
    .wish-list__title {
      margin-top: 0.4rem;
      font-size: clamp(2.15rem, 7vw, 3.4rem);
      line-height: 1.05;
      max-width: 12ch;
    }

    .wish-stage {
      position: relative;
      overflow: hidden;
      margin-top: 1.2rem;
      --wish-peek: clamp(2.6rem, 9vw, 4.75rem);
      --wish-gap: clamp(0.85rem, 2vw, 1.1rem);
      touch-action: pan-y;
      user-select: none;
    }
    .wish-stage::before,
    .wish-stage::after {
      content: '';
      position: absolute;
      top: 0;
      bottom: 0;
      width: 1.1rem;
      z-index: 2;
      pointer-events: none;
    }
    .wish-stage::before {
      left: 0;
      background: linear-gradient(
        90deg,
        rgba(227, 236, 196, 0.95),
        rgba(227, 236, 196, 0)
      );
    }
    .wish-stage::after {
      right: 0;
      background: linear-gradient(
        270deg,
        rgba(227, 236, 196, 0.95),
        rgba(227, 236, 196, 0)
      );
    }
    .wish-list {
      display: flex;
      align-items: stretch;
      gap: 0;
      will-change: transform;
    }
    .wish-list:not(.wish-list--solo) {
      gap: var(--wish-gap);
    }
    .wish-empty {
      border-radius: 1.15rem;
      border: 1px dashed rgba(61, 86, 28, 0.18);
      background: rgba(255, 255, 255, 0.54);
      padding: 1.15rem 1.2rem;
      color: rgba(39, 54, 24, 0.68);
      line-height: 1.8;
      text-align: left;
    }
    .wish-card {
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      flex: 0 0 calc(100% - var(--wish-peek));
      min-height: clamp(17rem, 42vw, 19.5rem);
      max-height: clamp(17rem, 42vw, 19.5rem);
      border-radius: 1.35rem;
      border: 1px solid rgba(61, 86, 28, 0.12);
      background: linear-gradient(180deg, #fffdf6 0%, #f8f6ec 100%);
      padding: 1.2rem 1.25rem 1.15rem;
      margin-inline: 0;

      transition:
        transform 0.3s ease,
        border-color 0.25s ease;
    }
    .wish-card[aria-hidden='true'] {
      opacity: 0.68;
      transform: scale(0.965);
    }
    .wish-card[aria-hidden='false'] {
      opacity: 1;
      transform: scale(1);
    }
    .wish-list--solo .wish-card {
      flex-basis: 100%;
    }
    .wish-card::before {
      content: '';
      position: absolute;
      inset: 0 auto 0 0;
      width: 3px;
      background: linear-gradient(
        180deg,
        rgba(127, 154, 69, 0.88) 0%,
        rgba(127, 154, 69, 0) 100%
      );
      opacity: 0.72;
    }
    .wish-card::after {
      content: '';
      position: absolute;
      top: 0.85rem;
      right: 1rem;
      width: 2.2rem;
      height: 0.55rem;
      border-radius: 999px;
      background: rgba(186, 208, 129, 0.34);
      transform: rotate(10deg);
      pointer-events: none;
    }
    .wish-card:hover {
      transform: translateY(-2px);
      border-color: rgba(61, 86, 28, 0.18);
    }
    .wish-card__head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.85rem;
      flex-shrink: 0;
    }
    .wish-card__name {
      font-size: 0.95rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--wish-accent-ink);
    }
    .wish-card__date {
      margin-top: 0.35rem;
      font-size: 0.73rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(39, 54, 24, 0.42);
    }
    .wish-card__glyph {
      color: rgba(127, 154, 69, 0.82);
      font-size: 1rem;
      transform: translateY(0.15rem);
    }
    .wish-card__message {
      margin-top: 0.9rem;
      flex: 1 1 auto;
      overflow-y: auto;
      padding-right: 0.35rem;
      color: rgba(39, 54, 24, 0.84);
      line-height: 1.8;
      white-space: pre-line;
      text-wrap: pretty;
      overflow-wrap: anywhere;
      overscroll-behavior: contain;
      scrollbar-width: thin;
      scrollbar-color: rgba(127, 154, 69, 0.42) rgba(61, 86, 28, 0.06);
    }
    .wish-card__message::-webkit-scrollbar {
      width: 0.35rem;
    }
    .wish-card__message::-webkit-scrollbar-track {
      background: rgba(61, 86, 28, 0.06);
      border-radius: 999px;
    }
    .wish-card__message::-webkit-scrollbar-thumb {
      background: rgba(127, 154, 69, 0.42);
      border-radius: 999px;
    }
    .rsvp-btn:hover {
      background: linear-gradient(180deg, #c9dbab 0%, #b1c788 100%);
      transform: translateY(-2px);
      box-shadow: 0 10px 28px rgba(68, 99, 79, 0.22);
    }
    .rsvp-btn:hover .rsvp-arrow {
      transform: translateX(4px);
    }
    .rsvp-btn:active {
      transform: translateY(0);
      box-shadow: 0 2px 10px rgba(68, 99, 79, 0.14);
    }

    /* ── Divider line expand ── */
    .divider-line {
      transition: width 1s cubic-bezier(0.16, 1, 0.3, 1) 0.3s;
    }
    .reveal:not(.visible) .divider-line {
      width: 0;
    }

    /* ── Footer ── */
    .footer-logo {
      transition:
        letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1),
        color 0.3s ease;
      cursor: default;
    }
    .footer-logo:hover {
      letter-spacing: 0.2em;
    }
    .footer-dot {
      animation: pulse-dot 2s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%,
      100% {
        box-shadow: 0 0 0 0 rgba(225, 255, 0, 0.4);
      }
      50% {
        box-shadow: 0 0 0 6px rgba(225, 255, 0, 0);
      }
    }

    /* ── Hero ── */
    .hero-section {
      --hero-couple-transform: translateX(0);
    }
    .hero-scene {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
    }
    /* ── Hero load sequence: bg → mountain → couple → cats → text ── */
    .hero-bg-image {
      opacity: 0;
      transform: scale(1.04);
      transition:
        opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
        transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .hero-scene__mountain {
      position: absolute;
      left: 0;
      right: 0;
      bottom: -1px;
      height: 60%;
      background: url('/assets/gunung.webp') center bottom / cover no-repeat;
      opacity: 0;
      transform: translate3d(0, 2.4rem, 0) scale(1.04);
      transition:
        opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.5s,
        transform 1.3s cubic-bezier(0.16, 1, 0.3, 1) 0.5s;
    }
    .hero-scene__couple {
      position: absolute;
      top: 60%;
      left: 0;
      bottom: auto;
      width: 100%;
      max-width: none;
      opacity: 0;
      transform: var(--hero-couple-transform) translate3d(0, 3rem, 0)
        scale(0.94);
      filter: blur(12px);
      background-repeat: no-repeat;
      transition:
        opacity 1s cubic-bezier(0.16, 1, 0.3, 1) 1s,
        transform 1.4s cubic-bezier(0.16, 1, 0.3, 1) 1s,
        filter 1.2s cubic-bezier(0.16, 1, 0.3, 1) 1s;
    }
    .hero-scene__cat {
      opacity: 0;
      transform: translate3d(0, 1.4rem, 0) scale(0.92);
      filter: blur(10px);
      transition:
        opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
        transform 1.05s cubic-bezier(0.16, 1, 0.3, 1),
        filter 1s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .hero-scene__cat--left {
      transition-delay: 0s;
    }
    .hero-scene__cat--right {
      transition-delay: 0.1s;
    }
    .hero-scene__cat--center {
      transition-delay: 0.2s;
    }
    .hero-scene__cat--visible {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
      filter: blur(0);
    }
    .hero-section--loaded .hero-bg-image {
      opacity: 1;
      transform: scale(1);
    }
    .hero-section--loaded .hero-scene__mountain {
      opacity: 0.98;
      transform: translate3d(0, 0, 0) scale(1);
    }
    .hero-section--loaded .hero-scene__couple {
      opacity: 1;
      transform: var(--hero-couple-transform) translate3d(0, 0, 0) scale(1);
      filter: blur(0);
    }
    /* cats are revealed on scroll via .hero-scene__cat--visible */
    .hero-content {
      z-index: 1;
      display: flex;
      width: min(100%, 28rem);
      margin-inline: auto;
      flex-direction: column;
      align-items: center;
      will-change: transform;
      padding-top: max(5rem, calc(env(safe-area-inset-top) + 4.5rem));
      padding-bottom: 10.5rem;
      text-shadow: 0 10px 30px rgba(16, 66, 86, 0.18);
    }
    .hero-content .space-y-2 {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .hero-content [data-auto-scroll-next] {
      margin-top: clamp(2.5rem, 8svh, 5rem);
    }
    .hero-scroll-cue {
      transform: translate3d(0, 0, 0);
    }

    #introduction,
    #details,
    #schedule,
    #access,
    #wishes {
      padding-block: var(--mobile-section-padding);
    }
    #introduction {
      overflow: hidden;
    }
    #access {
      padding-bottom: 0;
    }
    #access + footer {
      margin-top: 0;
    }
    footer[data-auto-scroll-section] {
      padding-block: clamp(3rem, 8svh, 4.5rem);
      background: rgba(174, 209, 93, 1);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border-top: none;
    }
    .calendar-countdown {
      display: flex;
      flex-direction: row;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.65rem;
      margin-top: 1rem;
      justify-content: flex-start;
    }
    .calendar-countdown > span {
      display: block;
    }
    .calendar-countdown > div {
      min-width: 3.25rem;
      padding-top: 0.75rem;
      border-top: 1px solid rgba(26, 26, 26, 0.14);
    }
    .calendar-card__footer {
      display: flex;
      gap: 1rem;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      text-align: center;
    }
    .timeline-item {
      gap: clamp(0.9rem, 4vw, 1.25rem);
    }
    .timeline-item > div:first-child {
      width: 4.75rem;
    }
    .timeline-item > div:last-child {
      padding-bottom: 2.5rem;
    }
    .access-map {
      aspect-ratio: 4 / 5;
    }
    .rsvp-btn {
      justify-content: center;
    }

    /* ── Accessibility: users who prefer reduced motion ── */
    @media (prefers-reduced-motion: reduce) {
      .reveal {
        opacity: 1;
        transform: none;
        transition: none;
      }
      .hero-bg-image,
      .hero-scene__mountain,
      .hero-scene__cat {
        opacity: 1;
        transform: none;
        filter: none;
        transition: none;
      }
      .hero-scene__couple {
        opacity: 1;
        transform: var(--hero-couple-transform);
        filter: none;
        transition: none;
      }
      .footer-dot {
        animation: none;
      }
    }

    /* ── Mobile + tablet (≤1023px): hide hero cats on small screens — iPhone, Galaxy, iPad Mini/Air ── */
    @media (max-width: 1023px) {
      .hero-scene__cat {
        display: none;
      }
      .wish-hero__caption {
        position: static;
        margin-top: 1rem;
        text-align: center;
      }

      /* ── Details: 2-col layout on mobile so label/value don't overlap ── */
      .details-line__intro {
        transform: none;
      }
      .details-line {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.75rem clamp(1rem, 4vw, 2rem);
        align-items: start;
      }

      /* ── Access: neutralise translateY so label doesn't slide into venue title ── */
      .access-composition__label-block {
        transform: none;
      }
    }
    /* ── Small tablet + up (≥640px): iPad Mini (768), iPad Air (820), Surface Duo (540) ── */
    @media (min-width: 640px) {
      .calendar-card {
        background: rgba(174, 209, 93, 0.94);
      }
      #gallery {
        background: transparent !important;
        padding-top: 4rem;
        padding-bottom: 4rem;
      }
    }
    /* ── Tablet portrait (640px–1023px): iPad Mini (768×1024), iPad Air (820×1180), Surface Pro (912×1368) ── */
    @media (min-width: 640px) and (max-width: 1023px) {
      .couple-card__text--rian {
        justify-self: end;
        justify-items: end;
        text-align: right;
        width: 100%;
        padding-right: 1.5rem;
        box-sizing: border-box;
      }
      .hero-shell,
      .hero-content {
        width: min(100%, 31rem);
      }
      .hero-content {
        padding-top: max(5rem, calc(env(safe-area-inset-top) + 4.5rem));
        padding-bottom: 8rem;
      }
      .hero-scene__couple {
        top: 56%;
        left: 0;
        width: 100%;
        transform: none;
      }
      .hero-scene__mountain {
        top: auto;
        bottom: -1px;
        height: 65%;
      }
      .couple-card__portrait-image {
        width: min(100%, 24rem);
      }
      .access-map {
        aspect-ratio: 16 / 10;
      }
      #greeting {
        --greeting-scene-height: clamp(14rem, 34svh, 19rem);
        padding-top: calc(
          var(--greeting-scene-height) + clamp(0.35rem, 1.4svh, 0.9rem)
        );
        padding-bottom: clamp(2rem, 5svh, 3rem);
      }
      .greeting-panel {
        background: transparent;
      }
      .greeting-panel__scene {
        display: none;
      }
      .greeting-panel__art {
        display: none;
      }
      .greeting-content {
        width: min(100%, 29rem);
        padding-top: 0;
        padding-bottom: 0;
      }
      .greeting-content > p:first-child {
        font-size: clamp(0.98rem, 3.15vw, 1.08rem);
        line-height: 1.8;
      }
      .greeting-cat--gio {
        left: clamp(1.75rem, 6vw, 2.75rem);
        top: clamp(6.25rem, 17svh, 10rem);
        width: clamp(4.75rem, 21vw, 6.25rem);
      }
      .greeting-cat--coco {
        right: clamp(2.5rem, 8vw, 3.25rem);
        top: clamp(3.75rem, 10svh, 7rem);
        width: clamp(5.5rem, 24vw, 7.5rem);
      }
      .greeting-cat--ucil {
        top: clamp(9rem, 21.5svh, 13.5rem);
        width: clamp(5.5rem, 24vw, 7.25rem);
      }
      .calendar-card {
        background: transparent;
        border: none;
        box-shadow: none;
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
      }
      #gallery {
        background: #aed15d !important;
        padding-top: clamp(2.5rem, 7svh, 4rem);
        padding-bottom: clamp(2.5rem, 7svh, 4rem);
      }
      .calendar-card__body {
        gap: 1.5rem;
      }
      .calendar-countdown {
        gap: 0.65rem;
        margin-top: 1rem;
      }
    }
    /* ── Small phones + short viewports (≤389px wide or ≤739px tall): iPhone SE (375×667), iPhone 13 mini (375×812 landscape) ── */
    @media (max-width: 389px), (max-height: 739px) {
      #greeting {
        --greeting-scene-height: clamp(12.5rem, 31svh, 16rem);
      }
      .hero-scene__couple {
        top: 67%;
      }
      .hero-content {
        padding-bottom: 8rem;
      }
      .hero-content [data-auto-scroll-next] {
        margin-top: 2rem;
      }
      #greeting {
        padding-top: calc(
          var(--greeting-scene-height) + clamp(0.35rem, 1.2svh, 0.75rem)
        );
      }
      .greeting-panel__art {
        top: -18.5rem;
      }
      .greeting-cat--gio {
        top: clamp(5.9rem, 15.5svh, 8.4rem);
      }
      .greeting-cat--coco {
        top: clamp(3.25rem, 9svh, 5rem);
      }
      .greeting-cat--ucil {
        top: clamp(8rem, 19.5svh, 11.25rem);
      }
      .calendar-countdown {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.8rem 1rem;
      }
      .calendar-countdown > span {
        display: none;
      }
      .calendar-countdown > div {
        min-width: 0;
        text-align: center;
      }
      .wish-hero__title {
        font-size: clamp(2.2rem, 12vw, 3rem);
      }
      .wish-card:nth-child(2n),
      .wish-card:nth-child(3n) {
        transform: none;
      }
      .wish-card {
        min-height: 18.5rem;
        max-height: 18.5rem;
      }
    }

    /* ── Desktop (≥1024px): iPad Pro portrait (1024×1366), MacBook 13" (1280×800), 1080p (1920×1080), 2K/4K monitors ── */
    @media (min-width: 1024px) {
      .desktop-shell {
        max-width: 1280px;
      }
      .desktop-reading-block {
        max-width: 40rem;
      }
      .ambient-spacer {
        height: clamp(10rem, 18vw, 15rem);
      }
      .ambient-spacer--after-greeting {
        height: 0;
      }
      #introduction,
      #details,
      #schedule,
      #access,
      #wishes {
        padding-block: clamp(5.25rem, 8vw, 7rem);
      }
      #access {
        padding-bottom: 0;
      }
      footer[data-auto-scroll-section] {
        padding-block: clamp(3.25rem, 5vw, 4.5rem);
      }
      .content-card + .content-card {
        margin-top: clamp(1.5rem, 2vw, 2.25rem);
      }
      .hero-section {
        justify-content: flex-start;
        overflow: visible;
        align-items: center;
        z-index: 0;
      }

      .main-bg-image,
      .story-background__image {
        object-position: 72% 20%;
        transform: scale(1);
      }
      .hero-shell {
        width: min(40rem, 38vw);
        max-width: 38rem;
        margin-left: max(2rem, calc((100vw - 1280px) / 2 + 2rem));
        margin-right: auto;
        padding-inline: 0;
        padding-top: clamp(5rem, 10vh, 7rem);
        padding-bottom: clamp(7rem, 12vw, 10rem);
        text-align: left;
        z-index: 2;
      }
      .hero-content {
        display: block;
      }
      .hero-shell h1 {
        max-width: 32rem;
        font-size: clamp(5.75rem, 8vw, 8rem);
        line-height: 0.92;
      }
      .hero-shell .space-y-2 {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
      }
      .hero-scene {
        z-index: 1;
      }
      .hero-scene__mountain {
        display: block;
        left: 0;
        right: 0;
        width: 100%;
        height: 100%;
        background-repeat: no-repeat;
        background-size: cover;
        background-position: center bottom;
        opacity: 0.98;
        -webkit-mask-image: none;
        mask-image: none;
      }
      .hero-scene__couple {
        display: block;
        top: 55%;
        left: 0;
        right: auto;
        bottom: auto;
        width: 100%;
        max-width: none;
        filter: drop-shadow(0 26px 44px rgba(17, 59, 77, 0.18));
        --hero-couple-transform: translateX(0);
        -webkit-mask-image: none;
        mask-image: none;
      }
      .hero-scene__cat {
        display: none;
      }

      /* ── Desktop landscape (≥1024px wide AND wider than tall): MacBook, iMac, 1080p, 2K, 4K — side-by-side hero layout ── */
      @media (min-aspect-ratio: 4/3) {
        .hero-shell {
          width: min(40rem, 38vw);
          max-width: 38rem;
          margin-left: max(2rem, calc((100vw - 1280px) / 2 + 2rem));
          margin-right: auto;
          text-align: left;
        }
        .hero-content {
          display: block;
        }
        .hero-shell h1 {
          max-width: 32rem;
          font-size: clamp(5.75rem, 8vw, 8rem);
          line-height: 0.92;
        }
        .hero-shell .space-y-2 {
          align-items: flex-start;
        }
        .hero-scene__mountain {
          top: 40%;
          opacity: 1;
          height: 100%;
          -webkit-mask-image: linear-gradient(
            to top,
            #000 0%,
            #000 40%,
            transparent 100%
          );
          mask-image: linear-gradient(
            to top,
            #000 0%,
            #000 40%,
            transparent 100%
          );
          -webkit-mask-repeat: no-repeat;
          mask-repeat: no-repeat;
        }
        .hero-scene__couple {
          top: 15%;
          left: 50%;
          bottom: clamp(-20rem, -11vw, -10rem);
          --hero-couple-transform: translateX(-50%);
          filter: drop-shadow(0 26px 44px rgba(17, 59, 77, 0.18));
        }
      }

      #greeting {
        min-height: clamp(34rem, 52vw, 44rem);
        padding-block: clamp(5rem, 7vw, 7rem);
        padding-inline: 0;
        overflow: hidden;
        align-items: center;
        justify-content: flex-start;
      }
      .greeting-panel__scene {
        display: none;
      }
      .greeting-panel {
        display: none;
      }
      .greeting-content {
        width: min(40rem, 42vw);
        max-width: 40rem;
        margin-left: max(2rem, calc((100vw - 1280px) / 2 + 2rem));
        margin-right: auto;
        margin-bottom: 0;
        padding: clamp(2rem, 3vw, 3rem);
        text-align: left;
        background: rgba(174, 209, 93, 0.94);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 2rem;
        box-shadow: 0 24px 60px rgba(32, 72, 48, 0.18);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
      }
      .greeting-cats {
        display: grid;
        position: absolute;
        left: calc(
          max(2rem, ((100vw - 1280px) / 2 + 2rem)) + min(40rem, 38vw) +
            clamp(4rem, 7vw, 7rem)
        );
        top: 50%;
        bottom: auto;
        width: clamp(19rem, 21vw, 24rem);
        grid-template-columns: 0.95fr 1.1fr;
        grid-template-areas:
          'gio coco'
          'ucil coco';
        align-items: end;
        gap: clamp(0.75rem, 1.2vw, 1.1rem);
        transform: translateY(-50%);
        z-index: 2;
        pointer-events: none;
      }
      .greeting-cat {
        display: block;
        position: relative;
        left: auto;
        right: auto;
        top: auto;
        width: 100%;
        max-width: none;
        filter: drop-shadow(0 16px 24px rgba(26, 26, 26, 0.14));
      }
      .greeting-cat--gio {
        grid-area: gio;
        width: 98%;
        justify-self: start;
        transform: translateY(-1rem) rotate(-3deg);
      }
      .greeting-cat--coco {
        grid-area: coco;
        width: 112%;
        align-self: center;
        justify-self: center;
      }
      .greeting-cat--ucil {
        grid-area: ucil;
        width: 108%;
        justify-self: end;
        transform: translateY(-1rem);
      }
      .greeting-content > p:first-child {
        max-width: 32rem;
        font-size: clamp(1.2rem, 1.45vw, 1.45rem);
        line-height: 1.7;
      }
      .greeting-content > p:last-child {
        font-size: 0.95rem;
        margin-top: 1rem;
        letter-spacing: 0.08em;
      }
      .greeting-content br {
        display: none;
      }

      .gallery-teaser--floating {
        width: 4.25rem;
        height: 4.25rem;
        bottom: max(1rem, calc(env(safe-area-inset-bottom) + 1rem));
        right: max(1rem, calc(env(safe-area-inset-right) + 1rem));
      }
      .gallery-teaser__expanded {
        width: min(21rem, calc(100vw - 2rem));
        bottom: calc(100% + 0.65rem);
        padding: 1.1rem;
      }
      .gallery-teaser__expanded .calendar-card__title {
        font-size: 1.8rem;
        margin-bottom: 0.6rem;
      }
      .gallery-teaser__expanded .calendar-card__copy {
        font-size: 0.95rem;
      }
      .gallery-teaser__expanded .calendar-countdown {
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.85rem;
      }
      .gallery-teaser__expanded .calendar-countdown > div {
        text-align: center;
        padding-top: 0.85rem;
      }

      .couple-shell {
        max-width: 1280px;
      }
      #introduction {
        border-top: none;
        overflow: hidden;
        isolation: isolate;
      }
      #introduction .grid {
        gap: clamp(6rem, 10vw, 10rem);
      }
      .couple-card-group {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
        gap: clamp(2rem, 3vw, 3.5rem);
        align-items: end;
      }
      .couple-card-group--reverse {
        grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
      }
      .couple-card__image-frame--single {
        width: 100%;
        justify-self: start;
      }
      .couple-card-group--reverse .couple-card__image-frame--single {
        order: 2;
        justify-self: end;
      }
      .couple-card-group--reverse .couple-card__text {
        order: 1;
        justify-self: center;
        text-align: center;
      }
      .couple-card__text {
        width: 100%;
        max-width: 32rem;
        padding-bottom: clamp(1rem, 3vw, 2.5rem);
        justify-self: center;
      }
      .couple-card__name {
        font-size: clamp(4.5rem, 6vw, 6.5rem);
      }
      .couple-card__meta {
        font-size: clamp(1.05rem, 1.2vw, 1.18rem);
        line-height: 1.8;
        max-width: 22rem;
      }
      .couple-card__image-frame--single {
        aspect-ratio: 3 / 4;
      }
      #introduction
        .couple-card-group:nth-of-type(1)
        .couple-card__image-frame--single {
        max-width: 28rem;
      }
      #introduction
        .couple-card-group:nth-of-type(2)
        .couple-card__image-frame--single {
        max-width: 28rem;
      }

      .details-layout {
      }
      .details-composition {
        gap: clamp(3rem, 7vw, 6rem);
      }
      .details-line {
        display: grid;
        grid-template-columns: minmax(11rem, 0.42fr) minmax(0, 1fr);
        gap: clamp(2rem, 4vw, 4.5rem);
        align-items: center;
      }
      .details-line__intro {
        align-self: center;
      }
      .details-line__value--date {
        justify-self: end;
        text-align: right;
        font-size: clamp(5rem, 7.8vw, 7.4rem);
      }
      .details-line__value--time {
        justify-self: end;
        text-align: right;
        font-size: clamp(4rem, 6vw, 5.4rem);
      }
      .details-line--secondary {
        margin-top: clamp(0.5rem, 1.5vw, 1.5rem);
      }
      .details-venue {
        margin-top: 0.5rem;
        padding-top: 1.75rem;
      }

      .schedule-shell {
        max-width: 56rem;
      }
      .schedule-shell > .text-center {
        margin-bottom: clamp(2.75rem, 4vw, 3.5rem);
      }
      #schedule .space-y-0 {
        max-width: 44rem;
        margin: 0 auto;
      }
      .timeline-item {
        gap: clamp(1.5rem, 2vw, 2rem);
      }
      .timeline-item > div:first-child {
        width: 6rem;
      }
      .timeline-item > div:last-child {
        max-width: 26rem;
        padding-bottom: 3rem;
      }

      .access-layout {
        max-width: 1280px;
      }
      .story-intro {
        max-width: 1280px;
      }
      .story-intro__composition {
        position: relative;
        gap: clamp(2rem, 4vw, 3.5rem);
      }
      .story-intro__label-block {
        position: absolute;
        top: 0;
        right: 0;
        transform: translateY(1.25rem);
      }
      .story-intro__panel {
        display: flex;
        min-height: clamp(22rem, 40vw, 30rem);
        width: min(100%, 48rem);
        align-items: flex-end;
        padding-top: clamp(6rem, 10vw, 8.5rem);
      }
      .access-composition {
        position: relative;
      }
      .access-composition__top {
        position: absolute;
        top: 0;
        right: 0;
        display: block;
      }
      .access-composition__label-block {
        text-align: right;
      }
      .access-composition__title {
        font-size: clamp(5.2rem, 8vw, 7.6rem);
        max-width: 8.5ch;
      }
      .access-composition__body {
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1.75rem 2rem;
      }
      .access-composition__address {
        font-size: clamp(1.7rem, 2.3vw, 2.3rem);
        max-width: 34rem;
      }
      .access-composition__notes {
        max-width: 52rem;
        font-size: clamp(1.1rem, 1.45vw, 1.35rem);
      }

      .wish-grid {
        grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
        gap: clamp(1.5rem, 2.4vw, 2rem);
        align-items: start;
      }
      .wish-scene {
        margin-bottom: 0;
      }
      .wish-hero {
        grid-template-columns: minmax(0, 1.12fr) minmax(17rem, 0.88fr);
        align-items: center;
        text-align: left;
        padding: clamp(1.9rem, 3vw, 2.6rem);
      }
      .wish-hero__labels {
        justify-content: flex-start;
      }
      .wish-hero__lead {
        margin-inline: 0;
      }
      .wish-hero__art {
        min-height: 14rem;
      }
      .wish-hero__caption {
        right: 0.5rem;
        bottom: 0.5rem;
      }
      .footer-shell {
        max-width: 30rem;
        margin-inline: auto;
      }
    }

    /* ── Phones + iPad Mini exact width (≤768px): iPhone SE (375), iPhone 14/15 (390), Pixel 7 (412), Galaxy S24 (360), iPad Mini (768) ── */
    @media (max-width: 1023px) {
      .couple-card__image-frame--sherly {
        justify-self: end;
        margin-left: 0;
        margin-right: -1.5rem;
      }
      .couple-card__image-frame--rian {
        justify-self: start;
        margin-left: -1.5rem;
        margin-right: 0;
      }
      .couple-card__text--sherly {
        justify-self: start;
        justify-items: start;
        text-align: left;
      }
    }
    @media (max-width: 768px) {
      .hero-scene__mountain {
        height: 60%;
        background-position: center bottom;
      }

      .story-intro__label-block {
        justify-items: center;
        text-align: center;
      }
      .story-intro__panel {
        padding: 1.75rem 1.5rem 2rem;
      }
      .story-intro__lead,
      .story-intro__body {
        max-width: none;
      }
      .story-intro__footer {
        gap: 0.75rem;
      }
      .story-intro__season {
        letter-spacing: 0.22em;
      }
      .story-intro__signature {
        letter-spacing: 0.24em;
      }

      .couple-card-group {
        --couple-group-gap: 1.25rem;
      }
      .couple-card__image-frame--sherly {
        justify-self: end;
        margin-right: -1.5rem;
      }
      .couple-card__image-frame--rian {
        justify-self: start;
        margin-left: -1.5rem;
      }
      .couple-card__text--sherly,
      .couple-card__text--rian {
        justify-self: center;
        justify-items: center;
        text-align: center;
        width: min(100%, 22rem);
      }
      .couple-card__text--sherly .couple-card__meta,
      .couple-card__text--rian .couple-card__meta {
        margin-inline: auto;
      }
      .couple-separator {
        margin-block: -0.5rem;
      }
    }
  </style>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    );
    const liteMotionMedia = window.matchMedia(
      '(max-width: 767px), (pointer: coarse)',
    );
    const finePointerMedia = window.matchMedia(
      '(hover: hover) and (pointer: fine)',
    );

    const getMotionTier = (): 'reduced' | 'lite' | 'full' => {
      if (prefersReducedMotion.matches) return 'reduced';
      return liteMotionMedia.matches ? 'lite' : 'full';
    };

    const revealElements = Array.from(
      document.querySelectorAll<HTMLElement>('.reveal'),
    );
    const heroReveals = revealElements.filter((element) =>
      element.closest('#home'),
    );
    const heroSection = document.getElementById('home') as HTMLElement | null;
    const heroContent = document.querySelector(
      '.hero-content',
    ) as HTMLElement | null;
    const heroBgImage = document.querySelector(
      '.hero-bg-image',
    ) as HTMLElement | null;
    const heroCouple = document.querySelector(
      '.hero-scene__couple',
    ) as HTMLElement | null;
    const heroCats = Array.from(
      document.querySelectorAll<HTMLElement>('.hero-scene__cat'),
    );
    const nav = document.getElementById('main-nav') as HTMLElement | null;
    const heroScrollCue = document.querySelector(
      '.hero-scroll-cue',
    ) as HTMLElement | null;
    const syncNavState = () => {
      nav?.classList.toggle('scrolled', window.scrollY > 80);
    };

    const markVisible = (elements: HTMLElement[]) => {
      elements.forEach((element) => element.classList.add('visible'));
    };

    const showImmediately = (elements: HTMLElement[]) => {
      if (!elements.length) return;
      markVisible(elements);
      gsap.set(elements, { clearProps: 'all' });
    };

    const createRevealTrigger = (
      trigger: HTMLElement | null,
      targets: HTMLElement[],
      options?: {
        start?: string;
        y?: number;
        duration?: number;
        stagger?: number;
      },
    ) => {
      if (!trigger || targets.length === 0) return;

      gsap.set(targets, { autoAlpha: 0, y: options?.y ?? 30 });

      ScrollTrigger.create({
        trigger,
        start: options?.start ?? 'top 84%',
        once: true,
        onEnter: () => {
          gsap.to(targets, {
            autoAlpha: 1,
            y: 0,
            duration: options?.duration ?? 0.7,
            stagger: options?.stagger ?? 0.08,
            ease: 'power3.out',
            onComplete: () => markVisible(targets),
          });
        },
      });
    };

    const setupHeroScrollMotion = (tier: 'lite' | 'full') => {
      if (!heroSection || !nav) return;

      ScrollTrigger.create({
        trigger: heroSection,
        start: 'top top',
        end: 'bottom top',
        onUpdate: syncNavState,
        onRefresh: syncNavState,
      });

      if (tier !== 'full' || !heroContent) return;

      const heroTimeline = gsap.timeline({
        scrollTrigger: {
          trigger: heroSection,
          start: 'top top',
          end: 'bottom top',
          scrub: 0.8,
        },
      });

      heroTimeline.to(
        heroContent,
        {
          yPercent: 18,
          autoAlpha: 0.18,
          ease: 'none',
        },
        0,
      );

      if (heroBgImage) {
        heroTimeline.to(
          heroBgImage,
          {
            scale: 1.08,
            ease: 'none',
          },
          0,
        );
      }

      if (heroCouple) {
        heroTimeline.to(
          heroCouple,
          {
            yPercent: -7,
            scale: 1.03,
            ease: 'none',
          },
          0,
        );
      }
    };

    const setupHeroScrollCue = (tier: 'lite' | 'full') => {
      if (!heroScrollCue) return;

      if (tier === 'full') {
        gsap.to(heroScrollCue, {
          y: 12,
          duration: 1.15,
          ease: 'sine.inOut',
          repeat: -1,
          yoyo: true,
        });
        return;
      }

      gsap.set(heroScrollCue, { clearProps: 'transform' });
    };

    const setupCoupleTimelines = (tier: 'lite' | 'full') => {
      const groups = Array.from(
        document.querySelectorAll<HTMLElement>('.couple-card-group'),
      );

      groups.forEach((group, index) => {
        const frame = group.querySelector(
          '.couple-card__image-frame',
        ) as HTMLElement | null;
        const image = group.querySelector(
          '.couple-card__image',
        ) as HTMLElement | null;
        const text = group.querySelector(
          '.couple-card__text',
        ) as HTMLElement | null;
        const textChildren = text
          ? Array.from(text.children).filter(
              (child): child is HTMLElement => child instanceof HTMLElement,
            )
          : [];

        const offsetX = tier === 'full' ? (index % 2 === 0 ? 52 : -52) : 28;

        if (frame) {
          gsap.set(frame, { autoAlpha: 0.18, x: offsetX });
        }
        if (image) {
          gsap.set(image, { scale: 1.06 });
        }
        if (textChildren.length > 0) {
          gsap.set(textChildren, {
            autoAlpha: 0,
            y: tier === 'full' ? 24 : 18,
          });
        }

        const timeline = gsap.timeline({
          paused: true,
          defaults: { ease: 'power3.out' },
          onComplete: () => group.classList.add('visible'),
        });

        if (frame) {
          timeline.to(frame, { autoAlpha: 1, x: 0, duration: 0.75 }, 0);
        }
        if (image) {
          timeline.to(image, { scale: 1, duration: 0.95 }, 0);
        }
        if (textChildren.length > 0) {
          timeline.to(
            textChildren,
            {
              autoAlpha: 1,
              y: 0,
              duration: tier === 'full' ? 0.55 : 0.45,
              stagger: 0.08,
            },
            tier === 'full' ? 0.18 : 0.08,
          );
        }

        ScrollTrigger.create({
          trigger: group,
          start: 'top 82%',
          once: true,
          onEnter: () => timeline.play(),
        });
      });
    };

    const setupDetailsTimeline = (tier: 'lite' | 'full') => {
      const composition = document.querySelector(
        '.details-composition',
      ) as HTMLElement | null;
      const intros = Array.from(
        document.querySelectorAll<HTMLElement>('.details-line__intro'),
      );
      const values = Array.from(
        document.querySelectorAll<HTMLElement>('.details-line__value'),
      );

      if (!composition) return;

      if (tier === 'lite') {
        createRevealTrigger(composition, [...intros, ...values], {
          y: 20,
          duration: 0.5,
          stagger: 0.08,
        });
        return;
      }

      gsap.set(intros, { autoAlpha: 0, y: 28 });
      gsap.set(values, { autoAlpha: 0, y: 38 });

      const timeline = gsap.timeline({
        paused: true,
        defaults: { ease: 'power3.out' },
        onComplete: () => composition.classList.add('visible'),
      });

      timeline
        .to(intros, {
          autoAlpha: 1,
          y: 0,
          duration: 0.6,
          stagger: 0.12,
        })
        .to(
          values,
          {
            autoAlpha: 1,
            y: 0,
            duration: 0.68,
            stagger: 0.14,
          },
          '-=0.38',
        );

      ScrollTrigger.create({
        trigger: composition,
        start: 'top 82%',
        once: true,
        onEnter: () => timeline.play(),
      });
    };

    const setupAccessTimeline = (tier: 'lite' | 'full') => {
      const composition = document.querySelector(
        '.access-composition',
      ) as HTMLElement | null;
      const labelBlock = document.querySelector(
        '.access-composition__label-block',
      ) as HTMLElement | null;
      const primaryTitleRow = document.querySelector(
        '.access-composition__title-row:not(.access-composition__title-row--live)',
      ) as HTMLElement | null;
      const liveTitleRow = document.querySelector(
        '.access-composition__title-row--live',
      ) as HTMLElement | null;
      const body = Array.from(
        document.querySelectorAll<HTMLElement>(
          '.access-composition__address, .access-composition__notes, .access-map',
        ),
      );

      if (!composition) return;

      const targets = [labelBlock, primaryTitleRow, ...body].filter(
        (element): element is HTMLElement => Boolean(element),
      );

      if (tier === 'lite') {
        createRevealTrigger(composition, targets, {
          y: 22,
          duration: 0.5,
          stagger: 0.08,
        });
        return;
      }

      if (labelBlock) {
        gsap.set(labelBlock, { autoAlpha: 0, y: 28 });
      }
      if (primaryTitleRow) {
        gsap.set(primaryTitleRow, { autoAlpha: 0, y: 34 });
      }
      if (liveTitleRow) {
        gsap.set(liveTitleRow, { autoAlpha: 0, y: 30 });
      }
      gsap.set(body, { autoAlpha: 0, y: 24 });

      const timeline = gsap.timeline({
        paused: true,
        defaults: { ease: 'power3.out' },
        onComplete: () => composition.classList.add('visible'),
      });

      if (labelBlock) {
        timeline.to(labelBlock, { autoAlpha: 1, y: 0, duration: 0.52 });
      }
      if (primaryTitleRow) {
        timeline.to(
          primaryTitleRow,
          { autoAlpha: 1, y: 0, duration: 0.68 },
          '-=0.18',
        );
      }
      if (body.length > 0) {
        timeline.to(
          body,
          {
            autoAlpha: 1,
            y: 0,
            duration: 0.55,
            stagger: 0.1,
          },
          '-=0.22',
        );
      }

      ScrollTrigger.create({
        trigger: composition,
        start: 'top 80%',
        once: true,
        onEnter: () => timeline.play(),
      });

      if (liveTitleRow) {
        createRevealTrigger(liveTitleRow, [liveTitleRow], {
          start: 'top 88%',
          y: tier === 'full' ? 26 : 16,
          duration: tier === 'full' ? 0.58 : 0.38,
          stagger: 0,
        });
      }
    };

    const setupWishTimeline = (tier: 'lite' | 'full') => {
      const wishSection = document.getElementById(
        'wishes',
      ) as HTMLElement | null;
      const wishScene = document.querySelector(
        '.wish-scene',
      ) as HTMLElement | null;
      const wishPanels = Array.from(
        document.querySelectorAll<HTMLElement>('.wish-panel'),
      );

      if (!wishSection || !wishScene || wishPanels.length === 0) return;

      if (tier === 'lite') {
        createRevealTrigger(wishSection, [wishScene, ...wishPanels], {
          y: 20,
          duration: 0.5,
          stagger: 0.08,
        });
        return;
      }

      gsap.set(wishScene, { autoAlpha: 0, y: 30 });
      gsap.set(wishPanels[0], { autoAlpha: 0, x: -24, y: 20 });
      if (wishPanels[1]) {
        gsap.set(wishPanels[1], { autoAlpha: 0, x: 24, y: 20 });
      }

      const timeline = gsap.timeline({
        paused: true,
        defaults: { ease: 'power3.out' },
      });

      timeline
        .to(wishScene, { autoAlpha: 1, y: 0, duration: 0.7 })
        .to(
          wishPanels,
          {
            autoAlpha: 1,
            x: 0,
            y: 0,
            duration: 0.62,
            stagger: 0.1,
          },
          '-=0.34',
        )
        .call(() => markVisible([wishScene, ...wishPanels]));

      ScrollTrigger.create({
        trigger: wishSection,
        start: 'top 82%',
        once: true,
        onEnter: () => timeline.play(),
      });
    };

    const setupSignatureMotion = (tier: 'lite' | 'full') => {
      createRevealTrigger(
        document.getElementById('greeting') as HTMLElement | null,
        Array.from(document.querySelectorAll<HTMLElement>('#greeting .reveal')),
        {
          y: tier === 'full' ? 28 : 18,
          duration: tier === 'full' ? 0.72 : 0.5,
        },
      );

      createRevealTrigger(
        document.getElementById('gallery') as HTMLElement | null,
        Array.from(document.querySelectorAll<HTMLElement>('#gallery .reveal')),
        {
          y: tier === 'full' ? 28 : 18,
          duration: tier === 'full' ? 0.66 : 0.5,
        },
      );

      createRevealTrigger(
        document.querySelector(
          '.story-background > section .reveal',
        ) as HTMLElement | null,
        Array.from(
          document.querySelectorAll<HTMLElement>(
            '.story-background > section .reveal',
          ),
        ),
        {
          y: tier === 'full' ? 26 : 16,
          duration: tier === 'full' ? 0.72 : 0.5,
        },
      );

      setupCoupleTimelines(tier);
      setupDetailsTimeline(tier);
      setupAccessTimeline(tier);
      setupWishTimeline(tier);

      createRevealTrigger(
        document.querySelector('.footer-shell') as HTMLElement | null,
        Array.from(document.querySelectorAll<HTMLElement>('.footer-shell')),
        { y: 18, duration: 0.5, stagger: 0 },
      );
    };

    const setupMagneticButton = (tier: 'lite' | 'full') => {
      const rsvpBtn = document.querySelector('.rsvp-btn') as HTMLElement | null;
      if (!rsvpBtn || tier !== 'full' || !finePointerMedia.matches) return;

      const moveX = gsap.quickTo(rsvpBtn, 'x', {
        duration: 0.24,
        ease: 'power3.out',
      });
      const moveY = gsap.quickTo(rsvpBtn, 'y', {
        duration: 0.24,
        ease: 'power3.out',
      });

      rsvpBtn.addEventListener('mousemove', (event: MouseEvent) => {
        const rect = rsvpBtn.getBoundingClientRect();
        const x = event.clientX - rect.left - rect.width / 2;
        const y = event.clientY - rect.top - rect.height / 2;
        moveX(x * 0.07);
        moveY(y * 0.06 - 2);
      });

      rsvpBtn.addEventListener('mouseleave', () => {
        moveX(0);
        moveY(0);
      });
    };

    const applyReducedMotionState = () => {
      heroSection?.classList.add('hero-section--loaded');
      showImmediately(revealElements);
      showImmediately(heroCats);
      syncNavState();
      window.addEventListener('scroll', syncNavState, { passive: true });
    };

    window.addEventListener(
      'intro-done',
      (event) => {
        const eventTier =
          event instanceof CustomEvent && typeof event.detail?.tier === 'string'
            ? (event.detail.tier as 'reduced' | 'lite' | 'full')
            : getMotionTier();

        if (eventTier === 'reduced') {
          applyReducedMotionState();
          return;
        }

        const heroRevealDistance = eventTier === 'full' ? 34 : 18;

        gsap.set(heroReveals, { autoAlpha: 0, y: heroRevealDistance });
        if (eventTier === 'full') {
          gsap.set(heroCats, {
            autoAlpha: 0,
            y: 16,
            scale: 0.92,
            filter: 'blur(8px)',
          });
        } else {
          gsap.set(heroCats, { autoAlpha: 1, y: 0, scale: 1, filter: 'none' });
        }

        const heroTimeline = gsap.timeline({
          defaults: { ease: 'power3.out' },
          onComplete: () => {
            markVisible(heroReveals);
            if (eventTier !== 'full') {
              markVisible(heroCats);
            }
            setupHeroScrollMotion(eventTier);
            setupHeroScrollCue(eventTier);
            setupSignatureMotion(eventTier);
            setupMagneticButton(eventTier);
            window.requestAnimationFrame(() => ScrollTrigger.refresh());
          },
        });

        heroTimeline.to(heroReveals, {
          autoAlpha: 1,
          y: 0,
          duration: eventTier === 'full' ? 0.75 : 0.52,
          stagger: eventTier === 'full' ? 0.12 : 0.08,
        });

        if (eventTier === 'full' && heroCats.length > 0) {
          heroTimeline.to(
            heroCats,
            {
              autoAlpha: 1,
              y: 0,
              scale: 1,
              filter: 'blur(0px)',
              duration: 0.72,
              stagger: 0.08,
            },
            '-=0.42',
          );
        }
      },
      { once: true },
    );

    const WEDDING_DATE = new Date('2026-05-02T09:00:00+07:00');
    const cdDays = document.getElementById('cd-days');
    const cdHours = document.getElementById('cd-hours');
    const cdMins = document.getElementById('cd-mins');
    const cdSecs = document.getElementById('cd-secs');
    let weddingPassed = false;

    function updateCountdown() {
      const now = new Date();
      const diff = WEDDING_DATE.getTime() - now.getTime();

      if (diff <= 0) {
        if (!weddingPassed) {
          weddingPassed = true;
        }
        if (cdDays) cdDays.textContent = '0';
        if (cdHours) cdHours.textContent = '0';
        if (cdMins) cdMins.textContent = '0';
        if (cdSecs) cdSecs.textContent = '0';
        return;
      }

      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
      const mins = Math.floor((diff / (1000 * 60)) % 60);
      const secs = Math.floor((diff / 1000) % 60);

      if (cdDays) cdDays.textContent = String(days);
      if (cdHours) cdHours.textContent = String(hours).padStart(2, '0');
      if (cdMins) cdMins.textContent = String(mins).padStart(2, '0');
      if (cdSecs) cdSecs.textContent = String(secs).padStart(2, '0');
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);

    const getActiveLanguage = () =>
      document.documentElement.getAttribute('data-lang') === 'en'
        ? 'en'
        : 'mix';

    const syncWishFieldPlaceholders = () => {
      const fields = document.querySelectorAll<
        HTMLInputElement | HTMLTextAreaElement
      >('[data-placeholder-mix][data-placeholder-en]');

      fields.forEach((field) => {
        field.placeholder =
          getActiveLanguage() === 'en'
            ? (field.dataset.placeholderEn ?? '')
            : (field.dataset.placeholderMix ?? '');
      });
    };

    const syncLanguageBlocks = () => {
      const activeLanguage = getActiveLanguage();
      const blocks =
        document.querySelectorAll<HTMLElement>('[data-lang-block]');

      blocks.forEach((block) => {
        block.hidden = block.dataset.langBlock !== activeLanguage;
      });
    };

    const langToggle = document.getElementById('lang-toggle');
    if (langToggle) {
      document.documentElement.setAttribute('data-lang', 'en');
      localStorage.setItem('wedding-lang', 'en');

      syncWishFieldPlaceholders();
      syncLanguageBlocks();

      langToggle.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-lang');
        const next = current === 'en' ? 'mix' : 'en';
        if (next === 'en') {
          document.documentElement.setAttribute('data-lang', 'en');
        } else {
          document.documentElement.removeAttribute('data-lang');
        }
        localStorage.setItem('wedding-lang', next);
        syncWishFieldPlaceholders();
        syncLanguageBlocks();
      });
    }

    const wishForm = document.getElementById(
      'wish-form',
    ) as HTMLFormElement | null;
    const wishList = document.getElementById('wish-list') as HTMLElement | null;
    const wishStage = document.getElementById(
      'wish-stage',
    ) as HTMLElement | null;
    const wishEmpty = document.getElementById(
      'wish-empty',
    ) as HTMLElement | null;
    const wishStatus = document.getElementById(
      'wish-status',
    ) as HTMLElement | null;
    const wishPrev = document.getElementById(
      'wish-prev',
    ) as HTMLButtonElement | null;
    const wishNext = document.getElementById(
      'wish-next',
    ) as HTMLButtonElement | null;
    const wishCardTemplate = document.getElementById(
      'wish-card-template',
    ) as HTMLTemplateElement | null;
    const wishSubmit = wishForm?.querySelector(
      '.wish-submit',
    ) as HTMLButtonElement | null;
    let wishDeckTween: gsap.core.Tween | null = null;
    let wishAutoAdvanceTimer: number | null = null;

    const wishMessages = {
      mix: {
        validation: 'Mohon isi nama dan ucapan terlebih dahulu.',
        pending: 'Ucapan Anda sedang kami kirim...',
        success: 'Terima kasih. Ucapan Anda kini hadir di buku ucapan kami.',
        error: 'Maaf, ucapan belum bisa dikirim sekarang.',
      },
      en: {
        validation: 'Please enter your name and message first.',
        pending: 'Sending your wish...',
        success: 'Thank you. Your note now lives in our guestbook.',
        error: 'Sorry, your wish could not be sent right now.',
      },
    } as const;

    const setWishStatus = (state: 'idle' | 'pending' | 'success' | 'error') => {
      if (!wishStatus) return;

      if (state === 'idle') {
        gsap.killTweensOf(wishStatus);
        wishStatus.textContent = '';
        wishStatus.classList.add('hidden');
        wishStatus.removeAttribute('data-state');
        gsap.set(wishStatus, { clearProps: 'all' });
        return;
      }

      wishStatus.dataset.state = state;
      wishStatus.textContent = wishMessages[getActiveLanguage()][state];
      wishStatus.classList.remove('hidden');

      gsap.killTweensOf(wishStatus);
      gsap.fromTo(
        wishStatus,
        {
          autoAlpha: 0,
          y: state === 'success' ? 18 : 10,
          scale: state === 'success' ? 0.985 : 0.995,
        },
        {
          autoAlpha: 1,
          y: 0,
          scale: 1,
          duration: state === 'success' ? 0.46 : 0.26,
          ease: state === 'success' ? 'power3.out' : 'power2.out',
          overwrite: 'auto',
        },
      );
    };

    const getWishCards = () =>
      wishList
        ? Array.from(wishList.querySelectorAll<HTMLElement>('[data-wish-id]'))
        : [];

    const applyWishCardStates = (
      cards: HTMLElement[],
      motionTier: 'reduced' | 'lite' | 'full',
    ) => {
      cards.forEach((card, index) => {
        card.setAttribute('aria-hidden', index === 0 ? 'false' : 'true');
      });

      if (motionTier === 'reduced') {
        gsap.set(cards, {
          scale: (index: number) => (index === 0 ? 1 : 0.965),
          opacity: (index: number) => (index === 0 ? 1 : 0.68),
        });
        return;
      }

      gsap.to(cards, {
        scale: (index: number) => (index === 0 ? 1 : 0.965),
        opacity: (index: number) => (index === 0 ? 1 : 0.68),
        duration: motionTier === 'full' ? 0.26 : 0.18,
        ease: 'power2.out',
        overwrite: 'auto',
      });
    };

    const getWishStep = (cards: HTMLElement[]) => {
      if (cards.length < 2) {
        return cards[0]?.getBoundingClientRect().width ?? 0;
      }

      return cards[1].offsetLeft - cards[0].offsetLeft;
    };

    const syncWishDeck = () => {
      if (!wishList) return;

      const cards = getWishCards();
      const total = cards.length;
      const motionTier = getMotionTier();

      if (wishEmpty) {
        wishEmpty.classList.toggle('hidden', total > 0);
      }

      if (total === 0) {
        wishDeckTween?.kill();
        gsap.set(wishList, { x: 0 });
        wishList.classList.add('wish-list--solo');
        if (wishPrev) wishPrev.disabled = true;
        if (wishNext) wishNext.disabled = true;
        return;
      }

      wishList.classList.toggle('wish-list--solo', total === 1);

      wishDeckTween?.kill();
      gsap.set(wishList, { x: 0 });
      applyWishCardStates(cards, motionTier);

      const canCycle = total > 1;
      if (wishPrev) wishPrev.disabled = !canCycle;
      if (wishNext) wishNext.disabled = !canCycle;
    };

    const rotateWishDeck = (
      direction: -1 | 1,
      options?: { restartAuto?: boolean },
    ) => {
      if (!wishList) return;

      const total = getWishCards().length;
      if (total < 2) {
        if (options?.restartAuto) startWishAutoAdvance();
        return;
      }

      const motionTier = getMotionTier();
      const immediate = motionTier === 'reduced';

      wishDeckTween?.kill();

      if (direction === 1) {
        const cards = getWishCards();
        const firstCard = cards[0];
        const step = getWishStep(cards);

        if (!firstCard || step === 0) {
          wishList.appendChild(firstCard);
          syncWishDeck();
          if (options?.restartAuto) startWishAutoAdvance();
          return;
        }

        if (immediate) {
          wishList.appendChild(firstCard);
          syncWishDeck();
          if (options?.restartAuto) startWishAutoAdvance();
          return;
        }

        wishDeckTween = gsap.to(wishList, {
          x: -step,
          duration: motionTier === 'full' ? 0.34 : 0.22,
          ease: motionTier === 'full' ? 'power3.inOut' : 'power2.out',
          overwrite: 'auto',
          onComplete: () => {
            wishList.appendChild(firstCard);
            gsap.set(wishList, { x: 0 });
            syncWishDeck();
            if (options?.restartAuto) startWishAutoAdvance();
          },
        });
        return;
      }

      const lastCard = getWishCards().at(-1);
      if (!lastCard) {
        if (options?.restartAuto) startWishAutoAdvance();
        return;
      }

      wishList.insertBefore(lastCard, wishList.firstChild);
      const cardsAfterPrepend = getWishCards();
      const step = getWishStep(cardsAfterPrepend);

      if (immediate || step === 0) {
        gsap.set(wishList, { x: 0 });
        syncWishDeck();
        if (options?.restartAuto) startWishAutoAdvance();
        return;
      }

      gsap.set(wishList, { x: -step });
      wishDeckTween = gsap.to(wishList, {
        x: 0,
        duration: motionTier === 'full' ? 0.34 : 0.22,
        ease: motionTier === 'full' ? 'power3.inOut' : 'power2.out',
        overwrite: 'auto',
        onComplete: () => {
          syncWishDeck();
          if (options?.restartAuto) startWishAutoAdvance();
        },
      });
    };

    const formatWishCardDate = (timestamp: number, language: 'mix' | 'en') =>
      new Intl.DateTimeFormat(language === 'en' ? 'en-US' : 'id-ID', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      }).format(new Date(timestamp));

    const createWishCard = (wish: {
      id: string;
      name: string;
      message: string;
      createdAt: number;
    }) => {
      const card =
        wishCardTemplate?.content.firstElementChild?.cloneNode(true) ??
        document.createElement('article');

      if (!(card instanceof HTMLElement)) {
        throw new Error('Failed to create wedding wish card');
      }

      card.dataset.wishId = wish.id;

      const name = card.querySelector('.wish-card__name');
      const dateMix = card.querySelector('.wish-card__date .lang-mix');
      const dateEn = card.querySelector('.wish-card__date .lang-en');
      const message = card.querySelector('.wish-card__message');

      if (name) name.textContent = wish.name;
      if (dateMix) {
        dateMix.textContent = formatWishCardDate(Number(wish.createdAt), 'mix');
      }
      if (dateEn) {
        dateEn.textContent = formatWishCardDate(Number(wish.createdAt), 'en');
      }
      if (message) message.textContent = wish.message;

      return card;
    };

    const animateInsertedWishCard = (card: HTMLElement) => {
      const motionTier = getMotionTier();
      if (motionTier === 'reduced') return;

      gsap.fromTo(
        card,
        {
          autoAlpha: 0,
          y: motionTier === 'full' ? 18 : 10,
          scale: motionTier === 'full' ? 0.985 : 0.992,
        },
        {
          autoAlpha: 1,
          y: 0,
          scale: 1,
          duration: motionTier === 'full' ? 0.42 : 0.24,
          ease: 'power3.out',
          overwrite: 'auto',
        },
      );
    };

    const animateWishSubmitRelease = () => {
      if (!wishSubmit || getMotionTier() === 'reduced') return;

      gsap.fromTo(
        wishSubmit,
        {
          scale: 0.985,
          y: 1,
        },
        {
          scale: 1,
          y: 0,
          duration: 0.28,
          ease: 'power3.out',
          overwrite: 'auto',
        },
      );
    };

    const stopWishAutoAdvance = () => {
      if (wishAutoAdvanceTimer === null) return;
      window.clearTimeout(wishAutoAdvanceTimer);
      wishAutoAdvanceTimer = null;
    };

    const startWishAutoAdvance = () => {
      if (!wishList) return;

      stopWishAutoAdvance();

      const total = getWishCards().length;
      if (total < 2 || getMotionTier() === 'reduced') return;

      wishAutoAdvanceTimer = window.setTimeout(() => {
        rotateWishDeck(1, { restartAuto: true });
      }, 4200);
    };

    const isWishSubmissionPayload = (
      value: unknown,
    ): value is {
      wish: {
        id: string;
        name: string;
        message: string;
        createdAt: number;
      };
    } => {
      if (!value || typeof value !== 'object') return false;

      const maybeWish = (value as { wish?: unknown }).wish;
      if (!maybeWish || typeof maybeWish !== 'object') return false;

      const wish = maybeWish as Record<string, unknown>;
      return (
        typeof wish.id === 'string' &&
        typeof wish.name === 'string' &&
        typeof wish.message === 'string' &&
        typeof wish.createdAt === 'number'
      );
    };

    if (wishForm && wishList && wishSubmit) {
      syncWishDeck();

      const moveWishDeck = (direction: -1 | 1) => {
        const total = getWishCards().length;
        if (total < 2) return;
        stopWishAutoAdvance();
        rotateWishDeck(direction, { restartAuto: true });
      };

      wishPrev?.addEventListener('click', () => moveWishDeck(-1));
      wishNext?.addEventListener('click', () => moveWishDeck(1));

      let touchStartX = 0;
      let touchStartY = 0;

      wishStage?.addEventListener(
        'touchstart',
        (event) => {
          const touch = event.changedTouches[0];
          touchStartX = touch.clientX;
          touchStartY = touch.clientY;
        },
        { passive: true },
      );

      wishStage?.addEventListener(
        'touchend',
        (event) => {
          const total = getWishCards().length;
          if (total < 2) return;

          const touch = event.changedTouches[0];
          const deltaX = touch.clientX - touchStartX;
          const deltaY = touch.clientY - touchStartY;

          if (Math.abs(deltaX) < 40 || Math.abs(deltaX) <= Math.abs(deltaY)) {
            return;
          }

          moveWishDeck(deltaX < 0 ? 1 : -1);
        },
        { passive: true },
      );

      window.addEventListener('resize', syncWishDeck);
      window.addEventListener('resize', startWishAutoAdvance);

      if (wishStage) {
        wishStage.addEventListener('mouseenter', stopWishAutoAdvance);
        wishStage.addEventListener('mouseleave', startWishAutoAdvance);
      }

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          stopWishAutoAdvance();
          return;
        }

        startWishAutoAdvance();
      });

      startWishAutoAdvance();

      wishForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        setWishStatus('idle');
        stopWishAutoAdvance();

        const formData = new FormData(wishForm);
        const name = String(formData.get('name') ?? '').trim();
        const message = String(formData.get('message') ?? '').trim();

        if (!name || !message) {
          setWishStatus('error');
          if (wishStatus) {
            wishStatus.textContent =
              wishMessages[getActiveLanguage()].validation;
          }
          return;
        }

        wishSubmit.disabled = true;
        wishSubmit.setAttribute('aria-busy', 'true');
        setWishStatus('pending');

        try {
          const response = await fetch(wishForm.action, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
            },
            body: JSON.stringify({ name, message }),
          });

          const payload: unknown = await response.json().catch(() => null);

          if (!response.ok || !isWishSubmissionPayload(payload)) {
            throw new Error('Guestbook submission failed');
          }

          const insertedCard = createWishCard(payload.wish);
          wishEmpty?.classList.add('hidden');
          wishList.insertAdjacentElement('afterbegin', insertedCard);
          syncWishDeck();
          wishForm.reset();
          syncWishFieldPlaceholders();
          setWishStatus('success');
          animateInsertedWishCard(insertedCard);
        } catch (error) {
          console.error('Failed to submit wedding wish', error);
          setWishStatus('error');
        } finally {
          wishSubmit.disabled = false;
          wishSubmit.removeAttribute('aria-busy');
          animateWishSubmitRelease();
          startWishAutoAdvance();
        }
      });
    }
  </script>
</Layout>
