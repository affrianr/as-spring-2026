---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You | Y & M Wedding">
  <div class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-lg">
      <div
        class="w-16 h-16 rounded-full bg-lime/20 flex items-center justify-center mx-auto mb-8"
      >
        <svg
          class="w-8 h-8 text-charcoal"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
          ></path>
        </svg>
      </div>

      <h1 class="font-display text-4xl md:text-5xl mb-6">Thank You</h1>
      <p class="font-serif text-lg mb-4">Terima kasih atas konfirmasi Anda</p>

      <p class="text-sm text-muted leading-relaxed mb-12">
        Terima kasih telah meluangkan waktu untuk mengisi RSVP.<br />
        Kami menantikan kehadiran Anda di hari istimewa kami.
      </p>

      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm tracking-widest uppercase text-muted hover:text-charcoal transition-colors"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        <span>Back to invitation</span>
      </a>
    </div>
  </div>
</Layout>
