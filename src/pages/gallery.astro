---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Gallery | A & S Wedding">
  <nav
    data-auto-scroll-header
    class="fixed top-0 left-0 right-0 z-50 gallery-nav transition-all duration-500"
  >
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <a
        href="/"
        class="group flex items-center gap-2 text-white/70 hover:text-white transition-colors duration-300"
      >
        <svg
          class="w-4 h-4 transition-transform duration-300 group-hover:-translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        <span class="text-xs tracking-widest uppercase">Back</span>
      </a>
      <span
        class="font-display text-sm tracking-widest uppercase text-white drop-shadow-sm"
        >Gallery</span
      >
    </div>
  </nav>

  <section
    class="relative min-h-screen flex items-center justify-center overflow-hidden px-6"
  >
    <div class="absolute inset-0">
      <img
        src="/assets/p1.webp"
        alt=""
        class="h-full w-full object-cover object-center"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-charcoal/65"></div>
    </div>

    <div class="relative z-10 w-full max-w-2xl text-center text-white">
      <p class="text-xs tracking-[0.32em] uppercase text-white/60 mb-6">
        A &amp; S
      </p>
      <h1 class="font-display text-5xl md:text-7xl drop-shadow-lg mb-4">
        Coming Soon
      </h1>
      <p
        class="text-sm md:text-base text-white/70 leading-relaxed max-w-xl mx-auto"
      >
        <span class="lang-mix"
          >Galeri foto sedang kami siapkan dan akan hadir setelah hari istimewa
          kami.</span
        >
        <span class="lang-en"
          >Our photo gallery is being prepared and will be available after our
          special day.</span
        >
      </p>

      <div
        class="mt-10 inline-flex items-center rounded-full border border-white/20 bg-white/8 px-5 py-2.5"
      >
        <span class="text-[10px] tracking-[0.3em] uppercase text-white/70">
          <span class="lang-mix">Segera diperbarui</span>
          <span class="lang-en">Updated soon</span>
        </span>
      </div>

      <div class="mt-12">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-xs tracking-widest uppercase text-white/70 hover:text-white transition-colors border border-white/20 hover:border-white/40 rounded-full px-6 py-3"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Back to invitation
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .gallery-nav {
    background: rgba(26, 26, 26, 0.35);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
</style>
