---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Wedding Invitation | 2026.05.02',
  description = 'Dengan penuh sukacita kami mengundang Anda ke hari pernikahan kami',
} = Astro.props;
---

<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style>
      /* ── Cover page ── */
      #page-cover {
        position: fixed;
        inset: 0;
        z-index: 100000;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: linear-gradient(
          160deg,
          #f5f6ef 0%,
          #eef2e4 40%,
          #e8edda 100%
        );
        color: #1a1a1a;
        text-align: center;
        cursor: default;
      }
      .cover__greeting {
        font-size: clamp(0.75rem, 2vw, 0.9rem);
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: rgba(26, 26, 26, 0.4);
        margin-bottom: 0.75rem;
      }
      .cover__guest {
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.8rem, 5.5vw, 3rem);
        font-style: italic;
        font-weight: 400;
        line-height: 1.2;
        color: rgba(26, 26, 26, 0.85);
        margin-bottom: 1rem;
      }
      .cover__subtitle {
        font-size: clamp(0.875rem, 2.2vw, 1.1rem);
        line-height: 1.5;
        color: rgba(26, 26, 26, 0.6);
        margin-bottom: 2.5rem;
        max-width: 20rem;
      }
      .cover__open {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 2rem;
        border: 1px solid rgba(26, 26, 26, 0.15);
        border-radius: 9999px;
        background: transparent;
        color: rgba(26, 26, 26, 0.6);
        font-size: 0.75rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.3s ease;
      }
      .cover__open:hover {
        border-color: rgba(26, 26, 26, 0.4);
        color: rgba(26, 26, 26, 0.9);
        transform: translateY(-2px);
      }
      .cover__open svg {
        width: 1rem;
        height: 1rem;
        transition: transform 0.3s ease;
      }
      .cover__open:hover svg {
        transform: translateX(2px);
      }
      /* Cover exit animations */
      .cover--exiting {
        pointer-events: none;
      }
      .cover--exiting .cover__greeting,
      .cover--exiting .cover__guest,
      .cover--exiting .cover__subtitle {
        animation: cover-text-up 0.5s cubic-bezier(0.76, 0, 0.24, 1) forwards;
      }
      .cover--exiting .cover__guest {
        animation-delay: 0.06s;
      }
      .cover--exiting .cover__subtitle {
        animation-delay: 0.12s;
      }
      .cover--exiting .cover__open {
        animation: cover-btn-out 0.4s cubic-bezier(0.76, 0, 0.24, 1) forwards;
      }
      .cover--exiting {
        animation: cover-bg-fade 0.5s cubic-bezier(0.76, 0, 0.24, 1) 0.3s
          forwards;
      }
      @keyframes cover-text-up {
        0% {
          opacity: 1;
          transform: translateY(0);
        }
        100% {
          opacity: 0;
          transform: translateY(-2rem);
        }
      }
      @keyframes cover-btn-out {
        0% {
          opacity: 1;
          transform: scale(1);
        }
        100% {
          opacity: 0;
          transform: scale(0.9);
        }
      }
      @keyframes cover-bg-fade {
        0% {
          opacity: 1;
        }
        100% {
          opacity: 0;
        }
      }

      /* ── Intro panels (behind cover, revealed after cover exits) ── */
      #page-intro {
        position: fixed;
        inset: 0;
        z-index: 99999;
        overflow: hidden;
        pointer-events: none;
      }
      .page-intro__panel {
        position: absolute;
        top: 0;
        bottom: 0;
        width: 51%;
        background: #eef2e4;
      }
      .page-intro__panel--left {
        left: 0;
      }
      .page-intro__panel--right {
        right: 0;
      }
      .page-intro__panel--exit-left {
        animation: intro-panel-left 1s cubic-bezier(0.76, 0, 0.24, 1) forwards;
      }
      .page-intro__panel--exit-right {
        animation: intro-panel-right 1s cubic-bezier(0.76, 0, 0.24, 1) forwards;
        animation-delay: 0.06s;
      }
      @keyframes intro-panel-left {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-102%);
        }
      }
      @keyframes intro-panel-right {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(102%);
        }
      }
    </style>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Noto+Sans+JP:wght@300;400;500&family=Noto+Serif+JP:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen overflow-hidden">
    <audio
      id="bg-music"
      src="/music/love-wins-all-classic.mp3"
      preload="auto"
      loop
      playsinline></audio>

    <!-- Cover page — user must click to enter -->
    <div id="page-cover">
      <p class="cover__greeting">With joy & love</p>
      <p class="cover__guest" id="cover-guest-name">Guest</p>
      <p class="cover__subtitle">We invite you to celebrate our special day</p>
      <button id="cover-open" class="cover__open" type="button">
        <span>Open Invitation</span>
        <svg
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
        </svg>
      </button>
    </div>

    <!-- Intro panels (slide open after cover exits) -->
    <div id="page-intro" aria-hidden="true">
      <div class="page-intro__panel page-intro__panel--left"></div>
      <div class="page-intro__panel page-intro__panel--right"></div>
    </div>
    <slot />

    <script>
      // ── Cover: read guest name from ?to= query param ──
      const pageCover = document.getElementById('page-cover');
      const guestEl = document.getElementById('cover-guest-name');
      const openBtn = document.getElementById('cover-open');
      const COVER_DISMISSED_KEY = 'wedding-cover-dismissed';
      const GUEST_NAME_KEY = 'wedding-guest-name';
      const MUTE_PREF_KEY = 'wedding-music-muted';
      const bgMusic = document.getElementById(
        'bg-music',
      ) as HTMLAudioElement | null;
      const musicToggle = document.getElementById(
        'music-toggle',
      ) as HTMLButtonElement | null;

      const syncMuteUi = () => {
        if (!bgMusic || !musicToggle) return;
        const isMuted = bgMusic.muted;
        musicToggle.dataset.state = isMuted ? 'muted' : 'playing';
        musicToggle.setAttribute('aria-label', isMuted ? 'Unmute' : 'Mute');
      };

      const startBackgroundMusic = () => {
        if (!bgMusic) return;
        bgMusic.volume = 0.42;
        bgMusic.play().catch(() => {});
        window.dispatchEvent(new CustomEvent('music-started'));
        syncMuteUi();
      };

      if (bgMusic) {
        bgMusic.muted = window.localStorage.getItem(MUTE_PREF_KEY) === 'true';
      }

      if (musicToggle && bgMusic) {
        syncMuteUi();
        musicToggle.addEventListener('click', () => {
          bgMusic.muted = !bgMusic.muted;
          window.localStorage.setItem(MUTE_PREF_KEY, String(bgMusic.muted));
          syncMuteUi();
        });
      }

      const params = new URLSearchParams(window.location.search);
      const guestName = params.get('to');
      let persistedGuestName = guestName?.trim() ?? '';

      if (!persistedGuestName) {
        try {
          persistedGuestName =
            window.sessionStorage.getItem(GUEST_NAME_KEY)?.trim() ?? '';
        } catch {}
      } else {
        try {
          window.sessionStorage.setItem(GUEST_NAME_KEY, persistedGuestName);
        } catch {}
      }

      if (guestEl && persistedGuestName) {
        guestEl.textContent = decodeURIComponent(persistedGuestName);
      }

      if (persistedGuestName && !guestName) {
        const nextUrl = new URL(window.location.href);
        nextUrl.searchParams.set('to', persistedGuestName);
        window.history.replaceState({}, '', nextUrl);
      }

      if (persistedGuestName) {
        document
          .querySelectorAll<HTMLAnchorElement>('a[href]')
          .forEach((anchor) => {
            const href = anchor.getAttribute('href');
            if (
              !href ||
              href.startsWith('#') ||
              href.startsWith('mailto:') ||
              href.startsWith('tel:') ||
              href.startsWith('javascript:')
            ) {
              return;
            }

            const targetUrl = new URL(href, window.location.origin);
            if (targetUrl.origin !== window.location.origin) return;

            targetUrl.searchParams.set('to', persistedGuestName);
            anchor.href =
              targetUrl.pathname + targetUrl.search + targetUrl.hash;
          });
      }

      // ── Intro panels ──
      const panelLeft = document.querySelector(
        '.page-intro__panel--left',
      ) as HTMLElement | null;
      const panelRight = document.querySelector(
        '.page-intro__panel--right',
      ) as HTMLElement | null;
      const pageIntro = document.getElementById('page-intro');
      const heroSection = document.getElementById('home');

      const finishEntryWithoutCover = () => {
        pageCover?.remove();
        pageIntro?.remove();
        document.body.classList.remove('overflow-hidden');
        heroSection?.classList.add('hero-section--loaded');
        startBackgroundMusic();

        window.setTimeout(() => {
          window.dispatchEvent(new CustomEvent('intro-done'));
        }, 0);
      };

      const runIntro = () => {
        // slide panels open
        window.setTimeout(() => {
          panelLeft?.classList.add('page-intro__panel--exit-left');
          panelRight?.classList.add('page-intro__panel--exit-right');

          // panels halfway → trigger hero bg → mountain → couple
          window.setTimeout(() => {
            heroSection?.classList.add('hero-section--loaded');
          }, 400);

          // after scene elements done → trigger text reveals
          window.setTimeout(() => {
            window.dispatchEvent(new CustomEvent('intro-done'));
          }, 2200);

          // remove overlay
          window.setTimeout(() => pageIntro?.remove(), 1200);
        }, 300);
      };

      let hasDismissedCover = false;
      try {
        hasDismissedCover =
          window.sessionStorage.getItem(COVER_DISMISSED_KEY) === 'true';
      } catch {}

      if (hasDismissedCover) {
        finishEntryWithoutCover();
      }

      // ── Open button: start music → fade cover → run intro ──
      openBtn?.addEventListener('click', () => {
        try {
          window.sessionStorage.setItem(COVER_DISMISSED_KEY, 'true');
        } catch {}

        startBackgroundMusic();

        // animate cover out
        pageCover?.classList.add('cover--exiting');
        window.setTimeout(() => {
          pageCover?.remove();
          // unlock scroll
          document.body.classList.remove('overflow-hidden');
          // run the panel intro sequence
          runIntro();
        }, 800);
      });

      const prefersReducedMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)',
      );
      const sections = Array.from(
        document.querySelectorAll<HTMLElement>('[data-auto-scroll-section]'),
      );

      if (sections.length > 1) {
        const AUTO_SNAP_ENABLED = !prefersReducedMotion.matches;
        const SNAP_THRESHOLD = 0.35;
        const SNAP_LOCK_MS = 700;

        let currentSnapIndex = 0;
        let isAutoScrolling = false;

        const getHeaderOffset = () => {
          const header = document.querySelector<HTMLElement>(
            '[data-auto-scroll-header]',
          );
          return header ? header.getBoundingClientRect().height : 0;
        };

        const getSectionTop = (section: HTMLElement) =>
          window.scrollY + section.getBoundingClientRect().top;

        const getTargetTop = (section: HTMLElement) => {
          const headerOffset = getHeaderOffset();
          const sectionTop = getSectionTop(section);
          const visibleHeight = window.innerHeight - headerOffset;
          const sectionHeight = section.getBoundingClientRect().height;
          const isDesktopViewport = window.innerWidth >= 1024;
          const shouldAlignStart =
            isDesktopViewport ||
            section.dataset.autoScrollAlign === 'start' ||
            section.hasAttribute('data-auto-scroll-no-center');

          if (!shouldAlignStart && sectionHeight < visibleHeight) {
            const centeredTop =
              sectionTop - headerOffset - (visibleHeight - sectionHeight) / 2;
            return Math.max(0, centeredTop);
          }

          return Math.max(0, sectionTop - headerOffset);
        };

        const getSnapIndex = () => {
          const anchorY =
            window.scrollY +
            getHeaderOffset() +
            window.innerHeight * SNAP_THRESHOLD;

          let index = 0;
          sections.forEach((section, sectionIndex) => {
            if (getSectionTop(section) <= anchorY) {
              index = sectionIndex;
            }
          });

          return index;
        };

        const syncCurrentIndex = () => {
          currentSnapIndex = getSnapIndex();
        };

        const snapToIndex = (nextIndex: number) => {
          const section = sections[nextIndex];
          if (!section) return;

          isAutoScrolling = true;
          currentSnapIndex = nextIndex;

          window.scrollTo({
            top: getTargetTop(section),
            behavior: AUTO_SNAP_ENABLED ? 'smooth' : 'auto',
          });

          window.setTimeout(() => {
            isAutoScrolling = false;
            syncCurrentIndex();
          }, SNAP_LOCK_MS);
        };

        const resolveTriggerIndex = (trigger: HTMLElement) => {
          const currentSection = trigger.closest<HTMLElement>(
            '[data-auto-scroll-section]',
          );
          const sectionIndex = currentSection
            ? sections.indexOf(currentSection)
            : currentSnapIndex;
          return sectionIndex >= 0 ? sectionIndex : currentSnapIndex;
        };

        const bindDirectionalTriggers = (
          selector: string,
          direction: -1 | 1,
        ) => {
          const triggers = document.querySelectorAll<HTMLElement>(selector);

          triggers.forEach((trigger) => {
            trigger.addEventListener('click', () => {
              if (isAutoScrolling) return;

              const currentIndex = resolveTriggerIndex(trigger);
              const targetIndex = Math.max(
                0,
                Math.min(sections.length - 1, currentIndex + direction),
              );

              if (targetIndex !== currentIndex) {
                snapToIndex(targetIndex);
              }
            });
          });
        };

        bindDirectionalTriggers('[data-auto-scroll-prev]', -1);
        bindDirectionalTriggers('[data-auto-scroll-next]', 1);

        const handleScroll = () => {
          syncCurrentIndex();
        };

        window.addEventListener('load', syncCurrentIndex);
        window.addEventListener('resize', syncCurrentIndex);
        window.addEventListener('hashchange', syncCurrentIndex);
        window.addEventListener('scroll', handleScroll, { passive: true });

        syncCurrentIndex();
      }
    </script>
  </body>
</html>
