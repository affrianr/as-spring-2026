---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Wedding Invitation | 2026.05.02",
  description = "Dengan penuh sukacita kami mengundang Anda ke hari pernikahan kami"
} = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Noto+Sans+JP:wght@300;400;500&family=Noto+Serif+JP:wght@400;600&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen">
    <slot />

    <div id="section-nav-helper" class="section-nav-helper" hidden>
      <button
        id="section-nav-prev"
        type="button"
        class="section-nav-helper__button"
        data-auto-scroll-prev
        aria-label="Scroll to previous section"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
        </svg>
      </button>
      <button
        id="section-nav-next"
        type="button"
        class="section-nav-helper__button"
        data-auto-scroll-next
        aria-label="Scroll to next section"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
    </div>

    <style>
      .section-nav-helper {
        position: fixed;
        right: max(1rem, calc(env(safe-area-inset-right) + 1rem));
        bottom: max(1rem, calc(env(safe-area-inset-bottom) + 1rem));
        z-index: 60;
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
        opacity: 0;
        transform: translateY(12px);
        transition: opacity 0.35s ease,
                    transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .section-nav-helper.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      .section-nav-helper__button {
        width: 2.75rem;
        height: 2.75rem;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 999px;
        background: linear-gradient(
          180deg,
          rgba(250, 249, 246, 0.4),
          rgba(250, 249, 246, 0.18)
        );
        color: rgba(26, 26, 26, 0.72);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(18px) saturate(130%);
        -webkit-backdrop-filter: blur(18px) saturate(130%);
        box-shadow: 0 12px 30px rgba(26, 26, 26, 0.14);
        opacity: 0.72;
        transition: opacity 0.25s ease,
                    transform 0.25s cubic-bezier(0.16, 1, 0.3, 1),
                    border-color 0.25s ease,
                    box-shadow 0.25s ease,
                    background 0.25s ease;
      }

      .section-nav-helper__button:hover {
        opacity: 0.94;
        transform: translateY(-2px);
        border-color: rgba(255, 255, 255, 0.32);
        box-shadow: 0 16px 34px rgba(26, 26, 26, 0.18);
      }

      .section-nav-helper__button:active {
        opacity: 0.88;
        transform: translateY(0);
      }

      .section-nav-helper__button:focus-visible {
        outline: 2px solid rgba(225, 255, 0, 0.6);
        outline-offset: 3px;
      }

      .section-nav-helper__button:disabled {
        opacity: 0.22;
        transform: none;
        cursor: default;
        box-shadow: none;
      }

      .section-nav-helper__button svg {
        width: 1rem;
        height: 1rem;
      }

      @media (max-width: 640px) {
        .section-nav-helper {
          right: max(0.75rem, calc(env(safe-area-inset-right) + 0.75rem));
          bottom: max(0.875rem, calc(env(safe-area-inset-bottom) + 0.875rem));
          gap: 0.5rem;
        }

        .section-nav-helper__button {
          width: 2.5rem;
          height: 2.5rem;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .section-nav-helper,
        .section-nav-helper__button {
          transition: none;
        }
      }
    </style>

    <script>
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      const sections = Array.from(
        document.querySelectorAll<HTMLElement>('[data-auto-scroll-section]')
      );

      if (sections.length > 1) {
        const AUTO_SNAP_ENABLED = !prefersReducedMotion.matches;
        const SNAP_THRESHOLD = 0.35;
        const SNAP_SETTLE_DELAY = 90;
        const SNAP_LOCK_MS = 700;

        let currentSnapIndex = 0;
        let isAutoScrolling = false;
        let scrollEndTimer: number | undefined;

        const helper = document.getElementById('section-nav-helper');
        const helperPrev = document.getElementById('section-nav-prev') as HTMLButtonElement | null;
        const helperNext = document.getElementById('section-nav-next') as HTMLButtonElement | null;

        const getHeaderOffset = () => {
          const header = document.querySelector<HTMLElement>('[data-auto-scroll-header]');
          return header ? header.getBoundingClientRect().height : 0;
        };

        const getSectionTop = (section: HTMLElement) =>
          window.scrollY + section.getBoundingClientRect().top;

        const getTargetTop = (section: HTMLElement) => {
          const headerOffset = getHeaderOffset();
          const sectionTop = getSectionTop(section);
          const visibleHeight = window.innerHeight - headerOffset;
          const sectionHeight = section.getBoundingClientRect().height;

          if (sectionHeight < visibleHeight) {
            const centeredTop =
              sectionTop - headerOffset - (visibleHeight - sectionHeight) / 2;
            return Math.max(0, centeredTop);
          }

          return Math.max(0, sectionTop - headerOffset);
        };

        const getSnapIndex = () => {
          const anchorY =
            window.scrollY + getHeaderOffset() + window.innerHeight * SNAP_THRESHOLD;

          let index = 0;
          sections.forEach((section, sectionIndex) => {
            if (getSectionTop(section) <= anchorY) {
              index = sectionIndex;
            }
          });

          return index;
        };

        const updateHelperState = () => {
          if (helper) {
            const shouldShowHelper = currentSnapIndex > 0;
            helper.hidden = !shouldShowHelper;
            helper.classList.toggle('is-visible', shouldShowHelper);
          }

          if (helperPrev) {
            helperPrev.disabled = currentSnapIndex <= 0;
          }

          if (helperNext) {
            helperNext.disabled = currentSnapIndex >= sections.length - 1;
          }
        };

        const syncCurrentIndex = () => {
          currentSnapIndex = getSnapIndex();
          updateHelperState();
        };

        const snapToIndex = (nextIndex: number) => {
          const section = sections[nextIndex];
          if (!section) return;

          isAutoScrolling = true;
          currentSnapIndex = nextIndex;
          updateHelperState();

          window.scrollTo({
            top: getTargetTop(section),
            behavior: AUTO_SNAP_ENABLED ? 'smooth' : 'auto',
          });

          window.setTimeout(() => {
            isAutoScrolling = false;
            syncCurrentIndex();
          }, SNAP_LOCK_MS);
        };

        const resolveTriggerIndex = (trigger: HTMLElement) => {
          const currentSection = trigger.closest<HTMLElement>('[data-auto-scroll-section]');
          const sectionIndex = currentSection ? sections.indexOf(currentSection) : currentSnapIndex;
          return sectionIndex >= 0 ? sectionIndex : currentSnapIndex;
        };

        const bindDirectionalTriggers = (selector: string, direction: -1 | 1) => {
          const triggers = document.querySelectorAll<HTMLElement>(selector);

          triggers.forEach((trigger) => {
            trigger.addEventListener('click', () => {
              if (isAutoScrolling) return;

              const currentIndex = resolveTriggerIndex(trigger);
              const targetIndex = Math.max(
                0,
                Math.min(sections.length - 1, currentIndex + direction)
              );

              if (targetIndex !== currentIndex) {
                snapToIndex(targetIndex);
              }
            });
          });
        };

        bindDirectionalTriggers('[data-auto-scroll-prev]', -1);
        bindDirectionalTriggers('[data-auto-scroll-next]', 1);

        const handleScrollEnd = () => {
          if (isAutoScrolling || !AUTO_SNAP_ENABLED) return;

          const nextIndex = getSnapIndex();
          if (nextIndex === currentSnapIndex) return;

          snapToIndex(nextIndex);
        };

        const queueSnapCheck = () => {
          if (scrollEndTimer) {
            window.clearTimeout(scrollEndTimer);
          }

          scrollEndTimer = window.setTimeout(handleScrollEnd, SNAP_SETTLE_DELAY);
        };

        const handleScroll = () => {
          syncCurrentIndex();
          if (AUTO_SNAP_ENABLED) {
            queueSnapCheck();
          }
        };

        window.addEventListener('load', syncCurrentIndex);
        window.addEventListener('resize', syncCurrentIndex);
        window.addEventListener('hashchange', syncCurrentIndex);
        window.addEventListener('scroll', handleScroll, { passive: true });

        syncCurrentIndex();
      }
    </script>
  </body>
</html>
