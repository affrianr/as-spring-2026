---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Affrian & Sherly', description = 'Saturday, May 2nd, 2026' } =
  Astro.props;
---

<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Open Graph / rich link preview -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content={new URL('/assets/rich-preview.webp', Astro.url).href}
    />
    <meta property="og:image:width" content="375" />
    <meta property="og:image:height" content="375" />
    <meta property="og:image:alt" content={`${title} — Wedding Invitation`} />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content={new URL('/assets/rich-preview.webp', Astro.url).href}
    />
    <style>
      /* ── Cover page ── */
      #page-cover {
        position: fixed;
        inset: 0;
        z-index: 100000;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: linear-gradient(
          160deg,
          #f5f6ef 0%,
          #eef2e4 40%,
          #e8edda 100%
        );
        color: #1a1a1a;
        text-align: center;
        cursor: default;
      }
      .cover__greeting {
        font-size: clamp(0.75rem, 2vw, 0.9rem);
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: rgba(26, 26, 26, 0.4);
        margin-bottom: 0.75rem;
      }
      .cover__guest {
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.8rem, 5.5vw, 3rem);
        font-style: italic;
        font-weight: 400;
        line-height: 1.2;
        color: rgba(26, 26, 26, 0.85);
        margin-bottom: 1rem;
      }
      .cover__subtitle {
        font-size: clamp(0.875rem, 2.2vw, 1.1rem);
        line-height: 1.5;
        color: rgba(26, 26, 26, 0.6);
        margin-bottom: 2.5rem;
        max-width: 20rem;
      }
      .cover__open {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 2rem;
        border: 1px solid rgba(26, 26, 26, 0.15);
        border-radius: 9999px;
        background: transparent;
        color: rgba(26, 26, 26, 0.6);
        font-size: 0.75rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.3s ease;
      }
      .cover__open:disabled {
        cursor: wait;
        opacity: 0.55;
        border-color: rgba(26, 26, 26, 0.12);
        color: rgba(26, 26, 26, 0.42);
        transform: none;
      }
      .cover__open[data-state='loading'] svg {
        animation: cover-open-spin 1s linear infinite;
      }
      .cover__open:hover {
        border-color: rgba(26, 26, 26, 0.4);
        color: rgba(26, 26, 26, 0.9);
        transform: translateY(-2px);
      }
      .cover__open:disabled:hover {
        border-color: rgba(26, 26, 26, 0.12);
        color: rgba(26, 26, 26, 0.42);
        transform: none;
      }
      .cover__open svg {
        width: 1rem;
        height: 1rem;
        transition: transform 0.3s ease;
      }
      .cover__open:hover svg {
        transform: translateX(2px);
      }
      /* Cover exit animations */
      .cover--exiting {
        pointer-events: none;
      }
      .cover--exiting .cover__greeting,
      .cover--exiting .cover__guest,
      .cover--exiting .cover__subtitle {
        animation: cover-text-up 0.5s cubic-bezier(0.76, 0, 0.24, 1) forwards;
      }
      .cover--exiting .cover__guest {
        animation-delay: 0.06s;
      }
      .cover--exiting .cover__subtitle {
        animation-delay: 0.12s;
      }
      .cover--exiting .cover__open {
        animation: cover-btn-out 0.4s cubic-bezier(0.76, 0, 0.24, 1) forwards;
      }
      .cover--exiting {
        animation: cover-bg-fade 0.5s cubic-bezier(0.76, 0, 0.24, 1) 0.3s
          forwards;
      }
      @keyframes cover-text-up {
        0% {
          opacity: 1;
          transform: translateY(0);
        }
        100% {
          opacity: 0;
          transform: translateY(-2rem);
        }
      }
      @keyframes cover-btn-out {
        0% {
          opacity: 1;
          transform: scale(1);
        }
        100% {
          opacity: 0;
          transform: scale(0.9);
        }
      }
      @keyframes cover-bg-fade {
        0% {
          opacity: 1;
        }
        100% {
          opacity: 0;
        }
      }
      @keyframes cover-open-spin {
        from {
          transform: rotate(0deg);
        }
        to {
          transform: rotate(360deg);
        }
      }

      /* ── Intro panels (behind cover, revealed after cover exits) ── */
      #page-intro {
        position: fixed;
        inset: 0;
        z-index: 99999;
        overflow: hidden;
        pointer-events: none;
      }
      .page-intro__panel {
        position: absolute;
        top: 0;
        bottom: 0;
        width: 51%;
        background: #eef2e4;
      }
      .page-intro__panel--left {
        left: 0;
      }
      .page-intro__panel--right {
        right: 0;
      }
      .page-intro__panel--exit-left {
        animation: intro-panel-left 1s cubic-bezier(0.76, 0, 0.24, 1) forwards;
      }
      .page-intro__panel--exit-right {
        animation: intro-panel-right 1s cubic-bezier(0.76, 0, 0.24, 1) forwards;
        animation-delay: 0.06s;
      }
      @keyframes intro-panel-left {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-102%);
        }
      }
      @keyframes intro-panel-right {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(102%);
        }
      }
    </style>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Noto+Sans+JP:wght@300;400;500&family=Noto+Serif+JP:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen overflow-hidden">
    <audio
      id="bg-music"
      src="/music/love-wins-all-classic.mp3"
      preload="auto"
      loop
      playsinline></audio>

    <!-- Cover page — user must click to enter -->
    <div id="page-cover">
      <p class="cover__greeting">With joy & love</p>
      <p class="cover__guest" id="cover-guest-name">Our dear friend</p>
      <p class="cover__subtitle">We invite you to celebrate our special day</p>
      <button
        id="cover-open"
        class="cover__open"
        type="button"
        disabled
        data-state="loading"
        aria-busy="true"
      >
        <span id="cover-open-label">Preparing invitation...</span>
        <svg
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
        </svg>
      </button>
    </div>

    <!-- Intro panels (slide open after cover exits) -->
    <div id="page-intro" aria-hidden="true">
      <div class="page-intro__panel page-intro__panel--left"></div>
      <div class="page-intro__panel page-intro__panel--right"></div>
    </div>
    <slot />

    <script>
      import { gsap } from 'gsap';

      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      window.scrollTo(0, 0);

      const pageCover = document.getElementById(
        'page-cover',
      ) as HTMLDivElement | null;
      const guestEl = document.getElementById(
        'cover-guest-name',
      ) as HTMLElement | null;
      const openBtn = document.getElementById(
        'cover-open',
      ) as HTMLButtonElement | null;
      const openBtnLabel = document.getElementById(
        'cover-open-label',
      ) as HTMLElement | null;
      const pageIntro = document.getElementById(
        'page-intro',
      ) as HTMLDivElement | null;
      const panelLeft = document.querySelector(
        '.page-intro__panel--left',
      ) as HTMLDivElement | null;
      const panelRight = document.querySelector(
        '.page-intro__panel--right',
      ) as HTMLDivElement | null;
      const heroSection = document.getElementById('home') as HTMLElement | null;
      const bgMusic = document.getElementById(
        'bg-music',
      ) as HTMLAudioElement | null;
      const musicToggle = document.getElementById(
        'music-toggle',
      ) as HTMLButtonElement | null;
      const coverCopy = Array.from(
        document.querySelectorAll<HTMLElement>(
          '.cover__greeting, .cover__guest, .cover__subtitle',
        ),
      );
      const prefersReducedMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)',
      );
      const liteMotionMedia = window.matchMedia(
        '(max-width: 767px), (pointer: coarse)',
      );

      const COVER_DISMISSED_KEY = 'wedding-cover-dismissed';
      const GUEST_NAME_KEY = 'wedding-guest-name';
      const MUTE_PREF_KEY = 'wedding-music-muted';

      const getIntroTier = () =>
        prefersReducedMotion.matches
          ? 'reduced'
          : liteMotionMedia.matches
            ? 'lite'
            : 'full';

      let coverScrollY = 0;
      const coverScrollKeys = new Set([
        'ArrowUp',
        'ArrowDown',
        'PageUp',
        'PageDown',
        'Home',
        'End',
        ' ',
      ]);
      const preventCoverScroll = (event: Event) => {
        event.preventDefault();
      };
      const preventCoverKeyScroll = (event: KeyboardEvent) => {
        if (coverScrollKeys.has(event.key)) {
          event.preventDefault();
        }
      };
      const lockCoverScroll = () => {
        coverScrollY = 0;
        window.scrollTo(0, 0);
        document.documentElement.style.overflow = 'hidden';
        document.body.style.overflow = 'hidden';
        document.body.style.position = 'fixed';
        document.body.style.inset = `-${coverScrollY}px 0 0 0`;
        document.body.style.width = '100%';
        window.addEventListener('wheel', preventCoverScroll, {
          passive: false,
        });
        window.addEventListener('touchmove', preventCoverScroll, {
          passive: false,
        });
        window.addEventListener('keydown', preventCoverKeyScroll, {
          passive: false,
        });
      };
      const unlockCoverScroll = () => {
        window.removeEventListener('wheel', preventCoverScroll);
        window.removeEventListener('touchmove', preventCoverScroll);
        window.removeEventListener('keydown', preventCoverKeyScroll);
        document.documentElement.style.overflow = '';
        document.body.style.overflow = '';
        document.body.style.position = '';
        document.body.style.inset = '';
        document.body.style.width = '';
        window.scrollTo(0, coverScrollY);
      };

      const syncMuteUi = () => {
        if (!bgMusic || !musicToggle) return;
        const isMuted = bgMusic.muted;
        musicToggle.dataset.state = isMuted ? 'muted' : 'playing';
        musicToggle.setAttribute('aria-label', isMuted ? 'Unmute' : 'Mute');
      };

      const startBackgroundMusic = () => {
        if (!bgMusic) return;
        bgMusic.volume = 0.42;
        bgMusic.play().catch(() => {});
        window.dispatchEvent(new CustomEvent('music-started'));
        syncMuteUi();
      };

      const DEFAULT_GUEST_NAME = 'Our dear friend';

      if (bgMusic) {
        bgMusic.muted = window.localStorage.getItem(MUTE_PREF_KEY) === 'true';
      }

      if (musicToggle && bgMusic) {
        syncMuteUi();
        musicToggle.addEventListener('click', () => {
          bgMusic.muted = !bgMusic.muted;
          window.localStorage.setItem(MUTE_PREF_KEY, String(bgMusic.muted));
          syncMuteUi();
        });
      }

      const params = new URLSearchParams(window.location.search);
      const guestName = params.get('to');
      let persistedGuestName = guestName?.trim() ?? '';

      if (!persistedGuestName) {
        try {
          persistedGuestName =
            window.sessionStorage.getItem(GUEST_NAME_KEY)?.trim() ?? '';
        } catch {}
      } else {
        try {
          window.sessionStorage.setItem(GUEST_NAME_KEY, persistedGuestName);
        } catch {}
      }

      if (guestEl) {
        guestEl.textContent = decodeURIComponent(
          persistedGuestName || DEFAULT_GUEST_NAME,
        );
      }

      if (persistedGuestName && !guestName) {
        const nextUrl = new URL(window.location.href);
        nextUrl.searchParams.set('to', persistedGuestName);
        window.history.replaceState({}, '', nextUrl);
      }

      if (persistedGuestName) {
        document
          .querySelectorAll<HTMLAnchorElement>('a[href]')
          .forEach((anchor) => {
            const href = anchor.getAttribute('href');
            if (
              !href ||
              href.startsWith('#') ||
              href.startsWith('mailto:') ||
              href.startsWith('tel:') ||
              href.startsWith('javascript:')
            ) {
              return;
            }

            const targetUrl = new URL(href, window.location.origin);
            if (targetUrl.origin !== window.location.origin) return;

            targetUrl.searchParams.set('to', persistedGuestName);
            anchor.href =
              targetUrl.pathname + targetUrl.search + targetUrl.hash;
          });
      }

      const setCoverButtonReadyState = (isReady: boolean) => {
        if (!openBtn || !openBtnLabel) return;

        openBtn.disabled = !isReady;
        openBtn.dataset.state = isReady ? 'ready' : 'loading';
        openBtn.setAttribute('aria-busy', isReady ? 'false' : 'true');
        openBtnLabel.textContent = isReady
          ? 'Open Invitation'
          : 'Preparing invitation...';
      };

      const waitForImageSource = (src: string) =>
        new Promise<void>((resolve) => {
          const image = new Image();
          image.decoding = 'async';
          image.onload = () => resolve();
          image.onerror = () => resolve();
          image.src = src;

          if (image.complete) {
            resolve();
          }
        });

      const waitForAudioSource = (audio: HTMLAudioElement | null) =>
        new Promise<void>((resolve) => {
          if (!audio) {
            resolve();
            return;
          }

          const done = () => resolve();
          audio.addEventListener('canplaythrough', done, { once: true });
          audio.addEventListener('error', done, { once: true });
          audio.load();

          if (audio.readyState >= HTMLMediaElement.HAVE_ENOUGH_DATA) {
            resolve();
          }
        });

      const waitForCriticalAssets = async () => {
        const fontsReady = document.fonts?.ready ?? Promise.resolve();

        await Promise.all([
          fontsReady,
          waitForImageSource('/assets/p1.webp'),
          waitForImageSource('/assets/p1b-r1-crop-smaller.webp'),
          waitForImageSource('/assets/gunung.webp'),
          waitForAudioSource(bgMusic),
        ]);
      };

      const finishIntro = (tier: 'reduced' | 'lite' | 'full') => {
        heroSection?.classList.add('hero-section--loaded');
        document.body.classList.remove('overflow-hidden');
        unlockCoverScroll();
        pageCover?.remove();
        pageIntro?.remove();
        window.dispatchEvent(
          new CustomEvent('intro-done', {
            detail: { tier, reduced: tier === 'reduced' },
          }),
        );
      };

      const playIntroTimeline = () => {
        const tier = getIntroTier();

        if (
          tier === 'reduced' ||
          !pageCover ||
          !pageIntro ||
          !panelLeft ||
          !panelRight
        ) {
          finishIntro(tier);
          return;
        }

        const panelDuration = tier === 'lite' ? 0.72 : 0.96;
        const introTimeline = gsap.timeline({
          defaults: { ease: 'power4.inOut' },
          onComplete: () => finishIntro(tier),
        });

        introTimeline
          .to(coverCopy, {
            y: -28,
            autoAlpha: 0,
            duration: 0.42,
            stagger: 0.06,
          })
          .to(
            openBtn,
            {
              scale: 0.92,
              autoAlpha: 0,
              duration: 0.34,
            },
            '<+0.04',
          )
          .to(
            pageCover,
            {
              autoAlpha: 0,
              duration: 0.38,
            },
            '-=0.12',
          )
          .set(pageCover, { display: 'none' })
          .call(() => {
            heroSection?.classList.add('hero-section--loaded');
          })
          .to(
            panelLeft,
            {
              xPercent: -102,
              duration: panelDuration,
            },
            '>-0.02',
          )
          .to(
            panelRight,
            {
              xPercent: 102,
              duration: panelDuration,
            },
            '<+0.04',
          );
      };

      try {
        window.sessionStorage.removeItem(COVER_DISMISSED_KEY);
      } catch {}

      lockCoverScroll();

      waitForCriticalAssets().finally(() => {
        setCoverButtonReadyState(true);
      });

      openBtn?.addEventListener('click', () => {
        if (openBtn.disabled) return;

        try {
          window.sessionStorage.setItem(COVER_DISMISSED_KEY, 'true');
        } catch {}

        openBtn.disabled = true;
        startBackgroundMusic();
        playIntroTimeline();
      });

      const sections = Array.from(
        document.querySelectorAll<HTMLElement>('[data-auto-scroll-section]'),
      );

      if (sections.length > 1) {
        const AUTO_SNAP_ENABLED = !prefersReducedMotion.matches;
        const SNAP_THRESHOLD = 0.35;
        const SNAP_LOCK_MS = 700;

        let currentSnapIndex = 0;
        let isAutoScrolling = false;

        const getHeaderOffset = () => {
          const header = document.querySelector<HTMLElement>(
            '[data-auto-scroll-header]',
          );
          return header ? header.getBoundingClientRect().height : 0;
        };

        const getSectionTop = (section: HTMLElement) =>
          window.scrollY + section.getBoundingClientRect().top;

        const getTargetTop = (section: HTMLElement) => {
          const headerOffset = getHeaderOffset();
          const sectionTop = getSectionTop(section);
          const visibleHeight = window.innerHeight - headerOffset;
          const sectionHeight = section.getBoundingClientRect().height;
          const isDesktopViewport = window.innerWidth >= 1024;
          const shouldAlignStart =
            isDesktopViewport ||
            section.dataset.autoScrollAlign === 'start' ||
            section.hasAttribute('data-auto-scroll-no-center');

          if (!shouldAlignStart && sectionHeight < visibleHeight) {
            const centeredTop =
              sectionTop - headerOffset - (visibleHeight - sectionHeight) / 2;
            return Math.max(0, centeredTop);
          }

          return Math.max(0, sectionTop - headerOffset);
        };

        const getSnapIndex = () => {
          const anchorY =
            window.scrollY +
            getHeaderOffset() +
            window.innerHeight * SNAP_THRESHOLD;

          let index = 0;
          sections.forEach((section, sectionIndex) => {
            if (getSectionTop(section) <= anchorY) {
              index = sectionIndex;
            }
          });

          return index;
        };

        const syncCurrentIndex = () => {
          currentSnapIndex = getSnapIndex();
        };

        const snapToIndex = (nextIndex: number) => {
          const section = sections[nextIndex];
          if (!section) return;

          isAutoScrolling = true;
          currentSnapIndex = nextIndex;

          window.scrollTo({
            top: getTargetTop(section),
            behavior: AUTO_SNAP_ENABLED ? 'smooth' : 'auto',
          });

          window.setTimeout(() => {
            isAutoScrolling = false;
            syncCurrentIndex();
          }, SNAP_LOCK_MS);
        };

        const resolveTriggerIndex = (trigger: HTMLElement) => {
          const currentSection = trigger.closest<HTMLElement>(
            '[data-auto-scroll-section]',
          );
          const sectionIndex = currentSection
            ? sections.indexOf(currentSection)
            : currentSnapIndex;
          return sectionIndex >= 0 ? sectionIndex : currentSnapIndex;
        };

        const bindDirectionalTriggers = (
          selector: string,
          direction: -1 | 1,
        ) => {
          const triggers = document.querySelectorAll<HTMLElement>(selector);

          triggers.forEach((trigger) => {
            trigger.addEventListener('click', () => {
              if (isAutoScrolling) return;

              const currentIndex = resolveTriggerIndex(trigger);
              const targetIndex = Math.max(
                0,
                Math.min(sections.length - 1, currentIndex + direction),
              );

              if (targetIndex !== currentIndex) {
                snapToIndex(targetIndex);
              }
            });
          });
        };

        bindDirectionalTriggers('[data-auto-scroll-prev]', -1);
        bindDirectionalTriggers('[data-auto-scroll-next]', 1);

        const handleScroll = () => {
          syncCurrentIndex();
        };

        window.addEventListener('load', syncCurrentIndex);
        window.addEventListener('resize', syncCurrentIndex);
        window.addEventListener('hashchange', syncCurrentIndex);
        window.addEventListener('scroll', handleScroll, { passive: true });

        syncCurrentIndex();
      }
    </script>

    <!-- ── Souvenir Voucher FAB ── -->
    <style>
      #voucher-fab {
        position: fixed;
        bottom: calc(1.25rem + env(safe-area-inset-bottom));
        left: calc(1.25rem + env(safe-area-inset-left));
        z-index: 45;
        width: 4rem;
        height: 4rem;
        border-radius: 50%;
        background: #e1ff00;
        color: #1a1a1a;
        font-size: 1.5rem;
        border: none;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18);
        display: flex;
        align-items: center;
        justify-content: center;
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease;
      }
      #voucher-fab:hover {
        transform: scale(1.08) translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.22);
      }
      @media (max-width: 639px) {
        #voucher-fab {
          width: 3.75rem;
          height: 3.75rem;
          font-size: 1.35rem;
        }
      }

      #voucher-modal {
        position: fixed;
        inset: 0;
        z-index: 9000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
      }
      #voucher-modal[hidden] {
        display: none;
      }

      #voucher-modal__backdrop {
        position: absolute;
        inset: 0;
        background: rgba(10, 10, 10, 0.72);
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
      }

      #voucher-modal__card {
        position: relative;
        z-index: 1;
        background: transparent;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.25rem;
        max-width: 320px;
        width: 100%;
      }

      #voucher-modal__close {
        align-self: flex-end;
        background: rgba(255, 255, 255, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: #fff;
        border-radius: 50%;
        width: 2.25rem;
        height: 2.25rem;
        font-size: 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
      }
      #voucher-modal__close:hover {
        background: rgba(255, 255, 255, 0.28);
      }

      #voucher-polaroid {
        background: #ffffff;
        padding: 0.85rem 0.85rem 4.35rem;
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.35);
        transform: rotate(-1.5deg);
        width: 100%;
      }
      #voucher-polaroid__img {
        width: 100%;
        display: block;
        height: auto;
        object-fit: contain;
        aspect-ratio: auto;
      }
      #voucher-polaroid__label {
        margin-top: 1.1rem;
        text-align: center;
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 0.82rem;
        line-height: 1.1;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: rgba(26, 26, 26, 0.68);
      }
      #voucher-polaroid__name {
        margin-top: 0.45rem;
        text-align: center;
        font-family: 'Playfair Display', Georgia, serif;
        font-style: italic;
        font-size: clamp(1.35rem, 3vw, 1.9rem);
        line-height: 1.12;
        color: #1a1a1a;
        min-height: 2.3em;
        white-space: pre-line;
        letter-spacing: 0.02em;
      }

      #voucher-modal__download {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: #e1ff00;
        color: #1a1a1a;
        font-family: 'Playfair Display', Georgia, serif;
        font-style: italic;
        font-size: 0.95rem;
        font-weight: 600;
        padding: 0.65rem 1.5rem;
        border-radius: 2rem;
        text-decoration: none;
        box-shadow: 0 4px 14px rgba(225, 255, 0, 0.3);
        transition:
          transform 0.2s,
          box-shadow 0.2s;
        border: 0;
        cursor: pointer;
      }
      #voucher-modal__download:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(225, 255, 0, 0.4);
      }
      #voucher-modal__download:disabled {
        opacity: 0.6;
        cursor: wait;
        transform: none;
        box-shadow: 0 4px 14px rgba(225, 255, 0, 0.2);
      }
    </style>

    <button
      id="voucher-fab"
      aria-label="Lihat Voucher Suvenir"
      title="Voucher Suvenir">🎁</button
    >

    <div
      id="voucher-modal"
      role="dialog"
      aria-modal="true"
      aria-label="Voucher Suvenir"
      hidden
    >
      <div id="voucher-modal__backdrop"></div>
      <div id="voucher-modal__card">
        <button id="voucher-modal__close" aria-label="Tutup">✕</button>
        <div id="voucher-polaroid">
          <img
            id="voucher-polaroid__img"
            src="/assets/voucher.webp"
            alt="Voucher Suvenir"
            crossorigin="anonymous"
          />
          <p id="voucher-polaroid__label">Just for you,</p>
          <p id="voucher-polaroid__name"></p>
        </div>
        <button id="voucher-modal__download" type="button" disabled
          >Menyiapkan Voucher...</button
        >
      </div>
    </div>

    <script>
      (() => {
        const fab = document.getElementById('voucher-fab') as HTMLButtonElement;
        const modal = document.getElementById(
          'voucher-modal',
        ) as HTMLDivElement;
        const closeBtn = document.getElementById(
          'voucher-modal__close',
        ) as HTMLButtonElement;
        const backdrop = document.getElementById(
          'voucher-modal__backdrop',
        ) as HTMLDivElement;
        const nameEl = document.getElementById(
          'voucher-polaroid__name',
        ) as HTMLParagraphElement;
        const downloadButton = document.getElementById(
          'voucher-modal__download',
        ) as HTMLButtonElement;

        const params = new URLSearchParams(location.search);
        const VOUCHER_LABEL = 'Just for you,';
        const DEFAULT_GUEST_NAME = 'Our dear friend';
        const FILENAME = 'voucher-suvenir.png';
        const EXPORT_FONT_MAX = 168;
        const EXPORT_FONT_MIN = 96;
        const EXPORT_SIDE_INSET = 84;
        const EXPORT_BOTTOM_BAND = 360;
        const EXPORT_LINE_HEIGHT = 1.08;
        const EXPORT_LABEL_SIZE = 40;
        const EXPORT_LABEL_GAP = 18;
        const guestName =
          params.get('to')?.trim() ||
          (() => {
            try {
              return sessionStorage.getItem('wedding-guest-name')?.trim() ?? '';
            } catch {
              return '';
            }
          })() ||
          DEFAULT_GUEST_NAME;
        nameEl.textContent = guestName;

        let preparedBlob: Blob | null = null;
        let preparedUrl = '';
        let preparedName = '';
        let isPreparing = false;

        const setDownloadState = (label: string, disabled: boolean) => {
          downloadButton.textContent = label;
          downloadButton.disabled = disabled;
        };

        const revokePreparedUrl = () => {
          if (!preparedUrl) return;
          URL.revokeObjectURL(preparedUrl);
          preparedUrl = '';
        };

        const setVoucherNamePreview = (name: string, lines: string[]) => {
          nameEl.textContent = lines.length > 0 ? lines.join('\n') : name;
        };

        const setCanvasFont = (ctx: CanvasRenderingContext2D, size: number) => {
          ctx.font = `italic 500 ${size}px 'Playfair Display', Georgia, serif`;
        };

        const measureLineWidth = (
          ctx: CanvasRenderingContext2D,
          line: string,
          size: number,
        ) => {
          setCanvasFont(ctx, size);
          return ctx.measureText(line).width;
        };

        const fitLineSize = (
          ctx: CanvasRenderingContext2D,
          line: string,
          maxWidth: number,
        ) => {
          let size = EXPORT_FONT_MAX;
          while (
            size > EXPORT_FONT_MIN &&
            measureLineWidth(ctx, line, size) > maxWidth
          )
            size -= 2;
          return size;
        };

        const pickTwoLineSplit = (
          ctx: CanvasRenderingContext2D,
          name: string,
          maxWidth: number,
        ) => {
          const words = name.trim().split(/\s+/).filter(Boolean);
          if (words.length < 2) return null;

          let best: {
            lines: string[];
            size: number;
            overflow: number;
            balance: number;
          } | null = null;
          for (let index = 1; index < words.length; index += 1) {
            const lines = [
              words.slice(0, index).join(' '),
              words.slice(index).join(' '),
            ];
            const longestLine = Math.max(...lines.map((line) => line.length));
            let size = EXPORT_FONT_MAX;
            while (
              size > EXPORT_FONT_MIN &&
              lines.some((line) => measureLineWidth(ctx, line, size) > maxWidth)
            ) {
              size -= 2;
            }
            const widths = lines.map((line) =>
              measureLineWidth(ctx, line, size),
            );
            const overflow = Math.max(...widths) - maxWidth;
            const balance = Math.abs(lines[0].length - lines[1].length);
            if (
              !best ||
              size > best.size ||
              (size === best.size && overflow < best.overflow) ||
              (size === best.size &&
                overflow === best.overflow &&
                balance < best.balance)
            ) {
              best = { lines, size, overflow, balance };
            }
          }
          return best;
        };

        const getNameLayout = (
          ctx: CanvasRenderingContext2D,
          name: string,
          maxWidth: number,
        ) => {
          const trimmedName = name.trim();
          if (!trimmedName) return { lines: [], fontSize: EXPORT_FONT_MAX };

          const singleLineSize = fitLineSize(ctx, trimmedName, maxWidth);
          if (measureLineWidth(ctx, trimmedName, singleLineSize) <= maxWidth) {
            return { lines: [trimmedName], fontSize: singleLineSize };
          }

          const splitLayout = pickTwoLineSplit(ctx, trimmedName, maxWidth);
          if (splitLayout) {
            return { lines: splitLayout.lines, fontSize: splitLayout.size };
          }

          return { lines: [trimmedName], fontSize: EXPORT_FONT_MIN };
        };

        async function buildPolaroidBlob(name: string): Promise<Blob | null> {
          return new Promise((resolve) => {
            const img = new Image();
            img.crossOrigin = 'anonymous';
            img.src = '/assets/voucher.webp';
            img.onload = async () => {
              const PAD = 48;
              const BOTTOM = EXPORT_BOTTOM_BAND;
              const W = img.naturalWidth + PAD * 2;
              const H = img.naturalHeight + PAD + BOTTOM;
              const canvas = document.createElement('canvas');
              canvas.width = W;
              canvas.height = H;
              const ctx = canvas.getContext('2d')!;
              ctx.fillStyle = '#ffffff';
              ctx.fillRect(0, 0, W, H);
              ctx.drawImage(img, PAD, PAD, img.naturalWidth, img.naturalHeight);
              if (name) {
                const maxTextWidth = W - EXPORT_SIDE_INSET * 2;
                const layout = getNameLayout(ctx, name, maxTextWidth);
                const labelLineHeight = EXPORT_LABEL_SIZE * 1.1;
                const lineHeight = layout.fontSize * EXPORT_LINE_HEIGHT;
                const bandTop = img.naturalHeight + PAD;
                const textBlockHeight =
                  labelLineHeight +
                  EXPORT_LABEL_GAP +
                  lineHeight * layout.lines.length;
                const labelY =
                  bandTop + (BOTTOM - textBlockHeight) / 2 + EXPORT_LABEL_SIZE;
                const firstLineY = labelY + EXPORT_LABEL_GAP + layout.fontSize;

                ctx.fillStyle = '#1a1a1a';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'alphabetic';
                ctx.font = `${EXPORT_LABEL_SIZE}px 'Playfair Display', Georgia, serif`;
                ctx.fillStyle = 'rgba(26, 26, 26, 0.68)';
                ctx.fillText(VOUCHER_LABEL, W / 2, labelY);

                ctx.fillStyle = '#1a1a1a';
                setCanvasFont(ctx, layout.fontSize);
                layout.lines.forEach((line, index) => {
                  ctx.fillText(line, W / 2, firstLineY + index * lineHeight);
                });
              }
              resolve(
                await new Promise((blobResolve) =>
                  canvas.toBlob(blobResolve, 'image/png'),
                ),
              );
            };
            img.onerror = () => resolve(null);
          });
        }

        const prepareVoucher = async () => {
          if (preparedBlob && preparedName === guestName) {
            setDownloadState('↓ Save Voucher', false);
            return preparedBlob;
          }
          if (isPreparing) return null;

          isPreparing = true;
          setDownloadState('Preparing Voucher...', true);
          revokePreparedUrl();

          try {
            preparedBlob = await buildPolaroidBlob(guestName);
            preparedName = guestName;
            if (!preparedBlob) {
              setDownloadState('Failed to Prepare Voucher', true);
              return null;
            }
            preparedUrl = URL.createObjectURL(preparedBlob);
            setDownloadState('↓ Save Voucher', false);
            return preparedBlob;
          } finally {
            isPreparing = false;
          }
        };

        fab.addEventListener('click', () => {
          const previewCanvas = document.createElement('canvas');
          const previewCtx = previewCanvas.getContext('2d');
          if (previewCtx) {
            const previewLayout = getNameLayout(previewCtx, guestName, 920);
            setVoucherNamePreview(guestName, previewLayout.lines);
          } else {
            setVoucherNamePreview(guestName, []);
          }
          modal.hidden = false;
          document.body.style.overflow = 'hidden';
          void prepareVoucher();
        });

        downloadButton.addEventListener('click', async () => {
          const blob = preparedBlob ?? (await prepareVoucher());
          if (!blob) return;

          const href = preparedUrl || URL.createObjectURL(blob);
          const shouldRevokeHref = href !== preparedUrl;
          const link = document.createElement('a');
          link.href = href;
          link.download = FILENAME;
          link.rel = 'noopener';
          document.body.appendChild(link);
          link.click();
          link.remove();
          if (shouldRevokeHref) {
            window.setTimeout(() => URL.revokeObjectURL(href), 1000);
          }
        });

        const closeModal = () => {
          modal.hidden = true;
          document.body.style.overflow = '';
        };
        closeBtn.addEventListener('click', closeModal);
        backdrop.addEventListener('click', closeModal);
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') closeModal();
        });
        window.addEventListener('pagehide', revokePreparedUrl);
      })();
    </script>
  </body>
</html>
