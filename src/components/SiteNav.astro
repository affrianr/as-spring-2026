---
interface Props {
  currentPage?: 'home' | 'gallery' | 'thanks';
  useRootAnchors?: boolean;
  showMusicToggle?: boolean;
  forceScrolled?: boolean;
}

const {
  currentPage = 'home',
  useRootAnchors = false,
  showMusicToggle = false,
  forceScrolled = false,
} = Astro.props;

const sectionPrefix = useRootAnchors ? '/' : '';
const logoHref = currentPage === 'home' ? null : '/';
const navClass = [
  'fixed top-0 left-0 right-0 z-9999 transition-all duration-500',
  forceScrolled ? 'scrolled' : '',
]
  .filter(Boolean)
  .join(' ');

const navLinks = [
  { href: `${sectionPrefix}#home`, label: 'Top', key: 'top' },
  { href: `${sectionPrefix}#greeting`, label: 'Greeting', key: 'greeting' },
  { href: `${sectionPrefix}#details`, label: 'Details', key: 'details' },
  { href: `${sectionPrefix}#access`, label: 'Access', key: 'access' },
  { href: `${sectionPrefix}#wishes`, key: 'wishes', isWish: true },
  { href: '/gallery', label: 'Gallery', key: 'gallery' },
];

const isActive = (key: string) => currentPage === key;
---

<nav id="main-nav" data-auto-scroll-header class={navClass}>
  <div
    class="nav-shell desktop-shell max-w-5xl mx-auto px-6 py-4 flex items-center justify-between"
  >
    {
      logoHref ? (
        <a
          href={logoHref}
          class="font-display text-sm tracking-widest uppercase nav-logo text-white drop-shadow-sm"
        >
          A &amp; S
        </a>
      ) : (
        <span class="font-display text-sm tracking-widest uppercase nav-logo text-white drop-shadow-sm">
          A &amp; S
        </span>
      )
    }

    <div class="flex items-center gap-6">
      <div
        class="hidden lg:flex gap-8 text-xs tracking-widest uppercase text-white/70"
      >
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class={`nav-link relative hover:text-white transition-colors duration-300${
                isActive(link.key) ? ' text-white' : ''
              }`}
            >
              {link.isWish ? (
                <>
                  <span class="lang-mix">Ucapan</span>
                  <span class="lang-en">Wish</span>
                </>
              ) : (
                link.label
              )}
            </a>
          ))
        }
      </div>

      <div class="flex items-center gap-2.5">
        <button
          id="lang-toggle"
          class="lang-toggle flex items-center gap-1.5 text-[10px] tracking-widest uppercase text-white/60 hover:text-white border border-white/20 hover:border-white/40 rounded-full px-3 py-1.5 transition-all duration-300"
          aria-label="Toggle language"
        >
          <span class="lang-label-mix">ID / EN</span>
          <span class="lang-label-en hidden">EN</span>
        </button>

        {
          showMusicToggle && (
            <button
              id="music-toggle"
              type="button"
              class="music-toggle"
              aria-label="Mute"
              data-state="playing"
            >
              <span class="music-toggle__pulse" aria-hidden="true" />
              <svg
                class="music-toggle__icon music-toggle__icon--on"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.8"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15.536 8.464a5 5 0 010 7.072M17.95 6.05a8 8 0 010 11.9M6.5 8.5H4a1 1 0 00-1 1v5a1 1 0 001 1h2.5l4.5 4V4.5l-4.5 4z"
                />
              </svg>
              <svg
                class="music-toggle__icon music-toggle__icon--off"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.8"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M6.5 8.5H4a1 1 0 00-1 1v5a1 1 0 001 1h2.5l4.5 4V4.5l-4.5 4zM17 9.5l5 5m0-5l-5 5"
                />
              </svg>
            </button>
          )
        }

        <button
          class="mobile-nav__toggle lg:hidden"
          aria-label="Open navigation menu"
          aria-expanded="false"
          aria-controls="mobile-sidebar"
          data-mobile-nav-toggle
        >
          <svg
            class="mobile-nav__icon mobile-nav__icon--menu"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.8"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</nav>

<!-- Sidebar backdrop -->
<div
  class="mobile-sidebar__backdrop lg:hidden"
  aria-hidden="true"
  data-mobile-nav-backdrop
>
</div>

<!-- Sidebar panel -->
<aside
  id="mobile-sidebar"
  class="mobile-sidebar lg:hidden"
  aria-label="Navigation menu"
  data-mobile-nav-sidebar
>
  <div class="mobile-sidebar__header">
    <span class="font-display text-sm tracking-widest uppercase text-white/80"
      >A & S</span
    >
    <button
      class="mobile-sidebar__close"
      aria-label="Close navigation menu"
      data-mobile-nav-toggle
    >
      <svg
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.8"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 6l12 12M18 6 6 18"></path>
      </svg>
    </button>
  </div>

  <div class="mobile-sidebar__greeting" aria-live="polite">
    <p class="mobile-sidebar__greeting-text" id="sidebar-guest-greeting"></p>
  </div>

  <nav class="mobile-sidebar__links">
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class={`mobile-sidebar__link${isActive(link.key) ? ' mobile-sidebar__link--active' : ''}`}
          data-mobile-nav-link
        >
          {link.isWish ? (
            <>
              <span class="lang-mix">Ucapan</span>
              <span class="lang-en">Wish</span>
            </>
          ) : (
            link.label
          )}
        </a>
      ))
    }
  </nav>
</aside>

<style>
  .mobile-nav__toggle {
    position: relative;
    display: inline-flex;
    width: 2.9rem;
    height: 2.9rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.72);
    cursor: pointer;
    transition:
      transform 0.25s ease,
      background 0.25s ease,
      border-color 0.25s ease,
      color 0.25s ease;
  }

  .mobile-nav__toggle:hover {
    transform: translateY(-1px);
    color: rgba(255, 255, 255, 0.95);
    border-color: rgba(255, 255, 255, 0.34);
    background: rgba(255, 255, 255, 0.08);
  }

  .mobile-nav__toggle:active {
    transform: scale(0.96);
  }

  .mobile-nav__icon {
    width: 1rem;
    height: 1rem;
  }

  /* ── Backdrop ── */
  .mobile-sidebar__backdrop {
    position: fixed;
    inset: 0;
    z-index: 99998;
    background: rgba(6, 19, 24, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .mobile-sidebar__backdrop--open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Sidebar ── */
  .mobile-sidebar {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 99999;
    width: min(18rem, 80vw);
    background: rgba(10, 35, 45, 0.97);
    border-left: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(24px) saturate(150%);
    -webkit-backdrop-filter: blur(24px) saturate(150%);
    transform: translateX(100%);
    transition: transform 0.38s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    padding: max(1.5rem, env(safe-area-inset-top)) 1.5rem
      max(1.5rem, env(safe-area-inset-bottom))
      max(1.5rem, env(safe-area-inset-left));
    overflow-y: auto;
  }

  .mobile-sidebar--open {
    transform: translateX(0);
  }

  .mobile-sidebar__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .mobile-sidebar__greeting {
    margin-bottom: 1.75rem;
    min-height: 1.5rem;
  }

  .mobile-sidebar__greeting-text {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.4;
  }

  .mobile-sidebar__greeting-text:empty {
    display: none;
  }

  .mobile-sidebar__close {
    display: inline-flex;
    width: 2.4rem;
    height: 2.4rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    transition:
      background 0.2s ease,
      color 0.2s ease;
  }

  .mobile-sidebar__close svg {
    width: 1rem;
    height: 1rem;
  }

  .mobile-sidebar__close:hover {
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.95);
  }

  .mobile-sidebar__links {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-sidebar__link {
    display: flex;
    align-items: center;
    min-height: 3.25rem;
    padding: 0.9rem 1rem;
    border-radius: 1rem;
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.72rem;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .mobile-sidebar__link:hover {
    background: rgba(255, 255, 255, 0.07);
    color: rgba(255, 255, 255, 0.95);
    transform: translateX(3px);
  }

  .mobile-sidebar__link--active {
    background: rgba(225, 255, 0, 0.1);
    color: rgba(241, 248, 207, 0.98);
  }

  @media (min-width: 1024px) {
    .mobile-nav__toggle,
    .mobile-sidebar,
    .mobile-sidebar__backdrop {
      display: none !important;
    }
  }
</style>

<script>
  const toggleBtns = document.querySelectorAll<HTMLElement>(
    '[data-mobile-nav-toggle]',
  );
  const sidebar = document.querySelector<HTMLElement>(
    '[data-mobile-nav-sidebar]',
  );
  const backdrop = document.querySelector<HTMLElement>(
    '[data-mobile-nav-backdrop]',
  );
  const links = document.querySelectorAll<HTMLElement>(
    '[data-mobile-nav-link]',
  );
  const greetingEl = document.getElementById('sidebar-guest-greeting');

  // Populate guest greeting from ?to= param or sessionStorage
  const GUEST_NAME_KEY = 'wedding-guest-name';
  const guestName = (
    new URLSearchParams(window.location.search).get('to') ||
    (() => {
      try {
        return window.sessionStorage.getItem(GUEST_NAME_KEY);
      } catch {
        return null;
      }
    })()
  )?.trim();
  if (greetingEl && guestName) {
    greetingEl.textContent = `Hi, ${decodeURIComponent(guestName)}!`;
  }

  const openSidebar = () => {
    sidebar?.classList.add('mobile-sidebar--open');
    backdrop?.classList.add('mobile-sidebar__backdrop--open');
    document.body.style.overflow = 'hidden';
    toggleBtns[0]?.setAttribute('aria-expanded', 'true');
  };

  const closeSidebar = () => {
    sidebar?.classList.remove('mobile-sidebar--open');
    backdrop?.classList.remove('mobile-sidebar__backdrop--open');
    document.body.style.overflow = '';
    toggleBtns[0]?.setAttribute('aria-expanded', 'false');
  };

  toggleBtns.forEach((btn) =>
    btn.addEventListener('click', () => {
      const isOpen = sidebar?.classList.contains('mobile-sidebar--open');
      isOpen ? closeSidebar() : openSidebar();
    }),
  );

  backdrop?.addEventListener('click', closeSidebar);

  links.forEach((link) => link.addEventListener('click', closeSidebar));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSidebar();
  });
</script>
